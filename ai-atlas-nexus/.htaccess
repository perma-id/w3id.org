# w3id.org/ai-atlas-nexus — An ontology describing AI systems and their risks
Header set Access-Control-Allow-Origin *
Options +FollowSymLinks
RewriteEngine on

# Base namespace -> GitHub Pages 
RewriteRule ^$ https://ibm.github.io/ai-atlas-nexus/ontology/ [R=302,L]

# Pass-through for everything under /ontology/
RewriteRule ^(.*)$ https://ibm.github.io/ai-atlas-nexus/ontology/$1 [R=302,L]