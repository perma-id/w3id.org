@prefix fm:    <https://w3id.org/fair-mind/ap#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix prov:  <http://www.w3.org/ns/prov#> .
@prefix dc:    <http://purl.org/dc/terms/> .
@prefix efo:   <http://www.ebi.ac.uk/efo/> .
@prefix ncit:  <http://purl.obolibrary.org/obo/NCIT_> .
@prefix snomed: <http://snomed.info/id/> .
@prefix loinc: <http://loinc.org/> .
@prefix cmo:   <http://purl.obolibrary.org/obo/CMO_> .
@prefix chebi: <http://purl.obolibrary.org/obo/CHEBI_> .
@prefix mesh:  <http://id.nlm.nih.gov/mesh/> .
@prefix vso:   <http://purl.obolibrary.org/obo/VSO_> .
@prefix bcio:  <http://humanbehaviourchange.org/ontology/> .
@prefix sio:   <http://semanticscience.org/resource/> .

#################################################################
# Ontology Header
#################################################################

<https://w3id.org/fair-mind/ap> a owl:Ontology ;
    dc:title "FAIR-MIND Application Profile" ;
    dc:description "AP for integrating depression clinical data with ECG-derived HRV biomarkers" ;
    owl:versionInfo "v4.0" .

#################################################################
# Class Hierarchy
#################################################################

fm:Variable a owl:Class .

fm:Identifier a owl:Class ; rdfs:subClassOf fm:Variable .
fm:ProvenanceVar a owl:Class ; rdfs:subClassOf fm:Variable .
fm:Timestamp a owl:Class ; rdfs:subClassOf fm:Variable .
fm:DemographicVar a owl:Class ; rdfs:subClassOf fm:Variable .
fm:ClinicalVar a owl:Class ; rdfs:subClassOf fm:Variable .
fm:MedicationVar a owl:Class ; rdfs:subClassOf fm:Variable .
fm:ComputedVariable a owl:Class ; rdfs:subClassOf fm:Variable .

fm:HRVFeature a owl:Class ; rdfs:subClassOf fm:ComputedVariable .
fm:TimeDomainHRV a owl:Class ; rdfs:subClassOf fm:HRVFeature .
fm:SpectralHRV a owl:Class ; rdfs:subClassOf fm:HRVFeature .
fm:PoincareHRV a owl:Class ; rdfs:subClassOf fm:HRVFeature .
fm:NonlinearHRV a owl:Class ; rdfs:subClassOf fm:HRVFeature .
fm:PhysiologicalRate a owl:Class ; rdfs:subClassOf fm:ComputedVariable .

fm:APLayer a owl:Class .
fm:Layer1_Clinical a owl:Class, owl:NamedIndividual ; rdfs:subClassOf fm:APLayer .
fm:Layer2_Biomarkers a owl:Class, owl:NamedIndividual ; rdfs:subClassOf fm:APLayer .
fm:Layer3_Provenance a owl:Class, owl:NamedIndividual ; rdfs:subClassOf fm:APLayer .
fm:Layer4_Medications a owl:Class, owl:NamedIndividual ; rdfs:subClassOf fm:APLayer .

fm:SignalSource a owl:Class .
fm:RRIntervals a owl:Class, owl:NamedIndividual ; rdfs:subClassOf fm:SignalSource .
fm:ECGSignal a owl:Class, owl:NamedIndividual ; rdfs:subClassOf fm:SignalSource .

#################################################################
# Object Properties
#################################################################

fm:hasOntologyTerm a owl:ObjectProperty ;
    rdfs:domain fm:Variable ;
    rdfs:comment "Links a variable to its external ontology concept URI" .

fm:computedFrom a owl:ObjectProperty ;
    rdfs:domain fm:ComputedVariable ;
    rdfs:range fm:SignalSource ;
    rdfs:comment "Source signal from which this variable is computed" .

fm:belongsToLayer a owl:ObjectProperty ;
    rdfs:domain fm:Variable ;
    rdfs:range fm:APLayer .

#################################################################
# Datatype Properties
#################################################################

fm:variableName a owl:DatatypeProperty ; rdfs:range xsd:string .
fm:mappingType a owl:DatatypeProperty ; rdfs:range xsd:string .
fm:pipelineStatus a owl:DatatypeProperty ; rdfs:range xsd:string .
fm:refinementNotes a owl:DatatypeProperty ; rdfs:range xsd:string .
fm:uriVerified a owl:DatatypeProperty ; rdfs:range xsd:string .
fm:frequencyBand a owl:DatatypeProperty ; rdfs:range xsd:string .
fm:computationMethod a owl:DatatypeProperty ; rdfs:range xsd:string .

fm:hasParamsRef a owl:DatatypeProperty ;
    rdfs:domain fm:ComputedVariable ;
    rdfs:range xsd:anyURI ;
    rdfs:comment "URI or path reference to computation parameter documentation (e.g., hrv_params.json)" .

#################################################################
# Named Individuals
#################################################################

fm:subject_id a owl:NamedIndividual, fm:Identifier ;
    rdfs:label "subject_id" ;
    rdfs:comment "MIMIC-IV unique patient identifier" ;
    fm:variableName "subject_id" ;
    fm:hasOntologyTerm ncit:C41189 ;
    fm:mappingType "exact" ;
    fm:pipelineStatus "implemented" ;
    fm:belongsToLayer fm:Layer3_Provenance ;
    fm:refinementNotes "MIMIC-IV patient identifier; maps to NCIT Study Subject concept" ;
    fm:uriVerified "yes" .

fm:study_id a owl:NamedIndividual, fm:Identifier ;
    rdfs:label "study_id" ;
    rdfs:comment "MIMIC-IV-ECG unique ECG study identifier" ;
    fm:variableName "study_id" ;
    fm:hasOntologyTerm prov:Entity ;
    fm:mappingType "exact" ;
    fm:pipelineStatus "implemented" ;
    fm:belongsToLayer fm:Layer3_Provenance ;
    fm:refinementNotes "MIMIC-IV-ECG recording identifier; PROV-O Entity representing one ECG record" ;
    fm:uriVerified "yes" .

fm:file_name a owl:NamedIndividual, fm:Identifier ;
    rdfs:label "file_name" ;
    rdfs:comment "Relative path to WFDB record (.hea/.dat)" ;
    fm:variableName "file_name" ;
    fm:hasOntologyTerm prov:Location ;
    fm:mappingType "exact" ;
    fm:pipelineStatus "implemented" ;
    fm:belongsToLayer fm:Layer3_Provenance ;
    fm:refinementNotes "Relative path to WFDB waveform files (.hea/.dat); source locator" ;
    fm:uriVerified "yes" .

fm:recording_date a owl:NamedIndividual, fm:ProvenanceVar ;
    rdfs:label "recording_date" ;
    rdfs:comment "Date and time of ECG measurement" ;
    fm:variableName "recording_date" ;
    fm:hasOntologyTerm <http://www.w3.org/ns/prov#InstantaneousEvent> ;
    fm:mappingType "exact" ;
    fm:pipelineStatus "implemented" ;
    fm:belongsToLayer fm:Layer3_Provenance ;
    fm:refinementNotes "ISO8601 timestamp; renamed from ecg_time" ;
    fm:uriVerified "yes" .

fm:hadm_id a owl:NamedIndividual, fm:Identifier ;
    rdfs:label "hadm_id" ;
    rdfs:comment "Hospital admission identifier" ;
    fm:variableName "hadm_id" ;
    fm:hasOntologyTerm ncit:C25179 ;
    fm:mappingType "exact" ;
    fm:pipelineStatus "implemented" ;
    fm:belongsToLayer fm:Layer3_Provenance ;
    fm:refinementNotes "Hospital admission episode identifier; links ECG to clinical context" ;
    fm:uriVerified "yes" .

fm:admittime a owl:NamedIndividual, fm:Timestamp ;
    rdfs:label "admittime" ;
    rdfs:comment "Admission timestamp" ;
    fm:variableName "admittime" ;
    fm:hasOntologyTerm <http://loinc.org/LP185883-8> ;
    fm:mappingType "exact" ;
    fm:pipelineStatus "implemented" ;
    fm:belongsToLayer fm:Layer3_Provenance ;
    fm:uriVerified "yes" .

fm:dischtime a owl:NamedIndividual, fm:Timestamp ;
    rdfs:label "dischtime" ;
    rdfs:comment "Discharge timestamp" ;
    fm:variableName "dischtime" ;
    fm:hasOntologyTerm <http://loinc.org/MTHU048209> ;
    fm:mappingType "exact" ;
    fm:pipelineStatus "implemented" ;
    fm:belongsToLayer fm:Layer3_Provenance ;
    fm:uriVerified "yes" .

fm:sex a owl:NamedIndividual, fm:DemographicVar ;
    rdfs:label "sex" ;
    rdfs:comment "Biological sex of participant" ;
    fm:variableName "sex" ;
    fm:hasOntologyTerm <http://humanbehaviourchange.org/ontology/BCIO_015105> ;
    fm:mappingType "exact" ;
    fm:pipelineStatus "implemented" ;
    fm:belongsToLayer fm:Layer3_Provenance ;
    fm:refinementNotes "Values M/F; renamed from gender" ;
    fm:uriVerified "yes" .

fm:anchor_age a owl:NamedIndividual, fm:DemographicVar ;
    rdfs:label "anchor_age" ;
    rdfs:comment "MIMIC-IV anchor age" ;
    fm:variableName "anchor_age" ;
    fm:hasOntologyTerm <http://semanticscience.org/resource/SIO_001013> ;
    fm:mappingType "exact" ;
    fm:pipelineStatus "implemented" ;
    fm:belongsToLayer fm:Layer3_Provenance ;
    fm:refinementNotes "Reference point for computing age at ECG" ;
    fm:uriVerified "yes" .

fm:anchor_year a owl:NamedIndividual, fm:DemographicVar ;
    rdfs:label "anchor_year" ;
    rdfs:comment "MIMIC-IV anchor year" ;
    fm:variableName "anchor_year" ;
    fm:hasOntologyTerm <urn:fair-mind:demographic:anchor_year> ;
    fm:mappingType "exact" ;
    fm:pipelineStatus "implemented" ;
    fm:belongsToLayer fm:Layer3_Provenance ;
    fm:refinementNotes "Used with recording_date to derive age" ;
    fm:uriVerified "extension_term" .

fm:dod a owl:NamedIndividual, fm:Timestamp ;
    rdfs:label "dod" ;
    rdfs:comment "Date of death if known" ;
    fm:variableName "dod" ;
    fm:hasOntologyTerm ncit:C70810 ;
    fm:mappingType "exact" ;
    fm:pipelineStatus "implemented" ;
    fm:belongsToLayer fm:Layer3_Provenance ;
    fm:refinementNotes "Mortality endpoint" ;
    fm:uriVerified "yes" .

fm:age a owl:NamedIndividual, fm:DemographicVar ;
    rdfs:label "age" ;
    rdfs:comment "Age at ECG (years)" ;
    fm:variableName "age" ;
    fm:hasOntologyTerm <http://semanticscience.org/resource/SIO_001013> ;
    fm:mappingType "close" ;
    fm:pipelineStatus "implemented" ;
    fm:belongsToLayer fm:Layer3_Provenance ;
    fm:refinementNotes "Derived: anchor_age + (recording_date.year - anchor_year)" ;
    fm:uriVerified "yes" .

fm:z_age a owl:NamedIndividual, fm:DemographicVar ;
    rdfs:label "z_age" ;
    rdfs:comment "Age (standardized z-score)" ;
    fm:variableName "z_age" ;
    fm:hasOntologyTerm <urn:fair-mind:demographic:z_age> ;
    fm:mappingType "close" ;
    fm:pipelineStatus "implemented" ;
    fm:belongsToLayer fm:Layer3_Provenance ;
    fm:refinementNotes "Standardized z-score of age; no exact EFO/NCIT term for z-scored demographic; FAIR-MIND extension" ;
    fm:uriVerified "extension_term" .

fm:BMI a owl:NamedIndividual, fm:DemographicVar ;
    rdfs:label "BMI" ;
    rdfs:comment "Body mass index (kg/m2)" ;
    fm:variableName "BMI" ;
    fm:hasOntologyTerm cmo:0000105 ;
    fm:mappingType "exact" ;
    fm:pipelineStatus "implemented" ;
    fm:belongsToLayer fm:Layer3_Provenance ;
    fm:refinementNotes "Nearest OMR value to recording_date; filtered 10-80" ;
    fm:uriVerified "yes" .

fm:z_BMI a owl:NamedIndividual, fm:DemographicVar ;
    rdfs:label "z_BMI" ;
    rdfs:comment "Body mass index (standardized z-score)" ;
    fm:variableName "z_BMI" ;
    fm:hasOntologyTerm <urn:fair-mind:demographic:z_BMI> ;
    fm:mappingType "close" ;
    fm:pipelineStatus "implemented" ;
    fm:belongsToLayer fm:Layer3_Provenance ;
    fm:refinementNotes "Standardized z-score of BMI; FAIR-MIND extension" ;
    fm:uriVerified "extension_term" .

fm:SBP a owl:NamedIndividual, fm:DemographicVar ;
    rdfs:label "SBP" ;
    rdfs:comment "Systolic blood pressure (mmHg)" ;
    fm:variableName "SBP" ;
    fm:hasOntologyTerm vso:0000038 ;
    fm:mappingType "exact" ;
    fm:pipelineStatus "implemented" ;
    fm:belongsToLayer fm:Layer3_Provenance ;
    fm:refinementNotes "Nearest OMR value to recording_date" ;
    fm:uriVerified "yes" .

fm:DBP a owl:NamedIndividual, fm:DemographicVar ;
    rdfs:label "DBP" ;
    rdfs:comment "Diastolic blood pressure (mmHg)" ;
    fm:variableName "DBP" ;
    fm:hasOntologyTerm vso:0000015 ;
    fm:mappingType "exact" ;
    fm:pipelineStatus "implemented" ;
    fm:belongsToLayer fm:Layer3_Provenance ;
    fm:refinementNotes "Nearest OMR value to recording_date" ;
    fm:uriVerified "yes" .

fm:depression a owl:NamedIndividual, fm:ClinicalVar ;
    rdfs:label "depression" ;
    rdfs:comment "Depression flag (ICD-10 F32, F33)" ;
    fm:variableName "depression" ;
    fm:hasOntologyTerm snomed:35489007 ;
    fm:mappingType "exact" ;
    fm:pipelineStatus "implemented" ;
    fm:belongsToLayer fm:Layer1_Clinical ;
    fm:refinementNotes "Binary; replaces PHQ-9 (unavailable in MIMIC-IV)" ;
    fm:uriVerified "yes" .

fm:suicidality a owl:NamedIndividual, fm:ClinicalVar ;
    rdfs:label "suicidality" ;
    rdfs:comment "Suicidal thoughts or behavior flag" ;
    fm:variableName "suicidality" ;
    fm:hasOntologyTerm snomed:429451000124109 ;
    fm:mappingType "close" ;
    fm:pipelineStatus "implemented" ;
    fm:belongsToLayer fm:Layer1_Clinical ;
    fm:refinementNotes "ICD-10 T1491/Z915; ideation vs attempt distinction unclear" ;
    fm:uriVerified "yes" .

fm:lithium a owl:NamedIndividual, fm:MedicationVar ;
    rdfs:label "lithium" ;
    rdfs:comment "Lithium medication use (binary)" ;
    fm:variableName "lithium" ;
    fm:hasOntologyTerm chebi:30145 ;
    fm:mappingType "close" ;
    fm:pipelineStatus "implemented" ;
    fm:belongsToLayer fm:Layer4_Medications ;
    fm:refinementNotes "BCIO links to CHEBI compound for lithium carbonate" ;
    fm:uriVerified "yes" .

fm:antidepress a owl:NamedIndividual, fm:MedicationVar ;
    rdfs:label "antidepress" ;
    rdfs:comment "Antidepressant medication use (binary)" ;
    fm:variableName "antidepress" ;
    fm:hasOntologyTerm mesh:D000928 ;
    fm:mappingType "close" ;
    fm:pipelineStatus "implemented" ;
    fm:belongsToLayer fm:Layer4_Medications ;
    fm:refinementNotes "Covers SSRI/SNRI classes; renamed from antidepressant" ;
    fm:uriVerified "yes" .

fm:BPM a owl:NamedIndividual, fm:PhysiologicalRate ;
    rdfs:label "BPM" ;
    rdfs:comment "Mean heart rate (beats per minute)" ;
    fm:variableName "BPM" ;
    fm:hasOntologyTerm ncit:C49673 ;
    fm:mappingType "exact" ;
    fm:pipelineStatus "implemented" ;
    fm:computedFrom fm:RRIntervals ;
    fm:hasParamsRef "https://github.com/[your-repo]/hrv_params.json"^^xsd:anyURI ;
    fm:belongsToLayer fm:Layer2_Biomarkers ;
    fm:refinementNotes "60000 / mean(RR_ms); 10-second window" ;
    fm:uriVerified "yes" .

fm:RMSSD a owl:NamedIndividual, fm:TimeDomainHRV ;
    rdfs:label "RMSSD" ;
    rdfs:comment "Root mean square of successive RR differences (ms)" ;
    fm:variableName "RMSSD" ;
    fm:hasOntologyTerm efo:EFO_0009257 ;
    fm:mappingType "exact" ;
    fm:pipelineStatus "implemented" ;
    fm:computedFrom fm:RRIntervals ;
    fm:hasParamsRef "https://github.com/[your-repo]/hrv_params.json"^^xsd:anyURI ;
    fm:belongsToLayer fm:Layer2_Biomarkers ;
    fm:refinementNotes "Parasympathetic marker; artifact filtering via neurokit2" ;
    fm:uriVerified "yes" .

fm:SDNN a owl:NamedIndividual, fm:TimeDomainHRV ;
    rdfs:label "SDNN" ;
    rdfs:comment "Standard deviation of NN intervals (ms)" ;
    fm:variableName "SDNN" ;
    fm:hasOntologyTerm efo:EFO_0009256 ;
    fm:mappingType "exact" ;
    fm:pipelineStatus "implemented" ;
    fm:computedFrom fm:RRIntervals ;
    fm:hasParamsRef "https://github.com/[your-repo]/hrv_params.json"^^xsd:anyURI ;
    fm:belongsToLayer fm:Layer2_Biomarkers ;
    fm:uriVerified "yes" .

fm:pNN20 a owl:NamedIndividual, fm:TimeDomainHRV ;
    rdfs:label "pNN20" ;
    rdfs:comment "Percentage of NN differences > 20ms" ;
    fm:variableName "pNN20" ;
    fm:hasOntologyTerm <urn:fair-mind:hrv:pNN20> ;
    fm:mappingType "close" ;
    fm:pipelineStatus "implemented" ;
    fm:computedFrom fm:RRIntervals ;
    fm:hasParamsRef "https://github.com/[your-repo]/hrv_params.json"^^xsd:anyURI ;
    fm:belongsToLayer fm:Layer2_Biomarkers ;
    fm:refinementNotes "BMONT defines pNN50 but not pNN20; extension needed" ;
    fm:uriVerified "extension_term" .

fm:pNN50 a owl:NamedIndividual, fm:TimeDomainHRV ;
    rdfs:label "pNN50" ;
    rdfs:comment "Percentage of NN differences > 50ms" ;
    fm:variableName "pNN50" ;
    fm:hasOntologyTerm <urn:fair-mind:hrv:pNN50> ;
    fm:mappingType "close" ;
    fm:pipelineStatus "implemented" ;
    fm:computedFrom fm:RRIntervals ;
    fm:hasParamsRef "https://github.com/[your-repo]/hrv_params.json"^^xsd:anyURI ;
    fm:belongsToLayer fm:Layer2_Biomarkers ;
    fm:refinementNotes "Percentage of NN intervals >50ms; no verified EFO/CMO term found; FAIR-MIND extension pending EFO submission" ;
    fm:uriVerified "extension_term" .

fm:MAD a owl:NamedIndividual, fm:TimeDomainHRV ;
    rdfs:label "MAD" ;
    rdfs:comment "Median absolute deviation of RR intervals (ms)" ;
    fm:variableName "MAD" ;
    fm:hasOntologyTerm <urn:fair-mind:hrv:MAD> ;
    fm:mappingType "close" ;
    fm:pipelineStatus "implemented" ;
    fm:computedFrom fm:RRIntervals ;
    fm:hasParamsRef "https://github.com/[your-repo]/hrv_params.json"^^xsd:anyURI ;
    fm:belongsToLayer fm:Layer2_Biomarkers ;
    fm:refinementNotes "Robust variability index; ontology extension needed" ;
    fm:uriVerified "extension_term" .

fm:LF a owl:NamedIndividual, fm:SpectralHRV ;
    rdfs:label "LF" ;
    rdfs:comment "Low-frequency HRV power 0.04-0.15 Hz (ms^2)" ;
    fm:variableName "LF" ;
    fm:hasOntologyTerm <urn:fair-mind:hrv:LF> ;
    fm:mappingType "close" ;
    fm:pipelineStatus "implemented" ;
    fm:computedFrom fm:RRIntervals ;
    fm:hasParamsRef "https://github.com/[your-repo]/hrv_params.json"^^xsd:anyURI ;
    fm:belongsToLayer fm:Layer2_Biomarkers ;
    fm:frequencyBand "0.04-0.15 Hz" ;
    fm:refinementNotes "Computed via Lomb-Scargle Periodogram (LSP); ultra-short-term estimate; NIH supports use for ANS assessment with caveats documented" ;
    fm:uriVerified "extension_term" .

fm:HF a owl:NamedIndividual, fm:SpectralHRV ;
    rdfs:label "HF" ;
    rdfs:comment "High-frequency HRV power 0.15-0.4 Hz (ms^2)" ;
    fm:variableName "HF" ;
    fm:hasOntologyTerm <urn:fair-mind:hrv:HF> ;
    fm:mappingType "close" ;
    fm:pipelineStatus "implemented" ;
    fm:computedFrom fm:RRIntervals ;
    fm:hasParamsRef "https://github.com/[your-repo]/hrv_params.json"^^xsd:anyURI ;
    fm:belongsToLayer fm:Layer2_Biomarkers ;
    fm:frequencyBand "0.15-0.4 Hz" ;
    fm:refinementNotes "Computed via Lomb-Scargle Periodogram (LSP); more reliable than LF at 10s; parasympathetic marker" ;
    fm:uriVerified "extension_term" .

fm:LFnu a owl:NamedIndividual, fm:SpectralHRV ;
    rdfs:label "LFnu" ;
    rdfs:comment "Normalized LF power" ;
    fm:variableName "LFnu" ;
    fm:hasOntologyTerm <urn:fair-mind:hrv:LFnu> ;
    fm:mappingType "close" ;
    fm:pipelineStatus "implemented" ;
    fm:computedFrom fm:RRIntervals ;
    fm:hasParamsRef "https://github.com/[your-repo]/hrv_params.json"^^xsd:anyURI ;
    fm:belongsToLayer fm:Layer2_Biomarkers ;
    fm:refinementNotes "LF/(LF+HF)*100; normalized LF power; FAIR-MIND extension term" ;
    fm:frequencyBand "0.04-0.15 Hz (normalized)" ;
    fm:uriVerified "extension_term" .

fm:TP a owl:NamedIndividual, fm:SpectralHRV ;
    rdfs:label "TP" ;
    rdfs:comment "Total power of HRV (ms^2)" ;
    fm:variableName "TP" ;
    fm:hasOntologyTerm <urn:fair-mind:hrv:TP> ;
    fm:mappingType "close" ;
    fm:pipelineStatus "implemented" ;
    fm:computedFrom fm:RRIntervals ;
    fm:hasParamsRef "https://github.com/[your-repo]/hrv_params.json"^^xsd:anyURI ;
    fm:belongsToLayer fm:Layer2_Biomarkers ;
    fm:frequencyBand "0.003-0.4 Hz" ;
    fm:refinementNotes "Total spectral power (LF+HF+VLF); computed via LSP; reliability limited at 10s; documented in params" ;
    fm:uriVerified "extension_term" .

fm:SD1 a owl:NamedIndividual, fm:PoincareHRV ;
    rdfs:label "SD1" ;
    rdfs:comment "Poincare plot short-term variability (ms)" ;
    fm:variableName "SD1" ;
    fm:hasOntologyTerm <urn:fair-mind:hrv:SD1> ;
    fm:mappingType "close" ;
    fm:pipelineStatus "implemented" ;
    fm:computedFrom fm:RRIntervals ;
    fm:hasParamsRef "https://github.com/[your-repo]/hrv_params.json"^^xsd:anyURI ;
    fm:belongsToLayer fm:Layer2_Biomarkers ;
    fm:refinementNotes "BMONT missing explicit Poincare terms" ;
    fm:uriVerified "extension_term" .

fm:SD2 a owl:NamedIndividual, fm:PoincareHRV ;
    rdfs:label "SD2" ;
    rdfs:comment "Poincare plot long-term variability (ms)" ;
    fm:variableName "SD2" ;
    fm:hasOntologyTerm <urn:fair-mind:hrv:SD2> ;
    fm:mappingType "close" ;
    fm:pipelineStatus "implemented" ;
    fm:computedFrom fm:RRIntervals ;
    fm:hasParamsRef "https://github.com/[your-repo]/hrv_params.json"^^xsd:anyURI ;
    fm:belongsToLayer fm:Layer2_Biomarkers ;
    fm:refinementNotes "Requires ontology extension for Poincare metrics" ;
    fm:uriVerified "extension_term" .

fm:BR a owl:NamedIndividual, fm:PhysiologicalRate ;
    rdfs:label "BR" ;
    rdfs:comment "Breathing rate derived from ECG (breaths/min)" ;
    fm:variableName "BR" ;
    fm:hasOntologyTerm ncit:C49660 ;
    fm:mappingType "exact" ;
    fm:pipelineStatus "implemented" ;
    fm:computedFrom fm:RRIntervals ;
    fm:hasParamsRef "https://github.com/[your-repo]/hrv_params.json"^^xsd:anyURI ;
    fm:belongsToLayer fm:Layer2_Biomarkers ;
    fm:refinementNotes "ECG-derived breathing rate via EDR method (neurokit2); NCIT C49660 preferred over PATO for clinical measurement concept" ;
    fm:uriVerified "yes" .

fm:HFD a owl:NamedIndividual, fm:NonlinearHRV ;
    rdfs:label "HFD" ;
    rdfs:comment "Higuchi fractal dimension of RR series" ;
    fm:variableName "HFD" ;
    fm:hasOntologyTerm <urn:fair-mind:nonlinear:HFD> ;
    fm:mappingType "close" ;
    fm:pipelineStatus "implemented" ;
    fm:computedFrom fm:RRIntervals ;
    fm:hasParamsRef "https://github.com/[your-repo]/hrv_params.json"^^xsd:anyURI ;
    fm:belongsToLayer fm:Layer2_Biomarkers ;
    fm:refinementNotes "kmax=min(10 or N/2); antropy library; ECG signal-based computation (Čukić et al. method) planned as extension" ;
    fm:uriVerified "extension_term" .

fm:SampEn a owl:NamedIndividual, fm:NonlinearHRV ;
    rdfs:label "SampEn" ;
    rdfs:comment "Sample entropy of RR series (m=2)" ;
    fm:variableName "SampEn" ;
    fm:hasOntologyTerm <urn:fair-mind:nonlinear:SampEn> ;
    fm:mappingType "close" ;
    fm:pipelineStatus "implemented" ;
    fm:computedFrom fm:RRIntervals ;
    fm:hasParamsRef "https://github.com/[your-repo]/hrv_params.json"^^xsd:anyURI ;
    fm:belongsToLayer fm:Layer2_Biomarkers ;
    fm:refinementNotes "r=0.2*std; inf replaced with NaN; ECG signal-based computation (Čukić et al. method) planned as extension" ;
    fm:uriVerified "extension_term" .

fm:ApEn a owl:NamedIndividual, fm:NonlinearHRV ;
    rdfs:label "ApEn" ;
    rdfs:comment "Approximate entropy of RR series (m=2)" ;
