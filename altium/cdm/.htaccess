# CDM IRI → GitHub Pages redirects
# Static per-subset pattern rules — valid because ALL CDM classes follow
# the {subsetPrefix}_{PascalClassName} naming convention.

Options +FollowSymLinks
RewriteEngine on

RewriteRule ^$ https://altiumdeveloper.github.io/cdm/ [R=302,L]

RewriteRule ^collaboration$        https://altiumdeveloper.github.io/cdm/subsets/collaboration [R=302,L]
RewriteRule ^collaboration/(.*)$   https://altiumdeveloper.github.io/cdm/classes/col_$1/ [R=302,L]

RewriteRule ^configuration$        https://altiumdeveloper.github.io/cdm/subsets/configuration [R=302,L]
RewriteRule ^configuration/(.*)$   https://altiumdeveloper.github.io/cdm/classes/con_$1/ [R=302,L]

RewriteRule ^core$                 https://altiumdeveloper.github.io/cdm/subsets/core [R=302,L]
RewriteRule ^core/(.*)$            https://altiumdeveloper.github.io/cdm/classes/core_$1/ [R=302,L]

RewriteRule ^customization$        https://altiumdeveloper.github.io/cdm/subsets/customization [R=302,L]
RewriteRule ^customization/(.*)$   https://altiumdeveloper.github.io/cdm/classes/cus_$1/ [R=302,L]

RewriteRule ^design$               https://altiumdeveloper.github.io/cdm/subsets/design [R=302,L]
RewriteRule ^design/(.*)$          https://altiumdeveloper.github.io/cdm/classes/des_$1/ [R=302,L]

RewriteRule ^deviceModel$          https://altiumdeveloper.github.io/cdm/subsets/deviceModel [R=302,L]
RewriteRule ^deviceModel/(.*)$     https://altiumdeveloper.github.io/cdm/classes/dm_$1/ [R=302,L]

RewriteRule ^insights$            https://altiumdeveloper.github.io/cdm/subsets/insights [R=302,L]
RewriteRule ^insights/(.*)$        https://altiumdeveloper.github.io/cdm/classes/ins_$1/ [R=302,L]

RewriteRule ^library$              https://altiumdeveloper.github.io/cdm/subsets/library [R=302,L]
RewriteRule ^library/(.*)$         https://altiumdeveloper.github.io/cdm/classes/lib_$1/ [R=302,L]

RewriteRule ^ota$                  https://altiumdeveloper.github.io/cdm/subsets/ota [R=302,L]
RewriteRule ^ota/(.*)$             https://altiumdeveloper.github.io/cdm/classes/ota_$1/ [R=302,L]

RewriteRule ^platform$             https://altiumdeveloper.github.io/cdm/subsets/platform [R=302,L]
RewriteRule ^platform/(.*)$        https://altiumdeveloper.github.io/cdm/classes/plt_$1/ [R=302,L]

RewriteRule ^procurement$          https://altiumdeveloper.github.io/cdm/subsets/procurement [R=302,L]
RewriteRule ^procurement/(.*)$     https://altiumdeveloper.github.io/cdm/classes/pro_$1/ [R=302,L]

RewriteRule ^requirements$          https://altiumdeveloper.github.io/cdm/subsets/requirements [R=302,L]
RewriteRule ^requirements/(.*)$     https://altiumdeveloper.github.io/cdm/classes/req_$1/ [R=302,L]

RewriteRule ^software$             https://altiumdeveloper.github.io/cdm/subsets/software [R=302,L]
RewriteRule ^software/(.*)$        https://altiumdeveloper.github.io/cdm/classes/sft_$1/ [R=302,L]

RewriteRule ^supply$               https://altiumdeveloper.github.io/cdm/subsets/supply [R=302,L]
RewriteRule ^supply/(.*)$          https://altiumdeveloper.github.io/cdm/classes/sup_$1/ [R=302,L]

RewriteRule ^system$               https://altiumdeveloper.github.io/cdm/subsets/system [R=302,L]
RewriteRule ^system/(.*)$          https://altiumdeveloper.github.io/cdm/classes/sys_$1/ [R=302,L]
