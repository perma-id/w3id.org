# CDM IRI → GitHub Pages redirects
# Static per-subset pattern rules — valid because ALL CDM classes follow
# the {subsetPrefix}_{PascalClassName} naming convention.
#
# Pattern: w3id.org/altium/cdm/{subset}/{ClassName}
#       →  altiumdeveloper.github.io/cdm/classes/{subsetPrefix}_{ClassName}/

RewriteEngine on

RewriteRule ^$ https://altiumdeveloper.github.io/cdm/ [R=302,L]
RewriteRule ^/altium/cdm/collaboration/(.+)$   https://altiumdeveloper.github.io/cdm/classes/col_$1/ [R=302,L]
RewriteRule ^/altium/cdm/configuration/(.+)$   https://altiumdeveloper.github.io/cdm/classes/con_$1/ [R=302,L]
RewriteRule ^/altium/cdm/core/(.+)$            https://altiumdeveloper.github.io/cdm/classes/core_$1/ [R=302,L]
RewriteRule ^/altium/cdm/customization/(.+)$   https://altiumdeveloper.github.io/cdm/classes/cus_$1/ [R=302,L]
RewriteRule ^/altium/cdm/design/(.+)$          https://altiumdeveloper.github.io/cdm/classes/des_$1/ [R=302,L]
RewriteRule ^/altium/cdm/deviceModel/(.+)$     https://altiumdeveloper.github.io/cdm/classes/dm_$1/ [R=302,L]
RewriteRule ^/altium/cdm/insights/(.+)$        https://altiumdeveloper.github.io/cdm/classes/ins_$1/ [R=302,L]
RewriteRule ^/altium/cdm/library/(.+)$         https://altiumdeveloper.github.io/cdm/classes/lib_$1/ [R=302,L]
RewriteRule ^/altium/cdm/ota/(.+)$             https://altiumdeveloper.github.io/cdm/classes/ota_$1/ [R=302,L]
RewriteRule ^/altium/cdm/platform/(.+)$        https://altiumdeveloper.github.io/cdm/classes/plt_$1/ [R=302,L]
RewriteRule ^/altium/cdm/procurement/(.+)$     https://altiumdeveloper.github.io/cdm/classes/pro_$1/ [R=302,L]
RewriteRule ^/altium/cdm/requirement/(.+)$     https://altiumdeveloper.github.io/cdm/classes/req_$1/ [R=302,L]
RewriteRule ^/altium/cdm/software/(.+)$        https://altiumdeveloper.github.io/cdm/classes/sft_$1/ [R=302,L]
RewriteRule ^/altium/cdm/supply/(.+)$          https://altiumdeveloper.github.io/cdm/classes/sup_$1/ [R=302,L]
RewriteRule ^/altium/cdm/system/(.+)$          https://altiumdeveloper.github.io/cdm/classes/sys_$1/ [R=302,L]
