Options -MultiViews
Require all granted

Header set Access-Control-Allow-Origin *
Header set Cache-Control "max-age=3600"

# Redirect AP namespace to GitHub raw TTL
RewriteEngine on

RewriteRule ^ap$ https://raw.githubusercontent.com/cik860/w3id.org-fair-mind/main/fair_mind_ap_v3.ttl [R=303,L]
RewriteRule ^ap/(.*)$ https://raw.githubusercontent.com/cik860/w3id.org-fair-mind/main/fair_mind_ap_v3.ttl [R=303,L]
