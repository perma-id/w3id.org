#Options -MultiViews

#AddType application/rdf+xml .owl

RewriteEngine on

# OWL context
#RewriteCond %{HTTP_ACCEPT} \*/\* [OR]
#RewriteCond %{HTTP_ACCEPT} application/rdf\+xml
RewriteRule ^$ https://raw.githubusercontent.com/VICK-Blockchain/VICK-KnowledgeGraph/refs/heads/main/vick.owl [R=302,L]

RewriteRule ^vick.owl$ https://raw.githubusercontent.com/VICK-Blockchain/VICK-KnowledgeGraph/refs/heads/main/vick.owl [R=302,L]

RewriteRule ^vick-base.owl$ https://raw.githubusercontent.com/VICK-Blockchain/VICK-KnowledgeGraph/refs/heads/main/vick-base.owl [R=302,L]
