# Name of the project: OSTrails DMP Evaluation Commons
# Description: Persistent identifiers for the DMP Common Standard Compliance
# (DMP-CSC) evaluation metrics and tests, part of the OSTrails project
# (Open Science Plan-Track-Assess Pathways).
#
# https://w3id.org/dmp/evaluation/metric/<metric-id> redirects to the
# corresponding metric section on
# https://docs.ostrails.eu/en/latest/commons/dmp/dmp-evaluation-metrics.html
#
# https://w3id.org/dmp/evaluation/test/T-DCSC-NNN redirects to the
# corresponding test section on
# https://docs.ostrails.eu/en/latest/commons/dmp/dmp-catalogue-of-tests.html
#
# ## Contact
# This space is administered by:
#
# OSTrails Project
# GitHub: https://github.com/OSTrails
# Email: andres.romero@tuwien.ac.at
# Maintainer: @andretabima (https://github.com/andretabima)

Options +FollowSymLinks
RewriteEngine on
RewriteBase /dmp/

# Remove trailing slash (non-root only, to keep clean URLs)
RewriteCond %{REQUEST_URI} !^/dmp/?$
RewriteRule ^(.+)/$ $1 [R=301,L]

# --------------------------------------------------------------------
# Tests: /dmp/evaluation/test/T-DCSC-NNN -> #dmp-test-N
# (strips leading zeros from NNN via the 0*([1-9][0-9]*) capture)
# --------------------------------------------------------------------
RewriteRule ^evaluation/test/T-DCSC-0*([1-9][0-9]*)$ https://docs.ostrails.eu/en/latest/commons/dmp/dmp-catalogue-of-tests.html#dmp-test-$1 [R=302,L]

# --------------------------------------------------------------------
# Metrics: /dmp/evaluation/metric/<metric-id> -> #dmp-metric-N
# --------------------------------------------------------------------
