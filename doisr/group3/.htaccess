# Turn off MultiViews
Options -MultiViews

# Content types
AddType text/turtle .ttl

RewriteEngine On

# HTML documentation
RewriteCond %{HTTP_ACCEPT} text/html [OR]
RewriteCond %{HTTP_ACCEPT} application/xhtml\+xml [OR]
RewriteCond %{HTTP_USER_AGENT} ^Mozilla/.*
RewriteRule ^$ https://alvaroogarciia1.github.io/DOISR-25-26/1st%20ontology%20conceptualization%20assignment/index-en.html [R=303,L]

# Turtle ontology
RewriteCond %{HTTP_ACCEPT} text/turtle [OR]
RewriteCond %{HTTP_ACCEPT} text/* [OR]
RewriteCond %{HTTP_ACCEPT} */*
RewriteRule ^$ https://alvaroogarciia1.github.io/DOISR-25-26/1st%20ontology%20conceptualization%20assignment/ontology.ttl [R=303,L]

# Default response
RewriteRule ^$ https://alvaroogarciia1.github.io/DOISR-25-26/1st%20ontology%20conceptualization%20assignment/ontology.ttl [R=303,L]
