# Turn off MultiViews
Options -MultiViews

AddType application/rdf+xml .rdf
AddType application/rdf+xml .owl
AddType text/turtle .ttl
AddType application/n-triples .nt
AddType application/ld+json .json

RewriteEngine on

# ---------------------------
# Latest version (1.1.1)
# ---------------------------

# HTML documentation
RewriteCond %{HTTP_ACCEPT} !application/rdf\+xml.*(text/html|application/xhtml\+xml)
RewriteCond %{HTTP_ACCEPT} text/html [OR]
RewriteCond %{HTTP_ACCEPT} application/xhtml\+xml [OR]
RewriteCond %{HTTP_USER_AGENT} ^Mozilla/.*

RewriteRule ^$ https://alvaroogarciia1.github.io/DOISR-25-26/release/1.1.1/index-en.html [R=303,L]

# JSON-LD
RewriteCond %{HTTP_ACCEPT} application/ld\+json
RewriteRule ^$ https://alvaroogarciia1.github.io/DOISR-25-26/release/1.1.1/ontology.json [R=303,L]

# RDF/XML
RewriteCond %{HTTP_ACCEPT} \*/\* [OR]
RewriteCond %{HTTP_ACCEPT} application/rdf\+xml
RewriteRule ^$ https://alvaroogarciia1.github.io/DOISR-25-26/release/1.1.1/ontology.owl [R=303,L]

# N-Triples
RewriteCond %{HTTP_ACCEPT} application/n-triples
RewriteRule ^$ https://alvaroogarciia1.github.io/DOISR-25-26/release/1.1.1/ontology.nt [R=303,L]

# Turtle
RewriteCond %{HTTP_ACCEPT} text/turtle [OR]
RewriteCond %{HTTP_ACCEPT} text/\* [OR]
RewriteCond %{HTTP_ACCEPT} \*/turtle
RewriteRule ^$ https://alvaroogarciia1.github.io/DOISR-25-26/release/1.1.1/ontology.ttl [R=303,L]

# ---------------------------
# Specific versions
# ---------------------------

# HTML
RewriteCond %{HTTP_ACCEPT} !application/rdf\+xml.*(text/html|application/xhtml\+xml)
RewriteCond %{HTTP_ACCEPT} text/html [OR]
RewriteCond %{HTTP_ACCEPT} application/xhtml\+xml [OR]
RewriteCond %{HTTP_USER_AGENT} ^Mozilla/.*

RewriteRule ^(.+)$ https://alvaroogarciia1.github.io/DOISR-25-26/release/$1/index-en.html [R=303,L]

# JSON-LD
RewriteCond %{HTTP_ACCEPT} application/ld\+json
RewriteRule ^(.+)$ https://alvaroogarciia1.github.io/DOISR-25-26/release/$1/ontology.json [R=303,L]

# RDF/XML
RewriteCond %{HTTP_ACCEPT} \*/\* [OR]
RewriteCond %{HTTP_ACCEPT} application/rdf\+xml
RewriteRule ^(.+)$ https://alvaroogarciia1.github.io/DOISR-25-26/release/$1/ontology.owl [R=303,L]

# N-Triples
RewriteCond %{HTTP_ACCEPT} application/n-triples
RewriteRule ^(.+)$ https://alvaroogarciia1.github.io/DOISR-25-26/release/$1/ontology.nt [R=303,L]

# Turtle
RewriteCond %{HTTP_ACCEPT} text/turtle [OR]
RewriteCond %{HTTP_ACCEPT} text/\* [OR]
RewriteCond %{HTTP_ACCEPT} \*/turtle
RewriteRule ^(.+)$ https://alvaroogarciia1.github.io/DOISR-25-26/release/$1/ontology.ttl [R=303,L]

# ---------------------------
# Fallback
# ---------------------------

RewriteCond %{HTTP_ACCEPT} .+
RewriteRule ^(.*)$ https://alvaroogarciia1.github.io/DOISR-25-26/release/1.1.1/406.html [R=406,L]

# Default response
RewriteRule ^$ https://alvaroogarciia1.github.io/DOISR-25-26/release/1.1.1/ontology.owl [R=303,L]