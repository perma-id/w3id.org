 MultiViews
Options -MultiViews

AddType text/turtle .ttl

RewriteEngine on

# Rewrite rule for latest version (HTML)
RewriteCond %{HTTP_ACCEPT} !application/rdf\+xml.*(text/html|application/xhtml\+xml)
RewriteCond %{HTTP_ACCEPT} text/html [OR]
RewriteCond %{HTTP_ACCEPT} application/xhtml\+xml [OR]
RewriteCond %{HTTP_USER_AGENT} ^Mozilla/.*
RewriteRule ^$ https://appsudara.github.io/doisr-g5/release/1.0.0/index-en.html [R=303,L]

# Rewrite rule for Turtle serialization
RewriteCond %{HTTP_ACCEPT} text/turtle [OR]
RewriteCond %{HTTP_ACCEPT} text/\* [OR]
RewriteCond %{HTTP_ACCEPT} \*/turtle
RewriteRule ^$ https://appsudara.github.io/doisr-g5/release/1.0.0/ontology.ttl [R=303,L]

# Rewrite rules for specific versions (HTML)
RewriteCond %{HTTP_ACCEPT} !application/rdf\+xml.*(text/html|application/xhtml\+xml)
RewriteCond %{HTTP_ACCEPT} text/html [OR]
RewriteCond %{HTTP_ACCEPT} application/xhtml\+xml [OR]
RewriteCond %{HTTP_USER_AGENT} ^Mozilla/.*
RewriteRule ^(.+)$ https://appsudara.github.io/doisr-g5/release/$1/index-en.html [R=303,L]

# Rewrite rule for RDF/XML
RewriteCond %{HTTP_ACCEPT} \*/\* [OR]
RewriteCond %{HTTP_ACCEPT} application/rdf\+xml
RewriteRule ^(.+)$ https://appsudara.github.io/doisr-g5/release/$1/ontology.owl [R=303,L]