```apache
# Turn off MultiViews
Options -MultiViews

# MIME types
AddType application/rdf+xml .rdf
AddType application/rdf+xml .owl
AddType text/turtle .ttl
AddType application/n-triples .nt
AddType application/ld+json .jsonld

RewriteEngine On

RewriteCond %{HTTP_ACCEPT} text/html [OR]
RewriteCond %{HTTP_ACCEPT} application/xhtml+xml
RewriteRule ^$ https://lorddaniel-dev.github.io/DOISR-Group-6/ [R=303,L]

RewriteCond %{HTTP_ACCEPT} application/ld\+json
RewriteRule ^$ https://lorddaniel-dev.github.io/DOISR-Group-6/ontology.jsonld [R=303,L]

RewriteCond %{HTTP_ACCEPT} application/rdf\+xml
RewriteRule ^$ https://lorddaniel-dev.github.io/DOISR-Group-6/ontology.owl [R=303,L]

RewriteCond %{HTTP_ACCEPT} application/n-triples
RewriteRule ^$ https://lorddaniel-dev.github.io/DOISR-Group-6/ontology.nt [R=303,L]

RewriteCond %{HTTP_ACCEPT} text/turtle [OR]
RewriteCond %{HTTP_ACCEPT} application/x-turtle
RewriteRule ^$ https://lorddaniel-dev.github.io/DOISR-Group-6/ontology.ttl [R=303,L]

RewriteCond %{HTTP_ACCEPT} text/html [OR]
RewriteCond %{HTTP_ACCEPT} application/xhtml+xml
RewriteRule ^(.+)$ https://lorddaniel-dev.github.io/DOISR-Group-6/release/$1/index.html [R=303,L]

RewriteCond %{HTTP_ACCEPT} application/ld\+json
RewriteRule ^(.+)$ https://lorddaniel-dev.github.io/DOISR-Group-6/release/$1/ontology.jsonld [R=303,L]

RewriteCond %{HTTP_ACCEPT} application/rdf\+xml
RewriteRule ^(.+)$ https://lorddaniel-dev.github.io/DOISR-Group-6/release/$1/ontology.owl [R=303,L]

RewriteCond %{HTTP_ACCEPT} application/n-triples
RewriteRule ^(.+)$ https://lorddaniel-dev.github.io/DOISR-Group-6/release/$1/ontology.nt [R=303,L]

RewriteCond %{HTTP_ACCEPT} text/turtle [OR]
RewriteCond %{HTTP_ACCEPT} application/x-turtle
RewriteRule ^(.+)$ https://lorddaniel-dev.github.io/DOISR-Group-6/release/$1/ontology.ttl [R=303,L]

RewriteRule ^$ https://lorddaniel-dev.github.io/DOISR-Group-6/ [R=303,L]
```
