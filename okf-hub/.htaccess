# w3id.org/okf-hub — OKF-Hub knowledge store namespace
Options +FollowSymLinks
RewriteEngine on

# Interim: all requests → hub repository landing page (human-readable).
# Will be upgraded to per-ID resolution / content negotiation when the
# OKF wiki application is live.
RewriteRule ^(.*)$ https://github.com/kstewart-bot/hub [R=302,L]
