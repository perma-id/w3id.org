Options +FollowSymLinks
# Turn off MultiViews
Options -MultiViews

# Directive to ensure *.rdf files served as appropriate content type,
# if not present in main apache config
AddType application/rdf+xml .rdf
AddType application/rdf+xml .owl
AddType text/turtle .ttl

RewriteEngine on

# Rewrite rules for BuildingComponents ontology
RewriteCond %{HTTP_ACCEPT} !application/rdf\+xml.*(text/html|application/xhtml\+xml|text/\*|\*/\*)
RewriteCond %{HTTP_ACCEPT} text/html [OR]
RewriteCond %{HTTP_ACCEPT} application/xhtml\+xml [OR]
RewriteCond %{HTTP_ACCEPT} text/\* [OR]
RewriteCond %{HTTP_ACCEPT} \*/\* [OR]
RewriteCond %{HTTP_USER_AGENT} ^Mozilla/.*
RewriteRule ^BuildingComponents$ https://joacostar.github.io/Ontologies/OnToology/BuildingComponents.ttl/documentation/  [R=303,NE,L]
RewriteCond %{HTTP_ACCEPT} ^.*application/rdf\+xml.* 
RewriteRule ^BuildingComponents$ https://joacostar.github.io/Ontologies/OnToology/BuildingComponents.ttl/documentation/ontology.owl [R=303,NE,L]
RewriteCond %{HTTP_ACCEPT} ^.*text/turtle.* 
RewriteRule ^BuildingComponents$ https://joacostar.github.io/Ontologies/OnToology/BuildingComponents.ttl/documentation/ontology.ttl [R=303,NE,L]
#default response: owl
RewriteRule ^BuildingComponents$ https://joacostar.github.io/Ontologies/OnToology/BuildingComponents.ttl/documentation/ontology.owl [R=303,NE,L]

