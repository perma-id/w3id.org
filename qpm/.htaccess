# w3id.org redirect for the Qualitative Place Model (QPM) ontology
# Maintainer: Alia I. Abdelmoty (github.com/Aliaia)

RewriteEngine On

# Versioned ontology IRI: w3id.org/qpm/1.0
RewriteRule ^1\.0/?$ https://aliaia.github.io/qpm/qpm-1.0.ttl [R=302,L]

# Term namespace and ontology root, RDF request -> the ontology file
RewriteCond %{HTTP_ACCEPT} text/turtle [OR]
RewriteCond %{HTTP_ACCEPT} application/rdf\+xml [OR]
RewriteCond %{HTTP_ACCEPT} application/ld\+json
RewriteRule ^$ https://aliaia.github.io/qpm/qpm.ttl [R=302,L]

# Browsers and everything else -> human-readable landing page
RewriteRule ^$ https://aliaia.github.io/qpm/ [R=303,L]
