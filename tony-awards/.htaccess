RewriteEngine On
RewriteBase /tony-awards/

# Ontology document with simple content negotiation

RewriteCond %{HTTP_ACCEPT} application/rdf\+xml [OR]
RewriteCond %{HTTP_ACCEPT} application/xml
RewriteRule ^ontology$ https://raw.githubusercontent.com/tony07122004/group10-semantic-requirements/main/ontology/Ontology.owl [R=303,L]

RewriteCond %{HTTP_ACCEPT} text/turtle [OR]
RewriteCond %{HTTP_ACCEPT} application/x-turtle [OR]
RewriteCond %{HTTP_ACCEPT} text/plain
RewriteRule ^ontology$ https://raw.githubusercontent.com/tony07122004/group10-semantic-requirements/main/ontology/Ontology.ttl [R=303,L]

RewriteCond %{HTTP_ACCEPT} text/html
RewriteRule ^ontology$ https://github.com/tony07122004/group10-semantic-requirements/tree/main/ontology [R=303,L]

# Default ontology redirect
RewriteRule ^ontology$ https://raw.githubusercontent.com/tony07122004/group10-semantic-requirements/main/ontology/Ontology.ttl [R=303,L]

# Resource namespace
RewriteRule ^resource$ https://raw.githubusercontent.com/tony07122004/group10-semantic-requirements/main/data/tony_awards_data.ttl [R=303,L]
RewriteRule ^resource/(.*)$ https://raw.githubusercontent.com/tony07122004/group10-semantic-requirements/main/data/tony_awards_data.ttl [R=303,L]
