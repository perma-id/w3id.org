RewriteEngine On

RewriteRule ^collection/?$ https://terminology.services.base4nfdi.de/collection [R=302,L]
RewriteRule ^collection/([0-9a-fA-F-]+)$ https://terminology.services.base4nfdi.de/collection/$1 [R=302,L]
RewriteRule ^entityset/?$ https://terminology.services.base4nfdi.de/entityset [R=302,L]
RewriteRule ^entityset/([0-9a-fA-F-]+)$ https://terminology.services.base4nfdi.de/entityset/$1 [R=302,L]
