RewriteCond %{HTTP_ACCEPT} application/n-triples [NC]
RewriteRule ^$ https://GabrieleT0.github.io/FAIR-O-An-Ontology-for-FAIR-Assessment-and-Scoring/ontology.nt [R=303,L]

# Turtle
RewriteCond %{HTTP_ACCEPT} text/turtle [NC,OR]
RewriteCond %{HTTP_ACCEPT} application/x-turtle [NC]
RewriteRule ^$ https://GabrieleT0.github.io/FAIR-O-An-Ontology-for-FAIR-Assessment-and-Scoring/ontology.ttl [R=303,L]

