Options +FollowSymLinks
RewriteEngine On

# Version 1.0.0

# JSON-LD
RewriteCond %{HTTP_ACCEPT} application/ld\+json [NC]
RewriteRule ^1\.0\.0/?$ https://GabrieleT0.github.io/FAIR-O-An-Ontology-for-FAIR-Assessment-and-Scoring/1.0.0/ontology.jsonld [R=303,L]

# RDF/XML
RewriteCond %{HTTP_ACCEPT} application/rdf\+xml [NC]
RewriteRule ^1\.0\.0/?$ https://GabrieleT0.github.io/FAIR-O-An-Ontology-for-FAIR-Assessment-and-Scoring/1.0.0/ontology.owl [R=303,L]

# N-Triples
RewriteCond %{HTTP_ACCEPT} application/n-triples [NC]
RewriteRule ^1\.0\.0/?$ https://GabrieleT0.github.io/FAIR-O-An-Ontology-for-FAIR-Assessment-and-Scoring/1.0.0/ontology.nt [R=303,L]

# Turtle
RewriteCond %{HTTP_ACCEPT} text/turtle [NC,OR]
RewriteCond %{HTTP_ACCEPT} application/x-turtle [NC]
RewriteRule ^1\.0\.0/?$ https://GabrieleT0.github.io/FAIR-O-An-Ontology-for-FAIR-Assessment-and-Scoring/1.0.0/ontology.ttl [R=303,L]

# HTML
RewriteRule ^1\.0\.0/?$ https://GabrieleT0.github.io/FAIR-O-An-Ontology-for-FAIR-Assessment-and-Scoring/1.0.0/ [R=303,L]

# Latest version

