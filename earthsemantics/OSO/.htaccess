Options +FollowSymLinks
RewriteEngine On

# MIME types
AddType text/turtle .ttl
AddType application/rdf+xml .rdf
AddType application/ld+json .jsonld
AddType text/n3 .n3

# Version IRIs
RewriteRule ^1\.0\.0/?$ /earthsemantics/OSO/1.0.0.ttl [R=302,L]
RewriteRule ^1\.0\.1/?$ /earthsemantics/OSO/1.0.1.ttl [R=302,L]
RewriteRule ^1\.0\.2/?$ /earthsemantics/OSO/1.0.2.ttl [R=302,L]

# SPARQL endpoint
RewriteRule ^sparql/?$ https://virtuoso.ifremer.fr/oso/sparql/ [R=302,L]

# SPARQL UI
RewriteRule ^ui/?$ https://virtuoso.ifremer.fr/oso/ [R=302,L]

# Main ontology IRI: Turtle if requested
RewriteCond %{HTTP_ACCEPT} text/turtle [OR]
RewriteCond %{HTTP_ACCEPT} application/x-turtle
RewriteRule ^$ /earthsemantics/OSO/OSO.ttl [R=302,L]

# Main ontology IRI: HTML fallback
RewriteRule ^$ https://emso-eric.github.io/oso-ontology/ [R=302,L]

# Explicit Turtle serialization
RewriteRule ^ttl/?$ /earthsemantics/OSO/OSO.ttl [R=302,L]

# Metadata artifacts
RewriteRule ^void/?$ /earthsemantics/OSO/void.ttl [R=302,L]
RewriteRule ^dcat/?$ /earthsemantics/OSO/dcat.ttl [R=302,L]
