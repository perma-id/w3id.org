Options +FollowSymLinks
RewriteEngine On

# Default landing page (human-readable)
RewriteRule ^$ https://earthportal.eu/ontologies/OSO [R=302,L]

# Turtle serialization
RewriteRule ^ttl/?$ https://raw.githubusercontent.com/emso-eric/oso-ontology/develop/OSO.ttl [R=302,L]

# VoID
RewriteRule ^void/?$ https://raw.githubusercontent.com/emso-eric/oso-ontology/develop/void.ttl [R=302,L]

# DCAT
RewriteRule ^dcat/?$ https://raw.githubusercontent.com/emso-eric/oso-ontology/develop/dcat.ttl [R=302,L]
