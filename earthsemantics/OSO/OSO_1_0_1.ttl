###  http://purl.org/dc/terms/alternative
dcterms:alternative rdf:type owl:DatatypeProperty ;
                    rdfs:subPropertyOf dcterms:title .


###  http://purl.org/dc/terms/available
dcterms:available rdf:type owl:DatatypeProperty ;
                  rdfs:subPropertyOf dcterms:date .


###  http://purl.org/dc/terms/bibliographicCitation
dcterms:bibliographicCitation rdf:type owl:DatatypeProperty ;
                              rdfs:subPropertyOf dcterms:identifier .


###  http://purl.org/dc/terms/created
dcterms:created rdf:type owl:DatatypeProperty ;
                rdfs:subPropertyOf dcterms:date .


###  http://purl.org/dc/terms/date
dcterms:date rdf:type owl:DatatypeProperty ;
             rdfs:subPropertyOf dcterms:date .


###  http://purl.org/dc/terms/dateAccepted
dcterms:dateAccepted rdf:type owl:DatatypeProperty ;
                     rdfs:subPropertyOf dcterms:date .


###  http://purl.org/dc/terms/dateCopyrighted
dcterms:dateCopyrighted rdf:type owl:DatatypeProperty ;
                        rdfs:subPropertyOf dcterms:date .


###  http://purl.org/dc/terms/dateSubmitted
dcterms:dateSubmitted rdf:type owl:DatatypeProperty ;
                      rdfs:subPropertyOf dcterms:date .


###  http://purl.org/dc/terms/identifier
dcterms:identifier rdf:type owl:DatatypeProperty ;
                   rdfs:subPropertyOf dcterms:identifier .


###  http://purl.org/dc/terms/issued
dcterms:issued rdf:type owl:DatatypeProperty ;
               rdfs:subPropertyOf dcterms:date .


###  http://purl.org/dc/terms/modified
dcterms:modified rdf:type owl:DatatypeProperty ;
                 rdfs:subPropertyOf dcterms:date .


###  http://purl.org/dc/terms/title
dcterms:title rdf:type owl:DatatypeProperty ;
              rdfs:subPropertyOf dcterms:title .


###  http://purl.org/dc/terms/valid
dcterms:valid rdf:type owl:DatatypeProperty ;
              rdfs:subPropertyOf dcterms:date .


###  http://schema.org/endDate
schema:endDate rdf:type owl:DatatypeProperty ;
               rdfs:range xsd:date ;
               rdfs:label "End date"@el ,
                          "End date"@en ,
                          "End date"@es ,
                          "End date"@fr ,
                          "End date"@it ,
                          "End date"@no ,
                          "End date"@pt ,
                          "End date"@ro ;
               skos:prefLabel "End date"@el ,
                              "End date"@en ,
                              "End date"@es ,
                              "End date"@fr ,
                              "End date"@it ,
                              "End date"@no ,
                              "End date"@pt ,
                              "End date"@ro .


###  http://schema.org/startDate
schema:startDate rdf:type owl:DatatypeProperty ;
                 rdfs:range xsd:date ;
                 rdfs:label "Start date"@el ,
                            "Start date"@en ,
                            "Start date"@es ,
                            "Start date"@fr ,
                            "Start date"@it ,
                            "Start date"@no ,
                            "Start date"@pt ,
                            "Start date"@ro ;
                 skos:prefLabel "Start date"@el ,
                                "Start date"@en ,
                                "Start date"@es ,
                                "Start date"@fr ,
                                "Start date"@it ,
                                "Start date"@no ,
                                "Start date"@pt ,
                                "Start date"@ro .


###  http://www.opengis.net/ont/geosparql#asWKT
geosparql:asWKT rdf:type owl:DatatypeProperty ;
                rdfs:subPropertyOf foaf:title .


###  http://www.w3.org/2002/07/owl#bottomDataProperty
owl:bottomDataProperty rdf:type owl:DatatypeProperty ;
                       rdfs:domain owl:Thing ;
                       rdfs:range rdfs:Literal ;
                       rdfs:comment "The data property that does not relate any individual to any data value." ;
                       rdfs:isDefinedBy owl: ;
                       rdfs:label "bottomDataProperty" .


###  http://www.w3.org/2002/07/owl#cardinality
owl:cardinality rdf:type owl:DatatypeProperty ;
                rdfs:domain owl:Restriction ;
                rdfs:range xsd:nonNegativeInteger ;
                rdfs:comment "The property that determines the cardinality of an exact cardinality restriction." ;
                rdfs:isDefinedBy owl: ;
                rdfs:label "cardinality" .


###  http://www.w3.org/2002/07/owl#maxCardinality
owl:maxCardinality rdf:type owl:DatatypeProperty ;
                   rdfs:domain owl:Restriction ;
                   rdfs:range xsd:nonNegativeInteger ;
                   rdfs:comment "The property that determines the cardinality of a maximum cardinality restriction." ;
                   rdfs:isDefinedBy owl: ;
                   rdfs:label "maxCardinality" .


###  http://www.w3.org/2002/07/owl#maxQualifiedCardinality
owl:maxQualifiedCardinality rdf:type owl:DatatypeProperty ;
                            rdfs:domain owl:Restriction ;
                            rdfs:range xsd:nonNegativeInteger ;
                            rdfs:comment "The property that determines the cardinality of a maximum qualified cardinality restriction." ;
                            rdfs:isDefinedBy owl: ;
                            rdfs:label "maxQualifiedCardinality" .


###  http://www.w3.org/2002/07/owl#minCardinality
owl:minCardinality rdf:type owl:DatatypeProperty ;
                   rdfs:domain owl:Restriction ;
                   rdfs:range xsd:nonNegativeInteger ;
                   rdfs:comment "The property that determines the cardinality of a minimum cardinality restriction." ;
                   rdfs:isDefinedBy owl: ;
                   rdfs:label "minCardinality" .


###  http://www.w3.org/2002/07/owl#minQualifiedCardinality
owl:minQualifiedCardinality rdf:type owl:DatatypeProperty ;
                            rdfs:domain owl:Restriction ;
                            rdfs:range xsd:nonNegativeInteger ;
                            rdfs:comment "The property that determines the cardinality of a minimum qualified cardinality restriction." ;
                            rdfs:isDefinedBy owl: ;
                            rdfs:label "minQualifiedCardinality" .


###  http://www.w3.org/2002/07/owl#qualifiedCardinality
owl:qualifiedCardinality rdf:type owl:DatatypeProperty ;
                         rdfs:domain owl:Restriction ;
                         rdfs:range xsd:nonNegativeInteger ;
                         rdfs:comment "The property that determines the cardinality of an exact qualified cardinality restriction." ;
                         rdfs:isDefinedBy owl: ;
                         rdfs:label "qualifiedCardinality" .


###  http://www.w3.org/2002/07/owl#topDataProperty
owl:topDataProperty rdf:type owl:DatatypeProperty ;
                    rdfs:domain owl:Thing ;
                    rdfs:range rdfs:Literal ;
                    rdfs:comment "The data property that relates every individual to every data value." ;
                    rdfs:isDefinedBy owl: ;
                    rdfs:label "topDataProperty" .


###  http://www.w3.org/2003/01/geo/wgs84_pos#Latitude
wgs84_pos:Latitude rdf:type owl:DatatypeProperty ;
                   rdfs:domain geosparql:Geometry ;
                   rdfs:range xsd:double .


###  http://www.w3.org/2003/01/geo/wgs84_pos#Longitude
wgs84_pos:Longitude rdf:type owl:DatatypeProperty ;
                    rdfs:domain geosparql:Geometry ;
                    rdfs:range xsd:double .


###  http://www.w3.org/2004/02/skos/core#notation
skos:notation rdf:type owl:DatatypeProperty ;
              rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
              rdfs:label "notation"@el ,
                         "notation"@en ,
                         "notation"@es ,
                         "notation"@fr ,
                         "notation"@it ,
                         "notation"@no ,
                         "notation"@pt ,
                         "notation"@ro ;
              skos:definition "A notation, also known as classification code, is a string of characters such as \"T58.5\" or \"303.4833\" used to uniquely identify a concept within the scope of a given concept scheme."@en ;
              skos:scopeNote "By convention, skos:notation is used with a typed literal in the object position of the triple."@en .


###  http://xmlns.com/foaf/0.1/accountName
foaf:accountName rdf:type owl:DatatypeProperty ;
                 rdfs:domain foaf:OnlineAccount ;
                 rdfs:range rdfs:Literal ;
                 rdfs:comment "Indicates the name (identifier) associated with this online account." ;
                 rdfs:isDefinedBy foaf: ;
                 rdfs:label "account name" ;
                 ns:term_status "testing" .


###  http://xmlns.com/foaf/0.1/age
foaf:age rdf:type owl:DatatypeProperty ,
                  owl:FunctionalProperty ;
         rdfs:domain foaf:Agent ;
         rdfs:range rdfs:Literal ;
         rdfs:comment "The age in years of some agent." ;
         rdfs:isDefinedBy foaf: ;
         rdfs:label "age" ;
         ns:term_status "unstable" .


###  http://xmlns.com/foaf/0.1/aimChatID
foaf:aimChatID rdf:type owl:DatatypeProperty .


###  http://xmlns.com/foaf/0.1/birthday
foaf:birthday rdf:type owl:DatatypeProperty ,
                       owl:FunctionalProperty ;
              rdfs:domain foaf:Agent ;
              rdfs:range rdfs:Literal ;
              rdfs:comment "The birthday of this Agent, represented in mm-dd string form, eg. '12-31'." ;
              rdfs:isDefinedBy foaf: ;
              rdfs:label "birthday" ;
              ns:term_status "unstable" .


###  http://xmlns.com/foaf/0.1/dnaChecksum
foaf:dnaChecksum rdf:type owl:DatatypeProperty ;
                 rdfs:range rdfs:Literal ;
                 rdfs:comment "A checksum for the DNA of some thing. Joke." ;
                 rdfs:isDefinedBy foaf: ;
                 rdfs:label "DNA checksum" ;
                 ns:term_status "archaic" .


###  http://xmlns.com/foaf/0.1/familyName
foaf:familyName rdf:type owl:DatatypeProperty ;
                rdfs:domain foaf:Person ;
                rdfs:range rdfs:Literal ;
                rdfs:comment "The family name of some person." ;
                rdfs:isDefinedBy foaf: ;
                rdfs:label "familyName" ;
                ns:term_status "testing" .


###  http://xmlns.com/foaf/0.1/family_name
foaf:family_name rdf:type owl:DatatypeProperty ;
