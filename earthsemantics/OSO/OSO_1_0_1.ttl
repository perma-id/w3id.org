                 rdfs:label "ERIC federated a Research Infrastructure"@el ,
                            "ERIC federated a Research Infrastructure"@en ,
                            "ERIC federated a Research Infrastructure"@es ,
                            "ERIC federated a Research Infrastructure"@fr ,
                            "ERIC federated a Research Infrastructure"@it ,
                            "ERIC federated a Research Infrastructure"@no ,
                            "ERIC federated a Research Infrastructure"@pt ,
                            "ERIC federated a Research Infrastructure"@ro ;
                 skos:prefLabel "ERIC federated a Research Infrastructure"@el ,
                                "ERIC federated a Research Infrastructure"@en ,
                                "ERIC federated a Research Infrastructure"@es ,
                                "ERIC federated a Research Infrastructure"@fr ,
                                "ERIC federated a Research Infrastructure"@it ,
                                "ERIC federated a Research Infrastructure"@no ,
                                "ERIC federated a Research Infrastructure"@pt ,
                                "ERIC federated a Research Infrastructure"@ro .


