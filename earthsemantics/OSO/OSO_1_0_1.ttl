OSO:ERICMembership rdf:type owl:Class ;
                   rdfs:label "Συμμετοχή σε ERIC"@el ,
                              "ERIC membership"@en ,
                              "Membresía en un ERIC"@es ,
                              "Appartenance à un ERIC"@fr ,
