                 rdfs:label "priorVersion" ;
                 rdfs:range owl:Ontology ;
                 rdfs:domain owl:Ontology .


###  http://www.w3.org/2002/07/owl#sameAs
owl:sameAs rdf:type owl:AnnotationProperty ;
           rdfs:range owl:Thing .


###  http://www.w3.org/2002/07/owl#versionIRI
owl:versionIRI rdf:type owl:AnnotationProperty ;
               rdfs:comment "The property that identifies the version IRI of an ontology." ;
               rdfs:isDefinedBy owl: ;
               rdfs:label "versionIRI" ;
               rdfs:range owl:Ontology ;
               rdfs:domain owl:Ontology .


###  http://www.w3.org/2002/07/owl#versionInfo
owl:versionInfo rdf:type owl:AnnotationProperty ;
                rdfs:comment "The annotation property that provides version information for an ontology or another OWL construct." ;
                rdfs:isDefinedBy owl: ;
                rdfs:label "versionInfo" ;
                rdfs:range rdfs:Resource ;
                rdfs:domain rdfs:Resource .


###  http://www.w3.org/2003/01/geo/wgs84_pos#alt
wgs84_pos:alt rdf:type owl:AnnotationProperty ;
              rdfs:comment """The WGS84 altitude of a SpatialThing (decimal meters 
above the local reference ellipsoid).""" ;
              rdfs:label "altitude" ;
              rdfs:domain wgs84_pos:SpatialThing .


###  http://www.w3.org/2003/01/geo/wgs84_pos#lat
wgs84_pos:lat rdf:type owl:AnnotationProperty ;
              rdfs:comment "The WGS84 latitude of a SpatialThing (decimal degrees)." ;
              rdfs:label "latitude" ;
              rdfs:domain wgs84_pos:SpatialThing .


###  http://www.w3.org/2003/01/geo/wgs84_pos#location
wgs84_pos:location rdf:type owl:AnnotationProperty ;
                   rdfs:range wgs84_pos:SpatialThing .


###  http://www.w3.org/2003/01/geo/wgs84_pos#long
wgs84_pos:long rdf:type owl:AnnotationProperty ;
               rdfs:comment "The WGS84 longitude of a SpatialThing (decimal degrees)." ;
               rdfs:label "longitude" ;
               rdfs:domain wgs84_pos:SpatialThing .


###  http://www.w3.org/2003/06/sw-vocab-status/ns#term_status
ns:term_status rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#altLabel
skos:altLabel rdf:type owl:AnnotationProperty ;
              rdfs:comment "The range of skos:altLabel is the class of RDF plain literals."@el ,
                           "The range of skos:altLabel is the class of RDF plain literals."@en ,
                           "The range of skos:altLabel is the class of RDF plain literals."@es ,
                           "The range of skos:altLabel is the class of RDF plain literals."@fr ,
                           "The range of skos:altLabel is the class of RDF plain literals."@it ,
                           "The range of skos:altLabel is the class of RDF plain literals."@no ,
                           "The range of skos:altLabel is the class of RDF plain literals."@pt ,
                           "The range of skos:altLabel is the class of RDF plain literals."@ro ,
                           "skos:prefLabel, skos:altLabel and skos:hiddenLabel are pairwise disjoint properties."@el ,
                           "skos:prefLabel, skos:altLabel and skos:hiddenLabel are pairwise disjoint properties."@en ,
                           "skos:prefLabel, skos:altLabel and skos:hiddenLabel are pairwise disjoint properties."@es ,
                           "skos:prefLabel, skos:altLabel and skos:hiddenLabel are pairwise disjoint properties."@fr ,
                           "skos:prefLabel, skos:altLabel and skos:hiddenLabel are pairwise disjoint properties."@it ,
                           "skos:prefLabel, skos:altLabel and skos:hiddenLabel are pairwise disjoint properties."@no ,
                           "skos:prefLabel, skos:altLabel and skos:hiddenLabel are pairwise disjoint properties."@pt ,
                           "skos:prefLabel, skos:altLabel and skos:hiddenLabel are pairwise disjoint properties."@ro ;
              rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
              rdfs:label "alternative label"@el ,
                         "alternative label"@en ,
                         "alternative label"@es ,
                         "alternative label"@fr ,
                         "alternative label"@it ,
                         "alternative label"@no ,
                         "alternative label"@pt ,
                         "alternative label"@ro ;
              skos:definition "An alternative lexical label for a resource."@en ;
              skos:example "Acronyms, abbreviations, spelling variants, and irregular plural/singular forms may be included among the alternative labels for a concept. Mis-spelled terms are normally included as hidden labels (see skos:hiddenLabel)."@en ;
              rdfs:subPropertyOf rdfs:label .


###  http://www.w3.org/2004/02/skos/core#changeNote
skos:changeNote rdf:type owl:AnnotationProperty ;
                rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                rdfs:label "change note"@el ,
                           "change note"@en ,
                           "change note"@es ,
                           "change note"@fr ,
                           "change note"@it ,
                           "change note"@no ,
                           "change note"@pt ,
                           "change note"@ro ;
                skos:definition "A note about a modification to a concept."@en ;
                rdfs:subPropertyOf skos:note .


###  http://www.w3.org/2004/02/skos/core#definition
skos:definition rdf:type owl:AnnotationProperty ;
                rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                rdfs:label "definition"@el ,
                           "definition"@en ,
                           "definition"@es ,
                           "definition"@fr ,
                           "definition"@it ,
                           "definition"@no ,
                           "definition"@pt ,
                           "definition"@ro ;
                skos:definition "A statement or formal explanation of the meaning of a concept."@en ;
                rdfs:subPropertyOf skos:note .


###  http://www.w3.org/2004/02/skos/core#editorialNote
skos:editorialNote rdf:type owl:AnnotationProperty ;
                   rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                   rdfs:label "editorial note"@el ,
                              "editorial note"@en ,
                              "editorial note"@es ,
                              "editorial note"@fr ,
                              "editorial note"@it ,
                              "editorial note"@no ,
                              "editorial note"@pt ,
                              "editorial note"@ro ;
                   skos:definition "A note for an editor, translator or maintainer of the vocabulary."@en ;
                   rdfs:subPropertyOf skos:note .


###  http://www.w3.org/2004/02/skos/core#example
skos:example rdf:type owl:AnnotationProperty ;
             rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
             rdfs:label "example"@el ,
                        "example"@en ,
                        "example"@es ,
                        "example"@fr ,
                        "example"@it ,
                        "example"@no ,
                        "example"@pt ,
                        "example"@ro ;
             skos:definition "An example of the use of a concept."@en ;
             rdfs:subPropertyOf skos:note .


###  http://www.w3.org/2004/02/skos/core#hiddenLabel
skos:hiddenLabel rdf:type owl:AnnotationProperty ;
                 rdfs:comment "The range of skos:hiddenLabel is the class of RDF plain literals."@el ,
                              "The range of skos:hiddenLabel is the class of RDF plain literals."@en ,
                              "The range of skos:hiddenLabel is the class of RDF plain literals."@es ,
                              "The range of skos:hiddenLabel is the class of RDF plain literals."@fr ,
                              "The range of skos:hiddenLabel is the class of RDF plain literals."@it ,
                              "The range of skos:hiddenLabel is the class of RDF plain literals."@no ,
                              "The range of skos:hiddenLabel is the class of RDF plain literals."@pt ,
                              "The range of skos:hiddenLabel is the class of RDF plain literals."@ro ,
                              "skos:prefLabel, skos:altLabel and skos:hiddenLabel are pairwise disjoint properties."@el ,
                              "skos:prefLabel, skos:altLabel and skos:hiddenLabel are pairwise disjoint properties."@en ,
                              "skos:prefLabel, skos:altLabel and skos:hiddenLabel are pairwise disjoint properties."@es ,
                              "skos:prefLabel, skos:altLabel and skos:hiddenLabel are pairwise disjoint properties."@fr ,
                              "skos:prefLabel, skos:altLabel and skos:hiddenLabel are pairwise disjoint properties."@it ,
                              "skos:prefLabel, skos:altLabel and skos:hiddenLabel are pairwise disjoint properties."@no ,
                              "skos:prefLabel, skos:altLabel and skos:hiddenLabel are pairwise disjoint properties."@pt ,
                              "skos:prefLabel, skos:altLabel and skos:hiddenLabel are pairwise disjoint properties."@ro ;
                 rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                 rdfs:label "hidden label"@el ,
                            "hidden label"@en ,
                            "hidden label"@es ,
                            "hidden label"@fr ,
                            "hidden label"@it ,
                            "hidden label"@no ,
                            "hidden label"@pt ,
                            "hidden label"@ro ;
                 skos:definition "A lexical label for a resource that should be hidden when generating visual displays of the resource, but should still be accessible to free text search operations."@en ;
                 rdfs:subPropertyOf rdfs:label .


###  http://www.w3.org/2004/02/skos/core#historyNote
skos:historyNote rdf:type owl:AnnotationProperty ;
                 rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                 rdfs:label "history note"@el ,
                            "history note"@en ,
                            "history note"@es ,
                            "history note"@fr ,
                            "history note"@it ,
                            "history note"@no ,
                            "history note"@pt ,
                            "history note"@ro ;
                 skos:definition "A note about the past state/use/meaning of a concept."@en ;
                 rdfs:subPropertyOf skos:note .


###  http://www.w3.org/2004/02/skos/core#note
skos:note rdf:type owl:AnnotationProperty ;
          rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
          rdfs:label "note"@el ,
                     "note"@en ,
                     "note"@es ,
                     "note"@fr ,
                     "note"@it ,
                     "note"@no ,
                     "note"@pt ,
                     "note"@ro ;
          skos:definition "A general note, for any purpose."@en ;
          skos:scopeNote "This property may be used directly, or as a super-property for more specific note types."@en .


###  http://www.w3.org/2004/02/skos/core#prefLabel
skos:prefLabel rdf:type owl:AnnotationProperty ;
               rdfs:comment "A resource has no more than one value of skos:prefLabel per language tag, and no more than one value of skos:prefLabel without language tag."@el ,
                            "A resource has no more than one value of skos:prefLabel per language tag, and no more than one value of skos:prefLabel without language tag."@en ,
                            "A resource has no more than one value of skos:prefLabel per language tag, and no more than one value of skos:prefLabel without language tag."@es ,
                            "A resource has no more than one value of skos:prefLabel per language tag, and no more than one value of skos:prefLabel without language tag."@fr ,
                            "A resource has no more than one value of skos:prefLabel per language tag, and no more than one value of skos:prefLabel without language tag."@it ,
                            "A resource has no more than one value of skos:prefLabel per language tag, and no more than one value of skos:prefLabel without language tag."@no ,
                            "A resource has no more than one value of skos:prefLabel per language tag, and no more than one value of skos:prefLabel without language tag."@pt ,
                            "A resource has no more than one value of skos:prefLabel per language tag, and no more than one value of skos:prefLabel without language tag."@ro ,
                            "The range of skos:prefLabel is the class of RDF plain literals."@el ,
                            "The range of skos:prefLabel is the class of RDF plain literals."@en ,
                            "The range of skos:prefLabel is the class of RDF plain literals."@es ,
                            "The range of skos:prefLabel is the class of RDF plain literals."@fr ,
                            "The range of skos:prefLabel is the class of RDF plain literals."@it ,
                            "The range of skos:prefLabel is the class of RDF plain literals."@no ,
                            "The range of skos:prefLabel is the class of RDF plain literals."@pt ,
                            "The range of skos:prefLabel is the class of RDF plain literals."@ro ,
                            """skos:prefLabel, skos:altLabel and skos:hiddenLabel are pairwise
      disjoint properties."""@el ,
                            """skos:prefLabel, skos:altLabel and skos:hiddenLabel are pairwise
      disjoint properties."""@en ,
                            """skos:prefLabel, skos:altLabel and skos:hiddenLabel are pairwise
      disjoint properties."""@es ,
                            """skos:prefLabel, skos:altLabel and skos:hiddenLabel are pairwise
      disjoint properties."""@fr ,
                            """skos:prefLabel, skos:altLabel and skos:hiddenLabel are pairwise
      disjoint properties."""@it ,
                            """skos:prefLabel, skos:altLabel and skos:hiddenLabel are pairwise
      disjoint properties."""@no ,
                            """skos:prefLabel, skos:altLabel and skos:hiddenLabel are pairwise
      disjoint properties."""@pt ,
                            """skos:prefLabel, skos:altLabel and skos:hiddenLabel are pairwise
      disjoint properties."""@ro ;
               rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
               rdfs:label "preferred label"@el ,
                          "preferred label"@en ,
                          "preferred label"@es ,
                          "preferred label"@fr ,
                          "preferred label"@it ,
                          "preferred label"@no ,
                          "preferred label"@pt ,
                          "preferred label"@ro ;
               skos:definition "The preferred lexical label for a resource, in a given language."@en ;
               rdfs:subPropertyOf rdfs:label .


###  http://www.w3.org/2004/02/skos/core#scopeNote
skos:scopeNote rdf:type owl:AnnotationProperty ;
               rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
               rdfs:label "scope note"@el ,
                          "scope note"@en ,
                          "scope note"@es ,
                          "scope note"@fr ,
                          "scope note"@it ,
                          "scope note"@no ,
                          "scope note"@pt ,
                          "scope note"@ro ;
               skos:definition "A note that helps to clarify the meaning and/or the use of a concept."@en ;
               rdfs:subPropertyOf skos:note .


