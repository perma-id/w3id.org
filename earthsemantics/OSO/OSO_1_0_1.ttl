                                   "A Regional Facility is managed by one or more Organisations."@fr ,
                                   "A Regional Facility is managed by one or more Organisations."@it ,
                                   "A Regional Facility is managed by one or more Organisations."@no ,
                                   "A Regional Facility is managed by one or more Organisations."@pt ,
                                   "A Regional Facility is managed by one or more Organisations."@ro ;
                      rdfs:label "Regional Facility is managed by an Organisation"@el ,
                                 "Regional Facility is managed by an Organisation"@en ,
                                 "Regional Facility is managed by an Organisation"@es ,
                                 "Regional Facility is managed by an Organisation"@fr ,
                                 "Regional Facility is managed by an Organisation"@it ,
                                 "Regional Facility is managed by an Organisation"@no ,
                                 "Regional Facility is managed by an Organisation"@pt ,
                                 "Regional Facility is managed by an Organisation"@ro ;
                      skos:prefLabel "Regional Facility is managed by an Organisation"@el ,
                                     "Regional Facility is managed by an Organisation"@en ,
                                     "Regional Facility is managed by an Organisation"@es ,
                                     "Regional Facility is managed by an Organisation"@fr ,
                                     "Regional Facility is managed by an Organisation"@it ,
                                     "Regional Facility is managed by an Organisation"@no ,
                                     "Regional Facility is managed by an Organisation"@pt ,
                                     "Regional Facility is managed by an Organisation"@ro .


