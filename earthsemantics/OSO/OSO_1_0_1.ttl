###  https://w3id.org/earthsemantics/OSO#Canarias
OSO:Canarias rdf:type owl:NamedIndividual ,
                      OSO:RegionalFacility ;
             OSO:RegionalFacility_is_linked_to_a_project OSO:Atlantic_Whale_Deal ;
             OSO:hasERICMembership OSO:Canarias_EMSO_membership ;
             OSO:containsSite OSO:ESTOC ,
                              OSO:East_of_Gran_Canaria ;
             OSO:hasRegionalTeamLeader OSO:Eric_DELORY ;
             OSO:ledByOrganization OSO:CSIC ,
                                   OSO:PLOCAN ,
                                   OSO:ULPGC ;
             foaf:homepage "https://plocan.eu/en/installations/ocean-observatory"^^xsd:anyURI ;
             OSO:DistanceFromLand 60 ;
             OSO:dateFirstDeployment "1994-01-01" ;
             OSO:maxWaterDepth 3630 ;
             dcterms:description "EMSO Canarias, a.k.a. ESTOC (29º10’ N, 15º30’ W) is a monitoring time-series program. The station is located within the weak southward return flows on the Eastern side of the North Atlantic subtropical gyre. ESTOC is an open ocean site, located well outside of the highly variable Eastern boundary with its strong coastal upwelling regime (although interaction with this regime exists). The site is sufficiently deep to encompass the Eastern subtropical North Atlantic’s major water masses including the North Atlantic Deep Water (except the AABW). ESTOC is windward of the Canary Islands to avoid wake effects of both the major currents and winds (Canary Current and Northeast Trade Winds), and is far enough from coasts and islands to serve as reference for satellite images and altimetry."@en ;
             rdfs:comment "Canarias Regional Facility is linked to the Atlantic Whale Deal project (issue concerning collision with marine mammals)"@el ,
                          "Canarias Regional Facility is linked to the Atlantic Whale Deal project (issue concerning collision with marine mammals)"@en ,
                          "Canarias Regional Facility is linked to the Atlantic Whale Deal project (issue concerning collision with marine mammals)"@es ,
                          "Canarias Regional Facility is linked to the Atlantic Whale Deal project (issue concerning collision with marine mammals)"@fr ,
                          "Canarias Regional Facility is linked to the Atlantic Whale Deal project (issue concerning collision with marine mammals)"@it ,
                          "Canarias Regional Facility is linked to the Atlantic Whale Deal project (issue concerning collision with marine mammals)"@no ,
                          "Canarias Regional Facility is linked to the Atlantic Whale Deal project (issue concerning collision with marine mammals)"@pt ,
                          "Canarias Regional Facility is linked to the Atlantic Whale Deal project (issue concerning collision with marine mammals)"@ro ;
             rdfs:label "Canarias"@el ,
                        "Canarias"@en ,
                        "Canarias"@es ,
                        "Canarias"@fr ,
                        "Canarias"@it ,
                        "Canarias"@no ,
                        "Canarias"@pt ,
                        "Canarias"@ro ;
             skos:prefLabel "Canarias"@el ,
                            "Canarias"@en ,
                            "Canarias"@es ,
                            "Canarias"@fr ,
                            "Canarias"@it ,
                            "Canarias"@no ,
                            "Canarias"@pt ,
                            "Canarias"@ro .


