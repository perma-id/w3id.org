      rdf:type dcat:Distribution ;
      dcat:accessURL <https://w3id.org/earthsemantics/OSO.ttl> ;
      dcat:downloadURL <https://w3id.org/earthsemantics/OSO.ttl> ;
      dcat:mediaType <https://www.iana.org/assignments/media-types/text/turtle> ;
      dcterms:format "text/turtle" ;
      rdfs:label "OSO Turtle file (EarthPortal)"@en ;
