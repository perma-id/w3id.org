###  https://w3id.org/earthsemantics/OSO#DistanceFromLand
OSO:DistanceFromLand rdf:type owl:DatatypeProperty ;
                     rdfs:domain OSO:RegionalFacility ,
                                 OSO:Site ;
                     rdfs:range xsd:integer ;
                     qudt:unit unit:NauticalMile ;
                     rdfs:comment "value expressed in nautical miles (NM)"@el ,
                                  "value expressed in nautical miles (NM)"@en ,
                                  "value expressed in nautical miles (NM)"@es ,
                                  "value expressed in nautical miles (NM)"@fr ,
                                  "value expressed in nautical miles (NM)"@it ,
                                  "value expressed in nautical miles (NM)"@no ,
                                  "value expressed in nautical miles (NM)"@pt ,
                                  "value expressed in nautical miles (NM)"@ro ;
                     rdfs:label "Distance from land"@el ,
                                "Distance from land"@en ,
                                "Distance from land"@es ,
                                "Distance from land"@fr ,
                                "Distance from land"@it ,
                                "Distance from land"@no ,
                                "Distance from land"@pt ,
                                "Distance from land"@ro ;
                     skos:prefLabel "Distance from land"@el ,
                                    "Distance from land"@en ,
                                    "Distance from land"@es ,
                                    "Distance from land"@fr ,
                                    "Distance from land"@it ,
                                    "Distance from land"@no ,
                                    "Distance from land"@pt ,
                                    "Distance from land"@ro .


###  https://w3id.org/earthsemantics/OSO#dateFirstDeployment
OSO:dateFirstDeployment rdf:type owl:DatatypeProperty ;
                        rdfs:subPropertyOf schema:startDate ;
                        rdfs:domain OSO:Platform ,
                                    OSO:SubPlatform ,
                                    OSO:RegionalFacility ,
                                    OSO:Site ,
                                    OSO:Subsite ;
                        rdfs:range xsd:date ;
