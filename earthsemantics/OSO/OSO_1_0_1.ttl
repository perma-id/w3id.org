###  https://w3id.org/earthsemantics/OSO#ERIC_has_a_Director_General
OSO:ERIC_has_a_Director_General rdf:type owl:ObjectProperty ;
                                rdfs:domain OSO:ERIC ;
                                rdfs:range schema:Person ;
                                rdfs:label "ERIC has a Director General"@el ,
                                           "ERIC has a Director General"@en ,
                                           "ERIC has a Director General"@es ,
                                           "ERIC has a Director General"@fr ,
                                           "ERIC has a Director General"@it ,
                                           "ERIC has a Director General"@no ,
                                           "ERIC has a Director General"@pt ,
                                           "ERIC has a Director General"@ro ;
                                skos:prefLabel "ERIC has a Director General"@el ,
                                               "ERIC has a Director General"@en ,
                                               "ERIC has a Director General"@es ,
                                               "ERIC has a Director General"@fr ,
                                               "ERIC has a Director General"@it ,
                                               "ERIC has a Director General"@no ,
                                               "ERIC has a Director General"@pt ,
                                               "ERIC has a Director General"@ro .


