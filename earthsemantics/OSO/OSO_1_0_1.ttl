                     rdfs:subPropertyOf geo:hasGeometry ;
                     rdfs:domain OSO:FundedProject ;
                     rdfs:range wgs84_pos:BoundingBox ;
                     rdfs:label "έχει χωρική emprise"@el ,
                                "has spatial extent"@en ,
                                "tiene extensión espacial"@es ,
                                "a une emprise spatiale"@fr ,
                                "ha estensione spaziale"@it ,
                                "har romlig utstrekning"@no ,
                                "tem extensão espacial"@pt ,
                                "are extindere spațială"@ro ;
                     rdfs:comment "Relates an entity to its geographical extent, such as a bounding box or spatial coverage."@en ,
                                  "Relie une entité à son emprise géographique, comme une boîte englobante ou une zone de couverture."@fr .


###  https://w3id.org/earthsemantics/OSO#hasSubsite
OSO:hasSubsite rdf:type owl:ObjectProperty ;
               rdfs:domain OSO:Site ;
               rdfs:range OSO:Subsite ;
               rdfs:label "έχει υπο-τοποθεσία"@el ,
                          "has subsite"@en ,
                          "tiene subsitio"@es ,
                          "a un sous-site"@fr ,
                          "ha sotto-sito"@it ,
                          "har delområde"@no ,
                          "tem subsite"@pt ,
                          "are subsite"@ro ;
               rdfs:comment "Relates a site to a subdivision or component subsite."@en ,
                            "Relie un site à une sous-division ou un sous-site composant."@fr .


###  https://w3id.org/earthsemantics/OSO#isManagedBy
OSO:isManagedBy rdf:type owl:ObjectProperty ;
                rdfs:domain OSO:ERIC ,
                            OSO:ResearchInfrastructure ;
                rdfs:range foaf:Organization ;
                rdfs:comment "Links a research infrastructure (ERIC or national) to the organisation that manages or coordinates it."@en ;
                rdfs:label "is managed by"@en ;
                skos:prefLabel "is managed by"@en .


###  https://w3id.org/earthsemantics/OSO#isMemberof
OSO:isMemberof rdf:type owl:ObjectProperty ;
               rdfs:domain foaf:Organization ;
               rdfs:range OSO:ERIC ;
               rdfs:label "Organisation is member of an ERIC"@el ,
                          "Organisation is member of an ERIC"@en ,
                          "Organisation is member of an ERIC"@es ,
                          "Organisation is member of an ERIC"@fr ,
                          "Organisation is member of an ERIC"@it ,
                          "Organisation is member of an ERIC"@no ,
                          "Organisation is member of an ERIC"@pt ,
                          "Organisation is member of an ERIC"@ro ;
               skos:prefLabel "Organisation is member of an ERIC"@el ,
                              "Organisation is member of an ERIC"@en ,
                              "Organisation is member of an ERIC"@es ,
                              "Organisation is member of an ERIC"@fr ,
                              "Organisation is member of an ERIC"@it ,
                              "Organisation is member of an ERIC"@no ,
                              "Organisation is member of an ERIC"@pt ,
                              "Organisation is member of an ERIC"@ro .


###  https://w3id.org/earthsemantics/OSO#ledByOrganization
OSO:ledByOrganization rdf:type owl:ObjectProperty ;
