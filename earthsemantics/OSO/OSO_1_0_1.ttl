                                 "Regional Facility is linked to Cruise"@es ,
                                 "Regional Facility is linked to Cruise"@fr ,
                                 "Regional Facility is linked to Cruise"@it ,
                                 "Regional Facility is linked to Cruise"@no ,
                                 "Regional Facility is linked to Cruise"@pt ,
                                 "Regional Facility is linked to Cruise"@ro ;
                      skos:prefLabel "Regional Facility is linked to Cruise"@el ,
                                     "Regional Facility is linked to Cruise"@en ,
                                     "Regional Facility is linked to Cruise"@es ,
                                     "Regional Facility is linked to Cruise"@fr ,
                                     "Regional Facility is linked to Cruise"@it ,
