                                   "First deployment date"@en ,
                                   "Fecha del primer despliegue"@es ,
                                   "Date du premier déploiement"@fr ,
                                   "Data del primo dispiegamento"@it ,
                                   "Dato for første utplassering"@no ,
                                   "Data da primeira implantação"@pt ,
                                   "Data primei desfășurări"@ro ;
                        skos:prefLabel "Ημερομηνία πρώτης εγκατάστασης"@el ,
                                       "First deployment date"@en ,
                                       "Fecha del primer despliegue"@es ,
                                       "Date du premier déploiement"@fr ,
