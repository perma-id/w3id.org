# ==========================================
# IMKT
# ==========================================

# --- IMKT VOCAB: Default (concept_scheme.ttl) ---
# Machine (Accept: Turtle)
RewriteCond %{HTTP_ACCEPT} (?:application/x-turtle|text/turtle) [NC]
RewriteRule ^imkt/vocab/?$ https://raw.githubusercontent.com/RCrespoMartins/imkt-fair/main/vocab/concept_scheme.ttl [R=303,L]
# Human 
RewriteCond %{HTTP_ACCEPT} !(?:application/x-turtle|text/turtle) [NC]
RewriteRule ^imkt/vocab/?$ https://github.com/RCrespoMartins/imkt-fair/blob/main/vocab/concept_scheme.ttl [R=303,L]

# --- IMKT VOCAB: Specific files (e.g., test_concept.ttl) ---
# Machine (Accept: Turtle)
RewriteCond %{HTTP_ACCEPT} (?:application/x-turtle|text/turtle) [NC]
RewriteRule ^imkt/vocab/(.+)/?$ https://raw.githubusercontent.com/RCrespoMartins/imkt-fair/main/vocab/$1.ttl [R=303,L]
# Human 
RewriteCond %{HTTP_ACCEPT} !(?:application/x-turtle|text/turtle) [NC]
RewriteRule ^imkt/vocab/(.+)/?$ https://github.com/RCrespoMartins/imkt-fair/blob/main/vocab/$1.ttl [R=303,L]

# --- IMKT DATA: Default (data.ttl) ---
# Machine (Accept: Turtle)
RewriteCond %{HTTP_ACCEPT} (?:application/x-turtle|text/turtle) [NC]
RewriteRule ^imkt/data/?$ https://raw.githubusercontent.com/RCrespoMartins/imkt-fair/main/data/data.ttl [R=303,L]
# Human 
RewriteCond %{HTTP_ACCEPT} !(?:application/x-turtle|text/turtle) [NC]
RewriteRule ^imkt/data/?$ https://github.com/RCrespoMartins/imkt-fair/blob/main/data/data.ttl [R=303,L]

# --- IMKT DATA: Specific files (e.g., action_test.ttl) ---
# Machine (Accept: Turtle)
RewriteCond %{HTTP_ACCEPT} (?:application/x-turtle|text/turtle) [NC]
RewriteRule ^imkt/data/(.+)/?$ https://raw.githubusercontent.com/RCrespoMartins/imkt-fair/main/data/$1.ttl [R=303,L]
# Human 
RewriteCond %{HTTP_ACCEPT} !(?:application/x-turtle|text/turtle) [NC]
RewriteRule ^imkt/data/(.+)/?$ https://github.com/RCrespoMartins/imkt-fair/blob/main/data/$1.ttl [R=303,L]


