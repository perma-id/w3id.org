RewriteRule ^tribology_data_survey/?$ https://github.com/nick-garabedian/tribology-data-survey/blob/main/tribology_data_survey_results.ttl [R=303,L]

RewriteCond %{HTTP_ACCEPT} !(?:application/x-turtle|text/turtle) [NC]
