RewriteEngine On


# CORE — RDF (Accept: Turtle)
RewriteCond %{HTTP_ACCEPT} (?:application/x-turtle|text/turtle) [NC]
RewriteRule ^core/?$ https://gitlab.com/datin-publications/core/-/raw/main/data.ttl [R=303,L]
RewriteCond %{HTTP_ACCEPT} (?:application/x-turtle|text/turtle) [NC]
RewriteRule ^core/vocab/?$ https://gitlab.com/datin-publications/core/-/raw/main/vocab/concept_scheme.ttl [R=303,L]
RewriteCond %{HTTP_ACCEPT} (?:application/x-turtle|text/turtle) [NC]
RewriteRule ^core/(.+)/?$ https://gitlab.com/datin-publications/core/-/raw/main/$1.ttl [R=303,L]

# CORE — HTML/other (fallback)
RewriteCond %{HTTP_ACCEPT} !(?:application/x-turtle|text/turtle) [NC]
RewriteRule ^core/?$ https://gitlab.com/datin-publications/core/-/blob/main/data.ttl [R=303,L]
RewriteCond %{HTTP_ACCEPT} !(?:application/x-turtle|text/turtle) [NC]
RewriteRule ^core/vocab/?$ https://gitlab.com/datin-publications/core/-/blob/main/vocab/concept_scheme.ttl [R=303,L]
RewriteCond %{HTTP_ACCEPT} !(?:application/x-turtle|text/turtle) [NC]
RewriteRule ^core/(.+)/?$ https://gitlab.com/datin-publications/core/-/blob/main/$1.ttl [R=303,L]

