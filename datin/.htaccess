# IKFT — HTML/other (fallback)
RewriteCond %{HTTP_ACCEPT} !(?:application/x-turtle|text/turtle) [NC]
RewriteRule ^ikft/?$ https://gitlab.com/datin-publications/ikft/-/blob/main/data.ttl [R=303,L]
