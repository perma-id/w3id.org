# === Directory: /xwkont/ =====================================================

Options +FollowSymLinks
RewriteEngine on

# === Rewrite Rules ===========================================================

# Temporary (302) redirect while the project is pre-release.
# e.g. https://w3id.org/xwkont => https://github.com/xwkont
RewriteRule ^$ https://github.com/xwkont [R=302,L]

