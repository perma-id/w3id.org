RewriteEngine On

# Redirect to toRoll instance
RewriteRule ^$ https://toroll-materialized-holiness.github.io/skohub-pages/ [R=303,L,QSA]

#Redirect to toRoll Skosmos dashboard
RewriteRule   ^vocs/?$	https://toroll-materialized-holiness.github.io/skohub-pages/ [R=303,L,QSA]

# Redirect to Tagin & Otijjot Meshunnot vocabulary
RewriteRule   ^vocs/taginOM/?$	https://toroll-materialized-holiness.github.io/skohub-pages/w3id.org/toRoll/vocs/taginOM/ [R=303,L,QSA]

# Redirect individual concept of Tagin & OM
RewriteRule   ^vocs/taginOM/([^/]+)$ https://toroll-materialized-holiness.github.io/skohub-pages/w3id.org/toRoll/vocs/taginOM/$1 [R=303,L,QSA]
