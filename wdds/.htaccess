# contact info: Collin Schwantes
# github user: collinschwantes


Options +FollowSymLinks                                                                          
  RewriteEngine on                                                                               
                                                                                                   
  # -------------------------------------------------------
  # Vocabulary root: https://w3id.org/wdds/                                                        
  # -------------------------------------------------------                                      

  RewriteCond %{HTTP_ACCEPT} application/(json|ld\+json)                                           
  RewriteRule ^$
  https://raw.githubusercontent.com/viralemergence/wdds/main/wdds_schema/wdds_schema.json [R=303,L]
                                                                                                 
  RewriteRule ^$ https://viralemergence.github.io/wdds/ [R=303,L]                                  
                                                                                                 
  # -------------------------------------------------------                                        
  # Disease data term URIs:                                                                      
  # https://w3id.org/wdds/terms/disease-data/{termName}
  # -------------------------------------------------------                                        
   
  RewriteCond %{HTTP_ACCEPT} application/(json|ld\+json)                                           
  RewriteRule ^terms/disease-data/(.*)$                                                          
  https://raw.githubusercontent.com/viralemergence/wdds/main/wdds_schema/schemas/disease_data.json 
  [R=303,L]
                                                                                                   
  RewriteRule ^terms/disease-data/(.*)$ https://viralemergence.github.io/wdds/terms/#$1 [R=303,L]  
   
  # -------------------------------------------------------                                        
  # Project metadata term URIs:                                                                  
  # https://w3id.org/wdds/terms/project-metadata/{termName}
  # -------------------------------------------------------                                        
   
  RewriteCond %{HTTP_ACCEPT} application/(json|ld\+json)                                           
  RewriteRule ^terms/project-metadata/(.*)$ https://raw.githubusercontent.com/viralemergence/wdds/m
  ain/wdds_schema/schemas/project_metadata.json [R=303,L]                                          
   
  RewriteRule ^terms/project-metadata/(.*)$ https://viralemergence.github.io/wdds/terms/#$1        
  [R=303,L]                                                                                      
                                                                                                   
  # -------------------------------------------------------                                      
  # Schema URIs: https://w3id.org/wdds/schemas/{schema}
  # -------------------------------------------------------
                                                                                                   
  RewriteRule ^schemas/(.*)$
  https://raw.githubusercontent.com/viralemergence/wdds/main/wdds_schema/schemas/$1 [R=303,L]      
                   