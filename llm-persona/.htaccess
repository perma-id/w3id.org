RewriteEngine On

# Turtle
RewriteCond %{HTTP_ACCEPT} text/turtle [NC]
RewriteRule ^vocab.* https://raw.githubusercontent.com/D2KLab/llm_persona_ontology/refs/heads/master/src/llmp-identity-skos.ttl [R=302,L]
RewriteRule ^ https://raw.githubusercontent.com/D2KLab/llm_persona_ontology/refs/heads/master/src/llmp-ontology.ttl [R=302,L]

# HTML
RewriteCond %{HTTP_ACCEPT} text/html [NC]
RewriteRule ^vocab.* https://d2klab.github.io/llm_persona_ontology/vocab [R=302,L]
RewriteRule ^ https://d2klab.github.io/llm_persona_ontology/ [R=302,L]

# Default fallback
RewriteRule ^vocab.* https://d2klab.github.io/llm_persona_ontology/vocab [R=302,L]
RewriteRule ^ https://d2klab.github.io/llm_persona_ontology/ [R=302,L]
