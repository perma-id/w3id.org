RewriteCond %{HTTP_ACCEPT} application/ld\+json [NC]
RewriteRule ^aerospace-x/data-product-model/identification/([0-9.]+)/?$ https://aerospace-x.pages.fraunhofer.de/data-product-model/org.w3id.aerospace-x.data-product-model.identification/$1/Identification.json [R=303,L,NE]
