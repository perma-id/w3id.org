# https://w3id.org/itsdata/xxx/v# redirects to https://isotc204.org/ontology-its-xxx-v#/latest/ where xxx is the topic area
#
# ## Contact
# This space is administered by:
# ISO/TC 204 WG 1 Convenor
# Kenneth Vaughn
# kvaughn@trevilon.com
# GitHub username: k-vaughn

RewriteEngine On
Options -MultiViews

# Set FORMAT based on Accept header for RDF formats
RewriteCond %{HTTP_ACCEPT} application/rdf\+xml [OR]
RewriteCond %{HTTP_ACCEPT} text/turtle [OR]
RewriteCond %{HTTP_ACCEPT} application/ld\+json [OR]
RewriteCond %{HTTP_ACCEPT} application/n-triples [OR]
RewriteCond %{HTTP_ACCEPT} text/n3
RewriteRule ^ - [E=FORMAT:rdf]

RewriteCond %{HTTP_ACCEPT} text/html
RewriteRule ^ - [E=FORMAT:html]

# Default to RDF (TTL) if no Accept header (common for some tools; safer than HTML default for ontologies)
RewriteCond %{ENV:FORMAT} ^$
RewriteRule ^ - [E=FORMAT:rdf]


# -----------------------------------------------------------------------------
# URL patterns for ITS ontology topic areas
#
# Conventions:
# - topic area is the first path segment (e.g., "regulation")
# - major version is "vN" (e.g., "v2")
#
# Content negotiation (Accept â†’ FORMAT=rdf|html):
# - Topic / release IRIs:
#     RDF  â†’ its-{topic}.ttl
#     HTML â†’ release index
# - Upper-case local name:
#     *SHACL modules (any Accept) â†’ .../{kebab-case}.ttl  (no HTML docs page)
#     *Pattern modules:
#         HTML â†’ .../classes/{Name}/
#         RDF  â†’ .../{kebab-case}.ttl
#     Other Upper-case names (classes, even CamelCase like LegalBasis):
#         HTML â†’ .../classes/{Name}/
#         RDF  â†’ .../its-{topic}.ttl
# - Lower-case local name (property):
#     HTML â†’ .../properties/{name}/
#     RDF  â†’ .../its-{topic}.ttl
# - Explicit .ttl paths always redirect to that file in the ontology main directory
#
# Module naming (so Ontology IRI â†” filename with no exceptions):
# - Pattern modules:  {Area}Pattern  â†’ {area}-pattern.ttl (HTML docs + RDF ttl)
#                     e.g. ConditionPattern â†’ condition-pattern.ttl
# - SHACL modules:    {Area}SHACL    â†’ {area}-shacl.ttl (always the ttl file)
#                     e.g. ConditionSHACL â†’ condition-shacl.ttl
#                     e.g. CoreSHACL â†’ core-shacl.ttl
#
# Releases:
# - Explicit revision: r{int}.{int}[optional-text] (e.g., r3.0, r3.0-alpha)
# - "latest": latest revision pointer
# - Mike timestamp: YYYY-MM-DD_hh-mm-ss
#
# Notes:
# - Rules are ordered from most-specific to least-specific.
# - No [N] rewrite loops (unreliable here; aborted rewrites fall through to ritso).
# - Only local names containing Pattern or SHACL use CamelCaseâ†’kebab module files.
# - Those use fixed 2â€“5 segment captures + expr tolower.
# -----------------------------------------------------------------------------

# Release-pointer fragment (latest | rX.Yâ€¦ | mike timestamp)
#   (?:latest)|(?:r[0-9]+\.[0-9]+(?:[-._A-Za-z0-9]+)?)|(?:20[0-9]{2}-[0-9]{2}-[0-9]{2}_[0-9]{2}-[0-9]{2}-[0-9]{2})

# -----------------------------------------------------------------------------
# 1) Explicit .ttl under a release
# -----------------------------------------------------------------------------
RewriteRule ^([^/]+)/v(\d+)/((?:latest)|(?:r[0-9]+\.[0-9]+(?:[-._A-Za-z0-9]+)?)|(?:20[0-9]{2}-[0-9]{2}-[0-9]{2}_[0-9]{2}-[0-9]{2}-[0-9]{2}))/([^/]+\.ttl)/?$ https://isotc204.org/ontology-its-$1-v$2/$3/$4 [R=303,L]

# -----------------------------------------------------------------------------
# 2) Explicit .ttl (no release â†’ latest)
# -----------------------------------------------------------------------------
RewriteRule ^([^/]+)/v(\d+)/([^/]+\.ttl)/?$ https://isotc204.org/ontology-its-$1-v$2/latest/$3 [R=303,L]

# -----------------------------------------------------------------------------
# 3) Concept + release pointer
# -----------------------------------------------------------------------------

# RDF: 5-part CamelCase + release â†’ kebab .ttl
RewriteCond %{REQUEST_URI} SHACL|Pattern
RewriteCond %{ENV:FORMAT} rdf [OR]
RewriteCond %{REQUEST_URI} SHACL
RewriteRule ^([^/]+)/v(\d+)/([A-Z][a-z][a-z0-9]*)([A-Z][a-z][a-z0-9]*)([A-Z][a-z][a-z0-9]*)([A-Z][a-z][a-z0-9]*)([A-Z][A-Za-z0-9]*)/((?:latest)|(?:r[0-9]+\.[0-9]+(?:[-._A-Za-z0-9]+)?)|(?:20[0-9]{2}-[0-9]{2}-[0-9]{2}_[0-9]{2}-[0-9]{2}-[0-9]{2}))/?$ - [E=A:$3,E=B:$4,E=C:$5,E=D:$6,E=P5:$7,E=REL:$8]
RewriteCond %{REQUEST_URI} SHACL|Pattern
RewriteCond %{ENV:FORMAT} rdf [OR]
RewriteCond %{REQUEST_URI} SHACL
RewriteCond %{ENV:A} .+
RewriteCond expr "tolower(%{ENV:A}.'-'.%{ENV:B}.'-'.%{ENV:C}.'-'.%{ENV:D}.'-'.%{ENV:P5}) =~ m#^(.+)$#"
RewriteRule ^([^/]+)/v(\d+)/([A-Z][a-z][a-z0-9]*)([A-Z][a-z][a-z0-9]*)([A-Z][a-z][a-z0-9]*)([A-Z][a-z][a-z0-9]*)([A-Z][A-Za-z0-9]*)/((?:latest)|(?:r[0-9]+\.[0-9]+(?:[-._A-Za-z0-9]+)?)|(?:20[0-9]{2}-[0-9]{2}-[0-9]{2}_[0-9]{2}-[0-9]{2}-[0-9]{2}))/?$ https://isotc204.org/ontology-its-$1-v$2/%{ENV:REL}/%1.ttl [R=303,L]

# RDF: 4-part CamelCase + release â†’ kebab .ttl
#   TrafficControlDevicePattern/latest
RewriteCond %{REQUEST_URI} SHACL|Pattern
RewriteCond %{ENV:FORMAT} rdf [OR]
RewriteCond %{REQUEST_URI} SHACL
RewriteRule ^([^/]+)/v(\d+)/([A-Z][a-z][a-z0-9]*)([A-Z][a-z][a-z0-9]*)([A-Z][a-z][a-z0-9]*)([A-Z][A-Za-z0-9]*)/((?:latest)|(?:r[0-9]+\.[0-9]+(?:[-._A-Za-z0-9]+)?)|(?:20[0-9]{2}-[0-9]{2}-[0-9]{2}_[0-9]{2}-[0-9]{2}-[0-9]{2}))/?$ - [E=A:$3,E=B:$4,E=C:$5,E=D:$6,E=REL:$7]
RewriteCond %{REQUEST_URI} SHACL|Pattern
RewriteCond %{ENV:FORMAT} rdf [OR]
RewriteCond %{REQUEST_URI} SHACL
RewriteCond %{ENV:A} .+
RewriteCond expr "tolower(%{ENV:A}.'-'.%{ENV:B}.'-'.%{ENV:C}.'-'.%{ENV:D}) =~ m#^(.+)$#"
RewriteRule ^([^/]+)/v(\d+)/([A-Z][a-z][a-z0-9]*)([A-Z][a-z][a-z0-9]*)([A-Z][a-z][a-z0-9]*)([A-Z][A-Za-z0-9]*)/((?:latest)|(?:r[0-9]+\.[0-9]+(?:[-._A-Za-z0-9]+)?)|(?:20[0-9]{2}-[0-9]{2}-[0-9]{2}_[0-9]{2}-[0-9]{2}-[0-9]{2}))/?$ https://isotc204.org/ontology-its-$1-v$2/%{ENV:REL}/%1.ttl [R=303,L]

# RDF: 3-part CamelCase + release â†’ kebab .ttl
RewriteCond %{REQUEST_URI} SHACL|Pattern
RewriteCond %{ENV:FORMAT} rdf [OR]
RewriteCond %{REQUEST_URI} SHACL
RewriteRule ^([^/]+)/v(\d+)/([A-Z][a-z][a-z0-9]*)([A-Z][a-z][a-z0-9]*)([A-Z][A-Za-z0-9]*)/((?:latest)|(?:r[0-9]+\.[0-9]+(?:[-._A-Za-z0-9]+)?)|(?:20[0-9]{2}-[0-9]{2}-[0-9]{2}_[0-9]{2}-[0-9]{2}-[0-9]{2}))/?$ - [E=A:$3,E=B:$4,E=C:$5,E=REL:$6]
RewriteCond %{REQUEST_URI} SHACL|Pattern
RewriteCond %{ENV:FORMAT} rdf [OR]
RewriteCond %{REQUEST_URI} SHACL
RewriteCond %{ENV:A} .+
RewriteCond expr "tolower(%{ENV:A}.'-'.%{ENV:B}.'-'.%{ENV:C}) =~ m#^(.+)$#"
RewriteRule ^([^/]+)/v(\d+)/([A-Z][a-z][a-z0-9]*)([A-Z][a-z][a-z0-9]*)([A-Z][A-Za-z0-9]*)/((?:latest)|(?:r[0-9]+\.[0-9]+(?:[-._A-Za-z0-9]+)?)|(?:20[0-9]{2}-[0-9]{2}-[0-9]{2}_[0-9]{2}-[0-9]{2}-[0-9]{2}))/?$ https://isotc204.org/ontology-its-$1-v$2/%{ENV:REL}/%1.ttl [R=303,L]

# Module CamelCase + release â†’ kebab .ttl (*SHACL any Accept; *Pattern RDF only)
#   ConditionPattern/latest, ConditionSHACL/latest
RewriteCond %{REQUEST_URI} SHACL|Pattern
RewriteCond %{ENV:FORMAT} rdf [OR]
RewriteCond %{REQUEST_URI} SHACL
RewriteRule ^([^/]+)/v(\d+)/([A-Z][a-z][a-z0-9]*)([A-Z][A-Za-z0-9]*)/((?:latest)|(?:r[0-9]+\.[0-9]+(?:[-._A-Za-z0-9]+)?)|(?:20[0-9]{2}-[0-9]{2}-[0-9]{2}_[0-9]{2}-[0-9]{2}-[0-9]{2}))/?$ - [E=A:$3,E=B:$4,E=REL:$5]
RewriteCond %{REQUEST_URI} SHACL|Pattern
RewriteCond %{ENV:FORMAT} rdf [OR]
RewriteCond %{REQUEST_URI} SHACL
RewriteCond %{ENV:A} .+
RewriteCond expr "tolower(%{ENV:A}.'-'.%{ENV:B}) =~ m#^(.+)$#"
RewriteRule ^([^/]+)/v(\d+)/([A-Z][a-z][a-z0-9]*)([A-Z][A-Za-z0-9]*)/((?:latest)|(?:r[0-9]+\.[0-9]+(?:[-._A-Za-z0-9]+)?)|(?:20[0-9]{2}-[0-9]{2}-[0-9]{2}_[0-9]{2}-[0-9]{2}-[0-9]{2}))/?$ https://isotc204.org/ontology-its-$1-v$2/%{ENV:REL}/%1.ttl [R=303,L]

# RDF: leading acronym + word + release â†’ kebab .ttl
#   ITSRegulation/latest
RewriteCond %{REQUEST_URI} SHACL|Pattern
RewriteCond %{ENV:FORMAT} rdf [OR]
RewriteCond %{REQUEST_URI} SHACL
RewriteRule ^([^/]+)/v(\d+)/([A-Z]{2,})([A-Z][a-z][A-Za-z0-9]*)/((?:latest)|(?:r[0-9]+\.[0-9]+(?:[-._A-Za-z0-9]+)?)|(?:20[0-9]{2}-[0-9]{2}-[0-9]{2}_[0-9]{2}-[0-9]{2}-[0-9]{2}))/?$ - [E=A:$3,E=B:$4,E=REL:$5]
RewriteCond %{REQUEST_URI} SHACL|Pattern
RewriteCond %{ENV:FORMAT} rdf [OR]
RewriteCond %{REQUEST_URI} SHACL
RewriteCond %{ENV:A} .+
RewriteCond expr "tolower(%{ENV:A}.'-'.%{ENV:B}) =~ m#^(.+)$#"
RewriteRule ^([^/]+)/v(\d+)/([A-Z]{2,})([A-Z][a-z][A-Za-z0-9]*)/((?:latest)|(?:r[0-9]+\.[0-9]+(?:[-._A-Za-z0-9]+)?)|(?:20[0-9]{2}-[0-9]{2}-[0-9]{2}_[0-9]{2}-[0-9]{2}-[0-9]{2}))/?$ https://isotc204.org/ontology-its-$1-v$2/%{ENV:REL}/%1.ttl [R=303,L]

# RDF: single-token Upper-case + release â†’ topic vocabulary .ttl
RewriteCond %{ENV:FORMAT} rdf
RewriteRule ^([^/]+)/v(\d+)/([A-Z][A-Za-z0-9]*)/((?:latest)|(?:r[0-9]+\.[0-9]+(?:[-._A-Za-z0-9]+)?)|(?:20[0-9]{2}-[0-9]{2}-[0-9]{2}_[0-9]{2}-[0-9]{2}-[0-9]{2}))/?$ https://isotc204.org/ontology-its-$1-v$2/$4/its-$1.ttl [R=303,L]

# HTML: class/module + release â†’ class docs (not *SHACL modules)
RewriteCond %{REQUEST_URI} !SHACL
RewriteRule ^([^/]+)/v(\d+)/([A-Z][^/]+)/((?:latest)|(?:r[0-9]+\.[0-9]+(?:[-._A-Za-z0-9]+)?)|(?:20[0-9]{2}-[0-9]{2}-[0-9]{2}_[0-9]{2}-[0-9]{2}-[0-9]{2}))/?$ https://isotc204.org/ontology-its-$1-v$2/$4/classes/$3/ [R=303,L]

# RDF: property + release â†’ topic TTL under that release
RewriteCond %{ENV:FORMAT} rdf
RewriteRule ^([^/]+)/v(\d+)/([a-z][^/]+)/((?:latest)|(?:r[0-9]+\.[0-9]+(?:[-._A-Za-z0-9]+)?)|(?:20[0-9]{2}-[0-9]{2}-[0-9]{2}_[0-9]{2}-[0-9]{2}-[0-9]{2}))/?$ https://isotc204.org/ontology-its-$1-v$2/$4/its-$1.ttl [R=303,L]

# HTML: property + release â†’ property docs under that release
RewriteRule ^([^/]+)/v(\d+)/([a-z][^/]+)/((?:latest)|(?:r[0-9]+\.[0-9]+(?:[-._A-Za-z0-9]+)?)|(?:20[0-9]{2}-[0-9]{2}-[0-9]{2}_[0-9]{2}-[0-9]{2}-[0-9]{2}))/?$ https://isotc204.org/ontology-its-$1-v$2/$4/properties/$3/ [R=303,L]

# -----------------------------------------------------------------------------
# 4) Release pointer only (before bare concept rules so "latest" â‰  property)
# -----------------------------------------------------------------------------
RewriteCond %{ENV:FORMAT} rdf
RewriteRule ^([^/]+)/v(\d+)/latest/?$ https://isotc204.org/ontology-its-$1-v$2/latest/its-$1.ttl [R=303,L]
RewriteRule ^([^/]+)/v(\d+)/latest/?$ https://isotc204.org/ontology-its-$1-v$2/latest/ [R=303,L]

RewriteCond %{ENV:FORMAT} rdf
RewriteRule ^([^/]+)/v(\d+)/(r[0-9]+\.[0-9]+(?:[-._A-Za-z0-9]+)?)/?$ https://isotc204.org/ontology-its-$1-v$2/$3/its-$1.ttl [R=303,L]
RewriteRule ^([^/]+)/v(\d+)/(r[0-9]+\.[0-9]+(?:[-._A-Za-z0-9]+)?)/?$ https://isotc204.org/ontology-its-$1-v$2/$3/ [R=303,L]

RewriteCond %{ENV:FORMAT} rdf
RewriteRule ^([^/]+)/v(\d+)/(20[0-9]{2}-[0-9]{2}-[0-9]{2}_[0-9]{2}-[0-9]{2}-[0-9]{2})/?$ https://isotc204.org/ontology-its-$1-v$2/$3/its-$1.ttl [R=303,L]
RewriteRule ^([^/]+)/v(\d+)/(20[0-9]{2}-[0-9]{2}-[0-9]{2}_[0-9]{2}-[0-9]{2}-[0-9]{2})/?$ https://isotc204.org/ontology-its-$1-v$2/$3/ [R=303,L]

# -----------------------------------------------------------------------------
# 5) Concept only (no release â†’ latest)
# -----------------------------------------------------------------------------

# RDF: 5-part CamelCase â†’ kebab .ttl
RewriteCond %{REQUEST_URI} SHACL|Pattern
RewriteCond %{ENV:FORMAT} rdf [OR]
RewriteCond %{REQUEST_URI} SHACL
RewriteRule ^([^/]+)/v(\d+)/([A-Z][a-z][a-z0-9]*)([A-Z][a-z][a-z0-9]*)([A-Z][a-z][a-z0-9]*)([A-Z][a-z][a-z0-9]*)([A-Z][A-Za-z0-9]*)/?$ - [E=A:$3,E=B:$4,E=C:$5,E=D:$6,E=P5:$7]
RewriteCond %{REQUEST_URI} SHACL|Pattern
RewriteCond %{ENV:FORMAT} rdf [OR]
RewriteCond %{REQUEST_URI} SHACL
RewriteCond %{ENV:A} .+
RewriteCond expr "tolower(%{ENV:A}.'-'.%{ENV:B}.'-'.%{ENV:C}.'-'.%{ENV:D}.'-'.%{ENV:P5}) =~ m#^(.+)$#"
RewriteRule ^([^/]+)/v(\d+)/([A-Z][a-z][a-z0-9]*)([A-Z][a-z][a-z0-9]*)([A-Z][a-z][a-z0-9]*)([A-Z][a-z][a-z0-9]*)([A-Z][A-Za-z0-9]*)/?$ https://isotc204.org/ontology-its-$1-v$2/latest/%1.ttl [R=303,L]

# RDF: 4-part CamelCase â†’ kebab .ttl
RewriteCond %{REQUEST_URI} SHACL|Pattern
RewriteCond %{ENV:FORMAT} rdf [OR]
RewriteCond %{REQUEST_URI} SHACL
RewriteRule ^([^/]+)/v(\d+)/([A-Z][a-z][a-z0-9]*)([A-Z][a-z][a-z0-9]*)([A-Z][a-z][a-z0-9]*)([A-Z][A-Za-z0-9]*)/?$ - [E=A:$3,E=B:$4,E=C:$5,E=D:$6]
RewriteCond %{REQUEST_URI} SHACL|Pattern
RewriteCond %{ENV:FORMAT} rdf [OR]
RewriteCond %{REQUEST_URI} SHACL
RewriteCond %{ENV:A} .+
RewriteCond expr "tolower(%{ENV:A}.'-'.%{ENV:B}.'-'.%{ENV:C}.'-'.%{ENV:D}) =~ m#^(.+)$#"
RewriteRule ^([^/]+)/v(\d+)/([A-Z][a-z][a-z0-9]*)([A-Z][a-z][a-z0-9]*)([A-Z][a-z][a-z0-9]*)([A-Z][A-Za-z0-9]*)/?$ https://isotc204.org/ontology-its-$1-v$2/latest/%1.ttl [R=303,L]

# RDF: 3-part CamelCase â†’ kebab .ttl
RewriteCond %{REQUEST_URI} SHACL|Pattern
RewriteCond %{ENV:FORMAT} rdf [OR]
RewriteCond %{REQUEST_URI} SHACL
RewriteRule ^([^/]+)/v(\d+)/([A-Z][a-z][a-z0-9]*)([A-Z][a-z][a-z0-9]*)([A-Z][A-Za-z0-9]*)/?$ - [E=A:$3,E=B:$4,E=C:$5]
RewriteCond %{REQUEST_URI} SHACL|Pattern
RewriteCond %{ENV:FORMAT} rdf [OR]
RewriteCond %{REQUEST_URI} SHACL
RewriteCond %{ENV:A} .+
RewriteCond expr "tolower(%{ENV:A}.'-'.%{ENV:B}.'-'.%{ENV:C}) =~ m#^(.+)$#"
RewriteRule ^([^/]+)/v(\d+)/([A-Z][a-z][a-z0-9]*)([A-Z][a-z][a-z0-9]*)([A-Z][A-Za-z0-9]*)/?$ https://isotc204.org/ontology-its-$1-v$2/latest/%1.ttl [R=303,L]

# Module CamelCase â†’ kebab .ttl (*SHACL any Accept; *Pattern RDF only)
#   ConditionPattern â†’ condition-pattern.ttl; CoreSHACL â†’ core-shacl.ttl
#   LegalBasis (class) is NOT a module â†’ falls through to its-{topic}.ttl
RewriteCond %{REQUEST_URI} SHACL|Pattern
RewriteCond %{ENV:FORMAT} rdf [OR]
RewriteCond %{REQUEST_URI} SHACL
RewriteRule ^([^/]+)/v(\d+)/([A-Z][a-z][a-z0-9]*)([A-Z][A-Za-z0-9]*)/?$ - [E=A:$3,E=B:$4]
RewriteCond %{REQUEST_URI} SHACL|Pattern
RewriteCond %{ENV:FORMAT} rdf [OR]
RewriteCond %{REQUEST_URI} SHACL
RewriteCond %{ENV:A} .+
RewriteCond expr "tolower(%{ENV:A}.'-'.%{ENV:B}) =~ m#^(.+)$#"
RewriteRule ^([^/]+)/v(\d+)/([A-Z][a-z][a-z0-9]*)([A-Z][A-Za-z0-9]*)/?$ https://isotc204.org/ontology-its-$1-v$2/latest/%1.ttl [R=303,L]

# RDF: leading acronym + word â†’ kebab .ttl
#   ITSRegulation â†’ its-regulation.ttl
RewriteCond %{REQUEST_URI} SHACL|Pattern
RewriteCond %{ENV:FORMAT} rdf [OR]
RewriteCond %{REQUEST_URI} SHACL
RewriteRule ^([^/]+)/v(\d+)/([A-Z]{2,})([A-Z][a-z][A-Za-z0-9]*)/?$ - [E=A:$3,E=B:$4]
RewriteCond %{REQUEST_URI} SHACL|Pattern
RewriteCond %{ENV:FORMAT} rdf [OR]
RewriteCond %{REQUEST_URI} SHACL
RewriteCond %{ENV:A} .+
RewriteCond expr "tolower(%{ENV:A}.'-'.%{ENV:B}) =~ m#^(.+)$#"
RewriteRule ^([^/]+)/v(\d+)/([A-Z]{2,})([A-Z][a-z][A-Za-z0-9]*)/?$ https://isotc204.org/ontology-its-$1-v$2/latest/%1.ttl [R=303,L]

# RDF: single-token Upper-case â†’ topic vocabulary .ttl
#   Condition â†’ its-regulation.ttl
RewriteCond %{ENV:FORMAT} rdf
RewriteRule ^([^/]+)/v(\d+)/([A-Z][A-Za-z0-9]*)/?$ https://isotc204.org/ontology-its-$1-v$2/latest/its-$1.ttl [R=303,L]

# HTML: class/module â†’ class docs under latest (not *SHACL modules)
RewriteCond %{REQUEST_URI} !SHACL
RewriteRule ^([^/]+)/v(\d+)/([A-Z][^/]+)/?$ https://isotc204.org/ontology-its-$1-v$2/latest/classes/$3/ [R=303,L]

# RDF: property â†’ topic TTL under latest
RewriteCond %{ENV:FORMAT} rdf
RewriteRule ^([^/]+)/v(\d+)/([a-z][^/]+)/?$ https://isotc204.org/ontology-its-$1-v$2/latest/its-$1.ttl [R=303,L]

# HTML: property â†’ property docs under latest
RewriteRule ^([^/]+)/v(\d+)/([a-z][^/]+)/?$ https://isotc204.org/ontology-its-$1-v$2/latest/properties/$3/ [R=303,L]

# -----------------------------------------------------------------------------
# 6) Topic + major version only
# -----------------------------------------------------------------------------
RewriteCond %{ENV:FORMAT} rdf
RewriteRule ^([^/]+)/v(\d+)/?$ https://isotc204.org/ontology-its-$1-v$2/latest/its-$1.ttl [R=303,L]
RewriteRule ^([^/]+)/v(\d+)/?$ https://isotc204.org/ontology-its-$1-v$2/latest/ [R=303,L]

# -----------------------------------------------------------------------------
# 7) Fallback
# -----------------------------------------------------------------------------
RewriteRule ^ https://isotc204.org/ritso/ [R=303,L]
