# https://w3id.org/itsdata/xxx/v# redirects to https://isotc204.org/ontology-its-xxx-v#/latest/ where xxx is the topic area
#
# ## Contact
# This space is administered by:
# ISO/TC 204 WG 1 Convenor
# Kenneth Vaughn
# kvaughn@trevilon.com
# GitHub username: k-vaughn

RewriteEngine On
Options -MultiViews

# Prefer HTML only when explicitly requested; otherwise default to RDF
RewriteCond %{HTTP_ACCEPT} text/html
RewriteRule ^ - [E=FORMAT:html]

RewriteCond %{ENV:FORMAT} ^$
RewriteRule ^ - [E=FORMAT:rdf]


# -----------------------------------------------------------------------------
# URL patterns for ITS ontology topic areas
#
# Path shape (always):
#   {topic}/{major-version}/{item}/{release}
#   e.g. regulation/v2/ConditionPattern/latest
#
# - topic:          1st segment (e.g., "regulation")
# - major-version:  2nd segment "vN" (e.g., "v2")
# - item:           3rd segment (optional) — class, property, module, or *.ttl
# - release:        4th segment (optional; only when item is present)
#                   Any string is accepted and copied through.
#                   When omitted, "latest" is assumed.
#
# Content negotiation (Accept → FORMAT=rdf|html):
# - Topic only ({topic}/vN):
#     RDF  → .../latest/its-{topic}.ttl
#     HTML → .../latest/
# - Explicit .ttl item:
#     any → .../{release}/{filename.ttl}
# - *SHACL / *Alignment modules (any Accept):
#     → .../{release}/{Item}.ttl  (no HTML docs page)
# - *Pattern modules:
#     HTML → .../{release}/classes/{Item}/
#     RDF  → .../{release}/{Item}.ttl
# - Other Upper-case names (classes):
#     HTML → .../{release}/classes/{Item}/
#     RDF  → .../{release}/its-{topic}.ttl
# - Lower-case names (properties):
#     HTML → .../{release}/properties/{item}/
#     RDF  → .../{release}/its-{topic}.ttl
#
# Notes:
# - Rules are ordered from most-specific to least-specific.
# - Item names are copied through as given (no CamelCase→kebab conversion).
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# 1) Explicit .ttl: {topic}/vN/{file.ttl}/{release}
# -----------------------------------------------------------------------------
RewriteRule ^([^/]+)/v(\d+)/([^/]+\.ttl)/([^/]+)/?$ https://isotc204.org/ontology-its-$1-v$2/$4/$3 [R=303,L]

# -----------------------------------------------------------------------------
# 2) Explicit .ttl: {topic}/vN/{file.ttl}  (no release → latest)
# -----------------------------------------------------------------------------
RewriteRule ^([^/]+)/v(\d+)/([^/]+\.ttl)/?$ https://isotc204.org/ontology-its-$1-v$2/latest/$3 [R=303,L]

# -----------------------------------------------------------------------------
# 3) Item + release: {topic}/vN/{item}/{release}
# -----------------------------------------------------------------------------

# *SHACL / *Alignment (any Accept) → {Item}.ttl
RewriteCond %{REQUEST_URI} SHACL|Alignment
RewriteRule ^([^/]+)/v(\d+)/([^/]+)/([^/]+)/?$ https://isotc204.org/ontology-its-$1-v$2/$4/$3.ttl [R=303,L]

# *Pattern RDF → {Item}.ttl
RewriteCond %{REQUEST_URI} Pattern
RewriteCond %{ENV:FORMAT} rdf
RewriteRule ^([^/]+)/v(\d+)/([^/]+)/([^/]+)/?$ https://isotc204.org/ontology-its-$1-v$2/$4/$3.ttl [R=303,L]

# Class / Pattern HTML → class docs
RewriteCond %{ENV:FORMAT} rdf
RewriteRule ^([^/]+)/v(\d+)/([A-Z][^/]+)/([^/]+)/?$ https://isotc204.org/ontology-its-$1-v$2/$4/its-$1.ttl [R=303,L]
RewriteRule ^([^/]+)/v(\d+)/([A-Z][^/]+)/([^/]+)/?$ https://isotc204.org/ontology-its-$1-v$2/$4/classes/$3/ [R=303,L]

# Property RDF / HTML
RewriteCond %{ENV:FORMAT} rdf
RewriteRule ^([^/]+)/v(\d+)/([a-z][^/]+)/([^/]+)/?$ https://isotc204.org/ontology-its-$1-v$2/$4/its-$1.ttl [R=303,L]
RewriteRule ^([^/]+)/v(\d+)/([a-z][^/]+)/([^/]+)/?$ https://isotc204.org/ontology-its-$1-v$2/$4/properties/$3/ [R=303,L]

# -----------------------------------------------------------------------------
# 4) Item only (no release → latest): {topic}/vN/{item}
# -----------------------------------------------------------------------------

# *SHACL / *Alignment (any Accept) → {Item}.ttl
RewriteCond %{REQUEST_URI} SHACL|Alignment
RewriteRule ^([^/]+)/v(\d+)/([^/]+)/?$ https://isotc204.org/ontology-its-$1-v$2/latest/$3.ttl [R=303,L]

# *Pattern RDF → {Item}.ttl
RewriteCond %{REQUEST_URI} Pattern
RewriteCond %{ENV:FORMAT} rdf
RewriteRule ^([^/]+)/v(\d+)/([^/]+)/?$ https://isotc204.org/ontology-its-$1-v$2/latest/$3.ttl [R=303,L]

# Class / Pattern HTML → class docs
RewriteCond %{ENV:FORMAT} rdf
RewriteRule ^([^/]+)/v(\d+)/([A-Z][^/]+)/?$ https://isotc204.org/ontology-its-$1-v$2/latest/its-$1.ttl [R=303,L]
RewriteRule ^([^/]+)/v(\d+)/([A-Z][^/]+)/?$ https://isotc204.org/ontology-its-$1-v$2/latest/classes/$3/ [R=303,L]

# Property RDF / HTML
RewriteCond %{ENV:FORMAT} rdf
RewriteRule ^([^/]+)/v(\d+)/([a-z][^/]+)/?$ https://isotc204.org/ontology-its-$1-v$2/latest/its-$1.ttl [R=303,L]
RewriteRule ^([^/]+)/v(\d+)/([a-z][^/]+)/?$ https://isotc204.org/ontology-its-$1-v$2/latest/properties/$3/ [R=303,L]

# -----------------------------------------------------------------------------
# 5) Topic + major version only: {topic}/vN
# -----------------------------------------------------------------------------
RewriteCond %{ENV:FORMAT} rdf
RewriteRule ^([^/]+)/v(\d+)/?$ https://isotc204.org/ontology-its-$1-v$2/latest/its-$1.ttl [R=303,L]
RewriteRule ^([^/]+)/v(\d+)/?$ https://isotc204.org/ontology-its-$1-v$2/latest/ [R=303,L]

# -----------------------------------------------------------------------------
# 6) Fallback
# -----------------------------------------------------------------------------
RewriteRule ^ https://isotc204.org/ritso/ [R=303,L]
