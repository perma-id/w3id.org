# https://w3id.org/itsdata/xxx/v# redirects to https://isotc204.org/ontology-its-xxx-v#/latest/ where xxx is the topic area
#
# ## Contact
# This space is administered by:
# ISO/TC 204 WG 1 Convenor
# Kenneth Vaughn
# kvaughn@trevilon.com
# GitHub username: k-vaughn

RewriteEngine On
Options -MultiViews

# Set FORMAT based on Accept header for HTML formats
RewriteCond %{HTTP_ACCEPT} text/html
RewriteRule ^ - [E=FORMAT:html]

# Default to RDF (TTL) if no Accept header (common for some tools; safer than HTML default for ontologies)
RewriteCond %{ENV:FORMAT} ^$
RewriteRule ^ - [E=FORMAT:rdf]


# -----------------------------------------------------------------------------
# URL patterns for ITS ontology topic areas
#
# Conventions:
# - 1st segment: topic area (e.g., "regulation")
# - 2nd segment: major version (e.g., "v2")
# - 3rd segment: component (e.g., class, property, module name)
# - 4th segment: release pointer (e.g., "latest", "r3.0", "2026-07-15_12-34-56")
# - e.g. {w3id-base-url}/{topic}/{vN}/{class | property | module}/{release}/ = https://w3id.org/itsdata/regulation/v2/RegulationPattern/latest/
# - 3rd and 4th segments are optional
#
# Content negotiation: Return is based on the Accept header (Accept → FORMAT=rdf|html):
# - 3rd and 4th segments not present: {w3id-base-url}/{topic}/{vN}/ returns root page
#     RDF → {base-url}/ontology-its-{topic}-{vN}/latest/its-{topic}.ttl
#     HTML → {base-url}/ontology-its-{topic}-{vN}/latest/       (i.e., index.html)
# - 4th segment not present: {w3id-base-url}/{topic}/{vN}/{class | property | module}/ returns component page
#   - Always assumes "latest" release pointer ({base-url}/ontology-its-{topic}-{vN}/latest/...)
#   - Specific ttl file (i.e., ends with .ttl)
#       any → .../{filename.ttl}
#   - SHACL modules (i.e., ends in "SHACL")
#       any → .../{shacl-in-kebab-case}.ttl  (e.g., regulation-shacl.ttl; there is no HTML docs page)
#   - Pattern modules (i.e., ends in "Pattern")
#       HTML → .../classes/{PatternInUpperCamelCase}/
#       RDF  → .../{pattern-in-kebab-case}.ttl
#   - Classes (i.e., UpperCamelCase like LegalBasis):
#       HTML → .../classes/{ClassInUpperCamelCase}/
#       RDF  → .../its-{topic}.ttl
#   - Properties (i.e., lowerCamelCase like colour):
#       HTML → .../properties/{propertyNameInLowerCamelCase}/
#       RDF  → .../its-{topic}.ttl
# - All four segments present: {w3id-base-url}/{topic}/{vN}/{class | property | module}/{release}/ returns component page for release
#   - Same as above, but "latest" is replaced with the release pointer (4th segment)
#
# Release Pointer can be anything but should be in one of the following formats:
# - Explicit revision tag (semantic versioning minus the major version): r{int}.{int}[optional-text] (e.g., r3.0, r3.0-alpha)
# - "latest": latest revision pointer for indicated major version
# - Mike timestamp: YYYY-MM-DD_hh-mm-ss
#
# Notes:
# - Rules are ordered from most-specific to least-specific.
# - Aborted rewrites fall through to the Registry for ITS Ontologies home page.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# 1) Explicit .ttl files
# -----------------------------------------------------------------------------
RewriteRule ^([^/]+)/v(\d+)/([^/]+\.ttl)/([^/]+)/?$ https://isotc204.org/ontology-its-$1-v$2/$4/$3 [R=303,L]
RewriteRule ^([^/]+)/v(\d+)/([^/]+\.ttl)/?$     https://isotc204.org/ontology-its-$1-v$2/latest/$3 [R=303,L]

# -----------------------------------------------------------------------------
# 2) Component (+ optional release) → PHP
# -----------------------------------------------------------------------------
RewriteRule ^([^/]+)/v(\d+)/([^/]+)/([^/]+)/?$ handler.php?topic=$1&version=$2&component=$3&release=$4 [L,QSA]
RewriteRule ^([^/]+)/v(\d+)/([^/]+)/?$       handler.php?topic=$1&version=$2&component=$3 [L,QSA]

# -----------------------------------------------------------------------------
# 3) Topic + major version only
# -----------------------------------------------------------------------------
RewriteCond %{ENV:FORMAT} rdf
RewriteRule ^([^/]+)/v(\d+)/?$ https://isotc204.org/ontology-its-$1-v$2/latest/its-$1.ttl [R=303,L]
RewriteRule ^([^/]+)/v(\d+)/?$ https://isotc204.org/ontology-its-$1-v$2/latest/ [R=303,L]

# -----------------------------------------------------------------------------
# 4) Fallback
# -----------------------------------------------------------------------------
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

RewriteRule ^ https://isotc204.org/ritso/ [R=303,L]
