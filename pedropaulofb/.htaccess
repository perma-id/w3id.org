# =============================================================================
# Permanent identifiers for Pedro Paulo Favato Barcelos
# =============================================================================
#
# Maintainer: https://github.com/pedropaulofb
# Base URI:   https://w3id.org/pedropaulofb
#
# =============================================================================

RewriteEngine On
Options -MultiViews

# -----------------------------------------------------------------------------
# Landing page
# -----------------------------------------------------------------------------
# https://w3id.org/pedropaulofb
RewriteRule ^$ https://pedropaulofb.github.io/ [R=302,L]

# -----------------------------------------------------------------------------
# Profile redirects
# -----------------------------------------------------------------------------
# https://w3id.org/pedropaulofb/linkedin
RewriteRule ^linkedin/?$ https://www.linkedin.com/in/pedro-paulo-favato-barcelos/ [R=302,L]

# https://w3id.org/pedropaulofb/scholar
RewriteRule ^scholar/?$ https://scholar.google.com/citations?user=1kF9FGwAAAAJ [R=302,L]

# https://w3id.org/pedropaulofb/orcid
RewriteRule ^orcid/?$ https://orcid.org/0000-0003-2736-7817 [R=302,L]

# https://w3id.org/pedropaulofb/github
RewriteRule ^github/?$ https://github.com/pedropaulofb/ [R=302,L]

# -----------------------------------------------------------------------------
# Contact redirects
# -----------------------------------------------------------------------------
# https://w3id.org/pedropaulofb/email
RewriteRule ^email/?$ mailto:pedropaulofb@gmail.com [R=302,L]

# -----------------------------------------------------------------------------
# Resource redirects
# -----------------------------------------------------------------------------
# https://w3id.org/pedropaulofb/ao2025data
RewriteRule ^ao2025data/?$ https://github.com/pedropaulofb/ao2025data/ [R=302,L]
