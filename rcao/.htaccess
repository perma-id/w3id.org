Header set Access-Control-Allow-Origin *
Options +FollowSymLinks
Options -MultiViews

# AddType application/rdf+xml .rdf
# AddType application/rdf+xml .owl
# AddType text/turtle .ttl
# AddType application/n-triples .n3
# AddType application/ld+json .json

RewriteEngine on

# HTML documentation
RewriteCond %{HTTP_ACCEPT} text/html
RewriteRule ^$ https://vicomtech.github.io/rcao/versions/latest/index-en.html [R=303,L]

RewriteRule ^rcao\.ttl$ https://raw.githubusercontent.com/Vicomtech/rcao/refs/heads/main/versions/latest/rcao.ttl [R=303,L]
RewriteRule ^rcao\.jsonld$ https://raw.githubusercontent.com/Vicomtech/rcao/refs/heads/main/versions/latest/rcao.jsonld [R=303,L]
RewriteRule ^rcao\.owl$ https://raw.githubusercontent.com/Vicomtech/rcao/refs/heads/main/versions/latest/rcao.owl [R=303,L]
RewriteRule ^rcao\.nt$ https://raw.githubusercontent.com/Vicomtech/rcao/refs/heads/main/versions/latest/rcao.nt [R=303,L]

RewriteRule ^ontology$ https://raw.githubusercontent.com/Vicomtech/rcao/refs/heads/main/versions/latest/rcao.ttl [R=303,L]
RewriteRule ^github$ https://github.com/vicomtech/rcao [R=303,L]
RewriteRule ^docs$ https://vicomtech.github.io/rcao/versions/latest/index-en.html [R=303,L]
RewriteRule ^docs/ontospy$ https://vicomtech.github.io/rcao/docs/ontospy/html-multi-page/index.html [R=303,L]

# Redirect for versioned Turtle files
RewriteRule ^rcao-([0-9]+\.[0-9]+\.[0-9]+)\.ttl$ https://raw.githubusercontent.com/Vicomtech/rcao/refs/heads/main/versions/rcao-$1.ttl [R=303,L]

# redirects for HTML documentation of classes and properties
RewriteRule ^([A-Z]+(.*))$ https://vicomtech.github.io/rcao/versions/latest/rcao$1.html [R=303,L]
RewriteRule ^([a-z]+(.*))$ https://vicomtech.github.io/rcao/versions/latest/rcao$1.html [R=303,L]

# Redirects for Turtle files
RewriteCond %{HTTP_ACCEPT} text/turtle [OR]
RewriteCond %{HTTP_ACCEPT} text/ttl [OR]
RewriteCond %{HTTP_ACCEPT} application/turtle [OR]
RewriteCond %{HTTP_ACCEPT} application/x-turtle
RewriteRule ^$ https://raw.githubusercontent.com/Vicomtech/rcao/refs/heads/main/versions/latest/rcao.ttl [R=303,L]
RewriteRule ^rcao\.ttl$ https://raw.githubusercontent.com/Vicomtech/rcao/refs/heads/main/versions/latest/rcao.ttl [R=303,L]


# Rewrite rule to serve other formats from the vocabulary URI if requested
RewriteCond %{HTTP_ACCEPT} application/ld\+json
RewriteRule ^$ https://raw.githubusercontent.com/Vicomtech/rcao/refs/heads/main/versions/latest/rcao.jsonld [R=303,L]

RewriteCond %{HTTP_ACCEPT} application/n-triples
RewriteRule ^$ https://raw.githubusercontent.com/Vicomtech/rcao/refs/heads/main/versions/latest/rcao.nt [R=303,L]

# Rewrite rule to serve RDF/XML content from the vocabulary URI if requested
RewriteCond %{HTTP_ACCEPT} \*/\* [OR]
RewriteCond %{HTTP_ACCEPT} application/rdf\+xml
RewriteRule ^$ https://raw.githubusercontent.com/Vicomtech/rcao/refs/heads/main/versions/latest/rcao.owl [R=303,L]


# Default response
# ---------------------------
# Rewrite rule to serve the TTL content from the vocabulary URI by default
RewriteCond %{HTTP_ACCEPT} .+
RewriteRule ^$ https://raw.githubusercontent.com/Vicomtech/rcao/refs/heads/main/versions/latest/rcao.ttl [R=303,L]