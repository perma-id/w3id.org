RewriteEngine On

# 1) Base namespace -> GitHub Pages homepage
RewriteRule ^$ https://ecrum19.github.io/vord/ [R=302,L]

# 2) Vocab (human) -> homepage (or a specific docs page)
RewriteRule ^vocab$ https://ecrum19.github.io/vord/ [R=302,L]

# 3) Direct file redirects (machine)
RewriteRule ^vocab\.ttl$ https://raw.githubusercontent.com/ecrum19/vord/main/vocab/vord.ttl [R=302,L]
RewriteRule ^shacl\.ttl$ https://raw.githubusercontent.com/ecrum19/vord/main/shapes/vord.shacl.ttl [R=302,L]
