Header set Access-Control-Allow-Origin *
Options +FollowSymLinks
RewriteEngine on

# Redirect all requests to the IMO GitLab Pages site
RewriteRule ^imo/?$ https://isye.gitlab.io/mks/imo/ [R=302,L]
RewriteRule ^imo/(.*)$ https://isye.gitlab.io/mks/imo/$1 [R=302,L]

# Redirect all other requests to the main ISyE site
RewriteRule ^(.*)$ https://isye.be/$1 [R=302,L]
