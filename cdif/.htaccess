RewriteRule ^manifest/1\.0/?$ %{ENV:BB_BASE}/build/annotated/bbr/metadata/cdifProperties/cdifArchiveDistribution/schema.json [R=303,L]
RewriteCond %{HTTP_ACCEPT} application/yaml
RewriteRule ^manifest/1\.0/?$ %{ENV:BB_BASE}/build/annotated/bbr/metadata/cdifProperties/cdifArchiveDistribution/schema.yaml [R=303,L]
RewriteCond %{HTTP_ACCEPT} text/turtle
RewriteRule ^manifest/1\.0/?$ %{ENV:BB_BASE}/_sources/cdifProperties/cdifArchiveDistribution/rules.shacl [R=303,L]
RewriteCond %{HTTP_ACCEPT} application/ld\+json
RewriteRule ^manifest/1\.0/?$ %{ENV:BB_BASE}/build/annotated/bbr/metadata/cdifProperties/cdifArchiveDistribution/context.jsonld [R=303,L]
RewriteCond %{HTTP_ACCEPT} application/json
RewriteRule ^manifest/1\.0/?$ %{ENV:BB_BASE}/build/generateddocs/json-full/bbr/metadata/cdifProperties/cdifArchiveDistribution/index.json [R=303,L]
RewriteRule ^manifest/1\.0/?$ %{ENV:BB_BASE}/bblock/cdif.bbr.metadata.cdifProperties.cdifArchiveDistribution [R=303,L]

# --- provenance/1.0 → cdifProvenance ---
