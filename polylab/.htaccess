############################## Rules for Full Versions ##############################

# Rewrite rule to serve HTML
RewriteCond %{HTTP_ACCEPT} !application/rdf\+xml.*(text/html|application/xhtml\+xml)
RewriteCond %{HTTP_ACCEPT} \*/\* [OR]
RewriteCond %{HTTP_ACCEPT} text/html [OR]
RewriteCond %{HTTP_ACCEPT} application/xhtml\+xml [OR]
RewriteCond %{HTTP_USER_AGENT} ^Mozilla/.*
RewriteRule ^$ https://dlr-dw.gitlab.io/poly-ontologies/polylab-ontology/index.html [R=303,L]

# Rewrite rule to serve JSON-LD
RewriteCond %{HTTP_ACCEPT} application/ld\+json
RewriteRule ^$ https://dlr-dw.gitlab.io/poly-ontologies/polylab-ontology/ontology.jsonld [R=303,L]

# Rewrite rule to serve RDF/XML
RewriteCond %{HTTP_ACCEPT} application/rdf\+xml
RewriteRule ^$ https://dlr-dw.gitlab.io/poly-ontologies/polylab-ontology/ontology.owl [R=303,L]

# Rewrite rule to serve N-Triples
RewriteCond %{HTTP_ACCEPT} application/n-triples
RewriteRule ^$ https://dlr-dw.gitlab.io/poly-ontologies/polylab-ontology/ontology.nt [R=303,L]

# Rewrite rule to serve TTL
RewriteCond %{HTTP_ACCEPT} text/turtle [OR]
RewriteCond %{HTTP_ACCEPT} text/\* [OR]
RewriteCond %{HTTP_ACCEPT} \*/turtle
RewriteRule ^$ https://dlr-dw.gitlab.io/poly-ontologies/polylab-ontology/ontology.ttl [R=303,L]


# Default response
# ---------------------------
# default response is the documentation page
RewriteRule ^$ https://dlr-dw.gitlab.io/poly-ontologies/polylab-ontology/ [R=303,L]
