# ## Contact
# This space is administered by: @Natclinn


RewriteEngine on

# Base redirect to the AgroPortal landing page
RewriteRule ^$ https://agroportal.lirmm.fr/ontologies/NCL [R=302,L]

# Redirect specific entities to their AgroPortal page (e.g., classes or terms)
RewriteCond %{REQUEST_URI} ^.*afy.*$
RewriteRule ^([^/]+)/?$ https://agroportal.lirmm.fr/ontologies/NCL/$1 [R=302,L]