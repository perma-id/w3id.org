RewriteEngine On

# /fairagro/odrl -> FAIRagro GitHub Repository for ODRL Policies
RewriteRule ^odrl/?$ https://github.com/fairagro/odrl_policies [R=302,L]

# Individual ODRL files
RewriteRule ^odrl/(.*)$ https://raw.githubusercontent.com/fairagro/odrl_policies/main/policies/$1 [R=302,L]

# /fairagro -> FAIRagro GitHub Repository
RewriteRule ^$ https://github.com/fairagro [R=302,L]
