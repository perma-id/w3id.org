# =============================================================================
# w3id.org/ixo  —  redirect configuration for the IXO namespace
#
# Canonical content host : https://ixofoundation.github.io/ns/
# Canonical IRI form     : https://w3id.org/ixo/<path>      (NO "ns/" prefix)
#
# Policy:
#   * Namespace IRIs use 303 See Other — they identify abstract resources
#     (contexts, classes, properties, SKOS concepts), which 303-redirect to the
#     documents that describe them.
#   * The legacy "ns/"-prefixed variant (w3id.org/ixo/ns/<path>) is collapsed to
#     the canonical bare form with a single 301.
#   * Every rule targets a concrete file (…/index.jsonld or …/<name>.json),
#     never a bare directory (which would land on a GitHub Pages listing / 404).
#   * Trailing slashes are tolerated on every namespace path.
# =============================================================================

# --- CORS ---------------------------------------------------------------------
Header set Access-Control-Allow-Origin "*"
Header set Access-Control-Allow-Headers "DNT,Keep-Alive,User-Agent,X-Requested-With,If-Modified-Since,Cache-Control,Content-Type,Accept"
Options +FollowSymLinks

# --- Media types --------------------------------------------------------------
# NB: w3id.org only *redirects*; the authoritative Content-Type is set by the
# content host, which already serves .jsonld as application/ld+json (verified
# against ixofoundation.github.io/ns). The directive below is therefore
# documentary — it only takes effect if a variant of this config serves files
# directly. JSON Schema (.json) is served as application/json; the more specific
# application/schema+json is an optional content-host refinement. See readme.md.
AddType application/ld+json .jsonld

RewriteEngine On

# --- 0. did:ixo method context (interchain-identifiers) ------------------------
# The IID JSON-LD context that defines the did:ixo method-specific terms
# (linkedResource, linkedClaim, linkedEntity, accordedRight, blockchainAccountID,
# CosmosAccountAddress). Published WITH the "ns/" segment by request, so this
# explicit 303 must precede the rule-1 "ns/" collapse below — otherwise the IRI
# would be 301'd to the bare form before it could resolve to a document.
# Registered in the DID Specification Registries; appended to the @context array
# of every resolved did:ixo document (W3C DID Core §6.3.1 JSON-LD production).
RewriteRule ^ns/interchain-identifiers(?:/v1)?/?$ https://ixofoundation.github.io/ns/interchain-identifiers/v1/index.jsonld [R=303,L]

# --- 1. Legacy "ns/" prefix  →  canonical bare form (single 301) --------------
RewriteRule ^ns/(.*)$ https://w3id.org/ixo/$1 [R=301,L]

# --- 1b. Content negotiation — browsers get HTML docs, machines get JSON-LD ---
# A request whose Accept header includes text/html (a browser) is 303-redirected
# to the human-readable documentation page (docs/index.html, generated by
# scripts/build-docs.mjs). Machine clients (application/ld+json, application/json,
# or */*) do NOT match and fall through to the document rules below. An explicit
# .json / .jsonld request always returns the raw document, even from a browser.
RewriteCond %{HTTP_ACCEPT} text/html [NC]
RewriteCond %{REQUEST_URI} !\.(json|jsonld)$ [NC]
RewriteRule ^(vocab|protocol)(/|$) https://ixofoundation.github.io/ns/docs/ [R=303,L]
RewriteCond %{HTTP_ACCEPT} text/html [NC]
RewriteRule ^/?$ https://ixofoundation.github.io/ns/docs/ [R=303,L]

# --- 2. Umbrella context ------------------------------------------------------
#   context | context/v1 | context/v1/   ->   context/v1/index.jsonld
RewriteRule ^context(?:/v1)?/?$ https://ixofoundation.github.io/ns/context/v1/index.jsonld [R=303,L]

# --- 2b. Claim context --------------------------------------------------------
#   claimcontext | claimcontext/v1 | claimcontext/v1/  ->  claimcontext/v1/index.jsonld
#   The minimal @protected context bundled into claims (id/type/claim/vocab/
#   emerging/ecs/schema/attribute/protocol/supamoto/review/minisass/…). Needs an
#   explicit rule so claims that reference it by URL dereference to a document.
RewriteRule ^claimcontext(?:/v1)?/?$ https://ixofoundation.github.io/ns/claimcontext/v1/index.jsonld [R=303,L]

# --- 3. Core vocabulary + country codes ---------------------------------------
#   vocab/v1 -> vocab/v1/index.jsonld ;  vocab/v1/countries -> vocab/v1/countries.jsonld
#   (JSON-LD docs use .jsonld so GitHub Pages serves them as application/ld+json.)
RewriteRule ^vocab/v1/?$ https://ixofoundation.github.io/ns/vocab/v1/index.jsonld [R=303,L]
RewriteRule ^vocab/v1/countries/?$ https://ixofoundation.github.io/ns/vocab/v1/countries.jsonld [R=303,L]
# back-compat: legacy explicit .json links -> .jsonld
RewriteRule ^vocab/v1/index\.json$ https://ixofoundation.github.io/ns/vocab/v1/index.jsonld [R=301,L]
RewriteRule ^vocab/v1/countries\.json$ https://ixofoundation.github.io/ns/vocab/v1/countries.jsonld [R=301,L]

# --- 3b. Attribute dictionary -------------------------------------------------
#   attributes | attributes/v1 | attributes/v1/<term>  ->  attributes/v1/index.jsonld
#   The `attribute:` prefix (https://w3id.org/ixo/attributes/v1/) is path-based,
#   so individual term IRIs (…/attributes/v1/<term>) dereference to the dictionary
#   that describes them. Replaces the original singular `attribute/schema` mapping.
RewriteRule ^attributes(/.*)?$ https://ixofoundation.github.io/ns/attributes/v1/index.jsonld [R=303,L]

# --- 4a. Attribute namespace (schema.org context — .jsonld) -------------------
# protocol/attributes/v1 holds the schema.org JSON-LD context (schema.jsonld), NOT
# a SKOS index — so it precedes the generic protocol rule below.
RewriteRule ^protocol/attributes/v1/?$ https://ixofoundation.github.io/ns/protocol/attributes/v1/schema.jsonld [R=303,L]

# --- 4. Protocol schemes ------------------------------------------------------
# protocol/ now mixes two file types:
#   * plain-JSON survey-data / namespace stubs (no @context) -> index.json
#     (Studio survey-choices API reads these by path; see scope-13-protocol-schemes.md)
#   * SKOS concept schemes (JSON-LD) -> index.jsonld
# Remaining plain-JSON survey-data files (Studio reads by path). The empty stubs
# (tokens/identifiers/indicators/proofs) were removed and `methods` converted to a
# JSON-LD SKOS scheme — both now covered by the generic .jsonld rule below.
RewriteRule ^protocol/(blockchain-account|metric|tags|services)/v1/?$ https://ixofoundation.github.io/ns/protocol/$1/v1/index.json [R=303,L]
RewriteRule ^protocol/(.+)/v1/?$ https://ixofoundation.github.io/ns/protocol/$1/v1/index.jsonld [R=303,L]

# --- 4b. Capability concept schemes (zcap, …) ---------------------------------
#   capability/<thing>/v1  ->  capability/<thing>/v1/index.jsonld  (JSON-LD SKOS)
RewriteRule ^capability/(.+)/v1/?$ https://ixofoundation.github.io/ns/capability/$1/v1/index.jsonld [R=303,L]

# --- 5. JSON Schemas  (schema/v1/<name>) --------------------------------------
#   schema/v1/<name> | schema/v1/<name>.json   ->   schema/v1/<name>.json
RewriteRule ^schema/v1/([^/]+?)(?:\.json)?/?$ https://ixofoundation.github.io/ns/schema/v1/$1.json [R=303,L]

# --- 6. SHACL shapes  (schema/shapes/v1/<name>) -------------------------------
#   schema/shapes/v1/<name> | …<name>.jsonld   ->   schema/shapes/v1/<name>.jsonld
RewriteRule ^schema/shapes/v1/([^/]+?)(?:\.jsonld)?/?$ https://ixofoundation.github.io/ns/schema/shapes/v1/$1.jsonld [R=303,L]

# --- 7. Templates  (templates/v1/<name>)  — content lands in Phase 6 ----------
#   templates/v1/<name> | templates/v1/<name>.jsonld -> templates/v1/<name>.jsonld
RewriteRule ^templates/v1/([^/]+?)(?:\.jsonld)?/?$ https://ixofoundation.github.io/ns/templates/v1/$1.jsonld [R=303,L]

# --- 8. Catch-all  →  GitHub Pages /ns/ tree ----------------------------------
# Preserves the path under /ns/ (the prior config dropped the /ns/ prefix and
# landed on the wrong host root). Direct file paths (…/index.jsonld) and repo
# assets (LICENSE, README.md) resolve through here.
RewriteRule ^(.*)$ https://ixofoundation.github.io/ns/$1 [R=303,L]
