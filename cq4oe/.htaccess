# Turn off MultiViews
Options -MultiViews

RewriteEngine On

RewriteRule ^$ https://github.com/oeg-upm/cq4oe-benchmark [R=301,L]

RewriteRule ^metrics$ https://oeg-upm.github.io/cq4oe-benchmark/OntoCatalogue/html/catalog.html [R=302,L]
RewriteRule ^leaderboard$ https://oeg-upm.github.io/cq4oe-benchmark/leaderboard/leaderboard.html#cq2onto/term_recovery [R=302,L]
