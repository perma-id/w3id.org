# Turn off MultiViews
Options -MultiViews

# Basic redirect to the project pages
RewriteEngine On
RewriteRule ^$ https://oeg-upm.github.io/cq4oe-benchmark/OntoCatalogue/html/catalog.html [R=301,NE,L]

# redirects for metrics

RewriteCond %{HTTP_ACCEPT} text/turtle [OR]
RewriteCond %{HTTP_ACCEPT} text/\* [OR]
RewriteCond %{HTTP_ACCEPT} \*/turtle
RewriteRule ^(.+)$ https://github.com/oeg-upm/cq4oe-benchmark/blob/main/OntoCatalogue/KG/$1.ttl [R=303,L]

RewriteCond %{HTTP_ACCEPT} !application/rdf\+xml.*(text/html|application/xhtml\+xml)
RewriteCond %{HTTP_ACCEPT} text/html [OR]
RewriteCond %{HTTP_ACCEPT} application/xhtml\+xml [OR]
RewriteCond %{HTTP_USER_AGENT} ^Mozilla/.*
RewriteRule ^(.+)$ https://oeg-upm.github.io/cq4oe-benchmark/OntoCatalogue/html/$1.html [R=303,L]

