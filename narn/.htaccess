Options +FollowSymLinks
RewriteEngine on

RewriteCond %{HTTP:Accept} (application/rdf\+xml|text/turtle|application/x-turtle) [NC]
RewriteRule ^action/(.*)$ https://raw.githubusercontent.com/erdemonal/formal-model-of-story-plots/master/modules/actions.ttl [R=303,L]
RewriteRule ^action/(.*)$ https://erdemonal.github.io/formal-model-of-story-plots/OnToology/modules/actions.ttl/documentation/doc/index-en.html [R=303,L]

