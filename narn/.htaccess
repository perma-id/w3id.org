Options +FollowSymLinks
RewriteEngine on

RewriteRule ^action/(.*)$ https://erdemonal.github.io/formal-model-of-story-plots/OnToology/modules/actions.ttl/documentation/doc/index-en.html [R=303,L]

RewriteRule ^event/(.*)$ https://erdemonal.github.io/formal-model-of-story-plots/OnToology/modules/event.ttl/documentation/doc/index-en.html [R=303,L]

RewriteRule ^location/(.*)$ https://erdemonal.github.io/formal-model-of-story-plots/OnToology/modules/place.ttl/documentation/doc/index-en.html [R=303,L]

RewriteRule ^plot/(.*)$ https://erdemonal.github.io/formal-model-of-story-plots/OnToology/modules/plot.ttl/documentation/doc/index-en.html [R=303,L]

RewriteRule ^rcc/(.*)$ https://erdemonal.github.io/formal-model-of-story-plots/OnToology/modules/rcc.ttl/documentation/doc/index-en.html [R=303,L]

RewriteRule ^social/(.*)$ https://erdemonal.github.io/formal-model-of-story-plots/OnToology/modules/social.ttl/documentation/doc/index-en.html [R=303,L]

RewriteRule ^to/(.*)$ https://erdemonal.github.io/formal-model-of-story-plots/OnToology/modules/time.ttl/documentation/doc/index-en.html [R=303,L]

RewriteRule ^$ https://erdemonal.github.io/formal-model-of-story-plots/OnToology/narn-unified.ttl/documentation/doc/index-en.html [R=303,L]