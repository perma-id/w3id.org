Options +FollowSymLinks
RewriteEngine on

# Web interface
RewriteRule ^/?$ https://expo.eng.unibz.it

# Plugin request
RewriteRule ^plugin/?$ https://github.com/mozzherina/ontouml-vp-plugin/tree/features/abstraction

# Redirect API request
RewriteRule ^expose/(.+)/?$ https://expose.eng.unibz.it/$1

# GitHub folders
# Main GitHub project
RewriteRule ^github/?$ https://github.com/mozzherina/ExpO-Project
# CAiSE25 submission
RewriteRule ^github/CAiSE25 https://github.com/mozzherina/ExpO-Project/tree/main/CAiSE25
# Weakening check and related files
RewriteRule ^github/weakening https://github.com/mozzherina/ExpO-Project/tree/main/Weakening
