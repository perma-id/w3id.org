# did:cel Context
#
# homepage:
#   https://w3c-ccg.github.io/did-cel-spec/
# maintainers:
#   @msporny
#   @dlongley
#   @davidlehn
#
Header set Access-Control-Allow-Origin *
Header set Access-Control-Allow-Headers DNT,X-Mx-ReqToken,Keep-Alive,User-Agent,X-Requested-With,If-Modified$
Options +FollowSymLinks
RewriteEngine on
RewriteRule ^$ https://w3c-ccg.github.io/did-cel-spec/ [R=302,L]
RewriteRule ^v1rc1$ https://w3c-ccg.github.io/did-cel-spec/contexts/v1rc1.jsonld [R=302,L]
