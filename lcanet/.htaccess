# Maintainer: Fatima Danash (GitHub: DanashFatima)
# Project: LCAnet ontology

Options +FollowSymLinks
RewriteEngine On

# Root (homepage)
RewriteRule ^$ https://danashfatima.github.io/lcanet/index.html [R=302,L]

# Core module
RewriteRule ^core$ https://danashfatima.github.io/lcanet/core/index-en.html [R=302,L]

# Activity module
RewriteRule ^activity$ https://danashfatima.github.io/lcanet/activity/index-en.html [R=302,L]

# Actor module
RewriteRule ^actor$ https://danashfatima.github.io/lcanet/actor/index-en.html [R=302,L]

# Impact Assessment module
RewriteRule ^ia$ https://danashfatima.github.io/lcanet/ia/index-en.html [R=302,L]

# Property module
RewriteRule ^property$ https://danashfatima.github.io/lcanet/property/index-en.html [R=302,L]

# Spatiotemporal module
RewriteRule ^st$ https://danashfatima.github.io/lcanet/st/index-en.html [R=302,L]

# IC Knowledge Graph
RewriteRule ^ICdata$ https://danashfatima.github.io/lcanet/ICdata/index-en.html [R=302,L]
