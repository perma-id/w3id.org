# Defines the redirect for https://w3id.org/oco
#
# OCO — Ontology for Ceramics
# Maintainer: Wolfgang Grond (Numberland), grond@numberland.com
#
# Note: 302 (temporary) is used on purpose while the target domain may still
# change. Switch to R=301 once the destination is final, since 301 gets cached
# aggressively by browsers and tooling.

Options +FollowSymLinks
RewriteEngine on

# Send w3id.org/oco and every sub-path to the OntoCrafter landing page.
RewriteRule ^(.*)$ https://www.ontocrafter.eu/ [R=302,L]
