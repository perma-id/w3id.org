RewriteEngine On

RewriteRule ^$ https://www.epsilon-italia.it [R=302,L]
RewriteRule ^go-peg/go-depth/metadata$ https://data.europa.eu/api/hub/repo/datasets/ispra_rm-ge_3dmod_pobasin_dt.rdf?useNormalizedId=true&locale=en [R=302,L,QSA]
RewriteRule ^go-peg/go-depth$ https://data.europa.eu/data/datasets/ispra_rm-ge_3dmod_pobasin_dt?locale=en [R=302,L,QSA]

# 1. geoIACS Vocabulary
RewriteRule ^geoIACS/([^/]+)/([^/]+)/?$ https://showvoc.semantic.epsilon-italia.it/showvoc/#/datasets/$1/data?resId=https:%2F%2Fw3id.org%2Fepsilonitalia%2FgeoIACS%2F$1%2F$2 [R=302,L,NE]
RewriteRule ^geoIACS/([^/]+)/?$ https://showvoc.semantic.epsilon-italia.it/showvoc/#/datasets/$1/data [R=302,L,NE]
