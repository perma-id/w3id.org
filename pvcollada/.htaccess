# This namespace is maintained by the Universy of Central Florida
# Current maintainers are:
# Brent Thompson (https://github.com/TheAlgoDev) – UCF, CWRU, PSEL
# Contact Info: brent.thompson@ucf.edu

Options +FollowSymLinks
RewriteEngine on

# ── Content negotiation: RDF clients get raw Turtle ───────────────────────────
RewriteCond %{HTTP_ACCEPT} text/turtle [OR]
RewriteCond %{HTTP_ACCEPT} application/rdf\+xml [OR]
RewriteCond %{HTTP_ACCEPT} application/n-triples [OR]
RewriteCond %{HTTP_ACCEPT} application/ld\+json
RewriteRule ^(.*)$ https://raw.githubusercontent.com/TheAlgoDev/pvcollada-onto/main/ontology/pvcollada_onto.ttl [R=303,L]

# ── WebVOWL visualization ──────────────────────────────────────────────────────
RewriteRule ^webvowl/?$ https://thealgodev.github.io/pvcollada-onto/webvowl/index.html [R=303,L]

# ── OOPS! pitfall evaluation ───────────────────────────────────────────────────
RewriteRule ^oops/?$ https://thealgodev.github.io/pvcollada-onto/OOPSevaluation/oopsEval.html [R=303,L]

# ── Provenance ─────────────────────────────────────────────────────────────────
RewriteRule ^provenance/?$ https://thealgodev.github.io/pvcollada-onto/provenance/provenance-en.html [R=303,L]

# ── Named class/property terms: /ClassName → docs fragment ────────────────────
RewriteRule ^([A-Za-z][a-zA-Z0-9_-]+)$ https://thealgodev.github.io/pvcollada-onto/#$1 [R=303,L]

# ── Default: documentation root ───────────────────────────────────────────────
RewriteRule ^(.*)$ https://thealgodev.github.io/pvcollada-onto/ [R=303,L]

# Contact Info : Brent Thompson - brent.thompson@ucf.edu
