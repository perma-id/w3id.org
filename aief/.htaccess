Options -MultiViews
Require all granted

RewriteEngine on

# Redirect ontology IRI to raw TTL file on GitHub
RewriteRule ^$ https://raw.githubusercontent.com/navinaamuthan/w3id.org-ai-ethics-framework/main/aief/ai-ethics-final.ttl [R=303,L]

# Redirect any sub-path
RewriteRule ^(.*)$ https://raw.githubusercontent.com/navinaamuthan/w3id.org-ai-ethics-framework/main/aief/$1 [R=303,L]
