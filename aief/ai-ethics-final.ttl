:R007 rdf:type :Obligation ;
    :requirementID "R007" ;
    :requirementText "All non-Trinity collaborators must be listed with role, name, affiliation, country" ;
    :sectionReference "§2.2.3" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :REAMS ;
    :hasTier :Tier1_Mandatory ;
