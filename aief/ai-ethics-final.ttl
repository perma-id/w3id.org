@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <http://example.org/ai-ethics#> .

<http://example.org/ai-ethics> rdf:type owl:Ontology ;
    rdfs:label "AI-Assisted Ethics Assessment Framework" ;
    rdfs:comment "Ontology for multi-framework AI ethics compliance assessment" .

# ===== TOP-LEVEL CLASSES =====

:Framework rdf:type owl:Class .
:Requirement rdf:type owl:Class .
:Tier rdf:type owl:Class .
:EUCharterRight rdf:type owl:Class .
:Stakeholder rdf:type owl:Class .
:Evidence rdf:type owl:Class .
:RiskCategory rdf:type owl:Class .
:DataCategory rdf:type owl:Class .
:Mitigation rdf:type owl:Class .
:AssessmentProcess rdf:type owl:Class .
:ComplianceStatus rdf:type owl:Class .

# ===== FRAMEWORK SUBCLASSES =====

:REAMS rdf:type owl:Class ; rdfs:subClassOf :Framework ; rdfs:label "TCD REAMS" .
:EUAIAct rdf:type owl:Class ; rdfs:subClassOf :Framework ; rdfs:label "EU AI Act" .
:HorizonEurope rdf:type owl:Class ; rdfs:subClassOf :Framework ; rdfs:label "Horizon Europe" .
:ACMConference rdf:type owl:Class ; rdfs:subClassOf :Framework ; rdfs:label "ACM Conference" .
:ACLRollingReview rdf:type owl:Class ; rdfs:subClassOf :ACMConference ; rdfs:label "ACL Rolling Review" .
:NeurIPS rdf:type owl:Class ; rdfs:subClassOf :ACMConference ; rdfs:label "NeurIPS" .
:FAccT rdf:type owl:Class ; rdfs:subClassOf :ACMConference ; rdfs:label "FAccT" .
:AAAI rdf:type owl:Class ; rdfs:subClassOf :ACMConference ; rdfs:label "AAAI" .

# ===== REQUIREMENT SUBCLASSES =====

:Obligation rdf:type owl:Class ; rdfs:subClassOf :Requirement .
:Prohibition rdf:type owl:Class ; rdfs:subClassOf :Requirement .
:Permission rdf:type owl:Class ; rdfs:subClassOf :Requirement .

# ===== TIER SUBCLASSES =====

:Tier1_Mandatory rdf:type owl:Class ; rdfs:subClassOf :Tier .
:Tier2_Reflective rdf:type owl:Class ; rdfs:subClassOf :Tier .

# ===== EU CHARTER RIGHT HIERARCHY =====

:Title1_Dignity rdf:type owl:Class ; rdfs:subClassOf :EUCharterRight .
:Art1_HumanDignity rdf:type owl:Class ; rdfs:subClassOf :Title1_Dignity .
:Art2_RightToLife rdf:type owl:Class ; rdfs:subClassOf :Title1_Dignity .
:Art3_RightToIntegrity rdf:type owl:Class ; rdfs:subClassOf :Title1_Dignity .
:Art5_ProhibitionOfSlavery rdf:type owl:Class ; rdfs:subClassOf :Title1_Dignity .

:Title2_Freedoms rdf:type owl:Class ; rdfs:subClassOf :EUCharterRight .
:Art6_RightToLiberty rdf:type owl:Class ; rdfs:subClassOf :Title2_Freedoms .
:Art7_PrivateLife rdf:type owl:Class ; rdfs:subClassOf :Title2_Freedoms .
:Art8_DataProtection rdf:type owl:Class ; rdfs:subClassOf :Title2_Freedoms .
:Art10_FreedomOfThought rdf:type owl:Class ; rdfs:subClassOf :Title2_Freedoms .
:Art11_FreedomOfExpression rdf:type owl:Class ; rdfs:subClassOf :Title2_Freedoms .
:Art16_FreedomToConductBusiness rdf:type owl:Class ; rdfs:subClassOf :Title2_Freedoms .

:Title3_Equality rdf:type owl:Class ; rdfs:subClassOf :EUCharterRight .
:Art20_EqualityBeforeLaw rdf:type owl:Class ; rdfs:subClassOf :Title3_Equality .
:Art21_NonDiscrimination rdf:type owl:Class ; rdfs:subClassOf :Title3_Equality .
:Art22_CulturalDiversity rdf:type owl:Class ; rdfs:subClassOf :Title3_Equality .
:Art23_GenderEquality rdf:type owl:Class ; rdfs:subClassOf :Title3_Equality .
:Art24_RightsOfChild rdf:type owl:Class ; rdfs:subClassOf :Title3_Equality .
:Art25_RightsOfElderly rdf:type owl:Class ; rdfs:subClassOf :Title3_Equality .
:Art26_DisabilityIntegration rdf:type owl:Class ; rdfs:subClassOf :Title3_Equality .

:Title4_Solidarity rdf:type owl:Class ; rdfs:subClassOf :EUCharterRight .
:Art31_FairWorkingConditions rdf:type owl:Class ; rdfs:subClassOf :Title4_Solidarity .
:Art35_HealthCare rdf:type owl:Class ; rdfs:subClassOf :Title4_Solidarity .
:Art37_EnvironmentalProtection rdf:type owl:Class ; rdfs:subClassOf :Title4_Solidarity .

:Title5_CitizensRights rdf:type owl:Class ; rdfs:subClassOf :EUCharterRight .
:Art38_ConsumerProtection rdf:type owl:Class ; rdfs:subClassOf :Title5_CitizensRights .
:Art41_GoodAdministration rdf:type owl:Class ; rdfs:subClassOf :Title5_CitizensRights .

:Title6_Justice rdf:type owl:Class ; rdfs:subClassOf :EUCharterRight .
:Art47_RightToEffectiveRemedy rdf:type owl:Class ; rdfs:subClassOf :Title6_Justice .

# ===== STAKEHOLDER SUBCLASSES =====

:Researcher rdf:type owl:Class ; rdfs:subClassOf :Stakeholder .
:Supervisor rdf:type owl:Class ; rdfs:subClassOf :Stakeholder .
:PrincipalInvestigator rdf:type owl:Class ; rdfs:subClassOf :Stakeholder .
:EthicsCommittee rdf:type owl:Class ; rdfs:subClassOf :Stakeholder .
:DataSubject rdf:type owl:Class ; rdfs:subClassOf :Stakeholder .
:Participant rdf:type owl:Class ; rdfs:subClassOf :Stakeholder .
:Annotator rdf:type owl:Class ; rdfs:subClassOf :Stakeholder .
:AIDeployer rdf:type owl:Class ; rdfs:subClassOf :Stakeholder .
:MarketSurveillanceAuthority rdf:type owl:Class ; rdfs:subClassOf :Stakeholder .
:DataProtectionOfficer rdf:type owl:Class ; rdfs:subClassOf :Stakeholder .
:FundingBody rdf:type owl:Class ; rdfs:subClassOf :Stakeholder .

# ===== EVIDENCE SUBCLASSES =====

:Certificate rdf:type owl:Class ; rdfs:subClassOf :Evidence .
:ConsentForm rdf:type owl:Class ; rdfs:subClassOf :Evidence .
:DataProtectionPolicy rdf:type owl:Class ; rdfs:subClassOf :Evidence .
:RiskAssessmentReport rdf:type owl:Class ; rdfs:subClassOf :Evidence .
:BiasAssessmentReport rdf:type owl:Class ; rdfs:subClassOf :Evidence .
:DPIA rdf:type owl:Class ; rdfs:subClassOf :Evidence .
:FRIA rdf:type owl:Class ; rdfs:subClassOf :Evidence .
:ModelCard rdf:type owl:Class ; rdfs:subClassOf :Evidence .
:DataSheet rdf:type owl:Class ; rdfs:subClassOf :Evidence .
:PIL_ParticipantInfoLeaflet rdf:type owl:Class ; rdfs:subClassOf :Evidence .
:EthicsApproval rdf:type owl:Class ; rdfs:subClassOf :Evidence .
:GardaVettingCertificate rdf:type owl:Class ; rdfs:subClassOf :Evidence .
:RecruitmentMaterial rdf:type owl:Class ; rdfs:subClassOf :Evidence .
:DPOLetterOfCompletion rdf:type owl:Class ; rdfs:subClassOf :Evidence .

# ===== RISK CATEGORY SUBCLASSES =====

:PhysicalHarm rdf:type owl:Class ; rdfs:subClassOf :RiskCategory .
:PsychologicalHarm rdf:type owl:Class ; rdfs:subClassOf :RiskCategory .
:FinancialHarm rdf:type owl:Class ; rdfs:subClassOf :RiskCategory .
:ReputationalHarm rdf:type owl:Class ; rdfs:subClassOf :RiskCategory .
:PrivacyBreach rdf:type owl:Class ; rdfs:subClassOf :RiskCategory .
:Discrimination rdf:type owl:Class ; rdfs:subClassOf :RiskCategory .
:EnvironmentalHarm rdf:type owl:Class ; rdfs:subClassOf :RiskCategory .
:DualUseMisuse rdf:type owl:Class ; rdfs:subClassOf :RiskCategory .
:FunctionCreep rdf:type owl:Class ; rdfs:subClassOf :RiskCategory .
:WorkplaceSafetyRisk rdf:type owl:Class ; rdfs:subClassOf :RiskCategory .
:DemocraticProcessHarm rdf:type owl:Class ; rdfs:subClassOf :RiskCategory .
:AddictionRisk rdf:type owl:Class ; rdfs:subClassOf :RiskCategory .

# ===== DATA CATEGORY SUBCLASSES =====

:PersonalData rdf:type owl:Class ; rdfs:subClassOf :DataCategory .
:SpecialCategoryData rdf:type owl:Class ; rdfs:subClassOf :DataCategory .
:PseudonymisedData rdf:type owl:Class ; rdfs:subClassOf :DataCategory .
:AnonymisedData rdf:type owl:Class ; rdfs:subClassOf :DataCategory .
:TrainingData rdf:type owl:Class ; rdfs:subClassOf :DataCategory .
:InferredData rdf:type owl:Class ; rdfs:subClassOf :DataCategory .
:SurveillanceData rdf:type owl:Class ; rdfs:subClassOf :DataCategory .

# ===== MITIGATION SUBCLASSES =====

:TechnicalMeasure rdf:type owl:Class ; rdfs:subClassOf :Mitigation .
:Encryption rdf:type owl:Class ; rdfs:subClassOf :TechnicalMeasure .
:Pseudonymisation rdf:type owl:Class ; rdfs:subClassOf :TechnicalMeasure .
:Anonymisation rdf:type owl:Class ; rdfs:subClassOf :TechnicalMeasure .
:AccessControl rdf:type owl:Class ; rdfs:subClassOf :TechnicalMeasure .
:AuditLog rdf:type owl:Class ; rdfs:subClassOf :TechnicalMeasure .

:OrganisationalMeasure rdf:type owl:Class ; rdfs:subClassOf :Mitigation .
:StaffTraining rdf:type owl:Class ; rdfs:subClassOf :OrganisationalMeasure .
:GovernanceProcedure rdf:type owl:Class ; rdfs:subClassOf :OrganisationalMeasure .
:ComplaintMechanism rdf:type owl:Class ; rdfs:subClassOf :OrganisationalMeasure .
:IncidentResponsePlan rdf:type owl:Class ; rdfs:subClassOf :OrganisationalMeasure .
:EthicsReviewBoard rdf:type owl:Class ; rdfs:subClassOf :OrganisationalMeasure .
:HumanOversight rdf:type owl:Class ; rdfs:subClassOf :OrganisationalMeasure .
:ResponsibleReleasePolicy rdf:type owl:Class ; rdfs:subClassOf :OrganisationalMeasure .

# ===== ASSESSMENT PROCESS SUBCLASSES =====

:EthicsSelfAssessment rdf:type owl:Class ; rdfs:subClassOf :AssessmentProcess .
:RiskAssessment rdf:type owl:Class ; rdfs:subClassOf :AssessmentProcess .
:BiasAssessment rdf:type owl:Class ; rdfs:subClassOf :AssessmentProcess .
:FRIAProcedure rdf:type owl:Class ; rdfs:subClassOf :AssessmentProcess .
:DPIAProcedure rdf:type owl:Class ; rdfs:subClassOf :AssessmentProcess .
:EnvironmentalImpactAssessment rdf:type owl:Class ; rdfs:subClassOf :AssessmentProcess .

# ===== COMPLIANCE STATUS SUBCLASSES =====

:Compliant rdf:type owl:Class ; rdfs:subClassOf :ComplianceStatus .
:NonCompliant rdf:type owl:Class ; rdfs:subClassOf :ComplianceStatus .
:PartiallyCompliant rdf:type owl:Class ; rdfs:subClassOf :ComplianceStatus .
:NotApplicable rdf:type owl:Class ; rdfs:subClassOf :ComplianceStatus .

# ===== OBJECT PROPERTIES =====

:hasRequirement rdf:type owl:ObjectProperty ;
    rdfs:domain :Framework ;
    rdfs:range :Requirement ;
    rdfs:label "has requirement" .

:belongsToFramework rdf:type owl:ObjectProperty ;
    rdfs:domain :Requirement ;
    rdfs:range :Framework ;
    owl:inverseOf :hasRequirement ;
    rdfs:label "belongs to framework" .

:hasTier rdf:type owl:ObjectProperty ;
    rdfs:domain :Requirement ;
    rdfs:range :Tier ;
    rdfs:label "has tier" .

:mapsToRight rdf:type owl:ObjectProperty ;
    rdfs:domain :Requirement ;
    rdfs:range :EUCharterRight ;
    rdfs:label "maps to EU Charter right" .

:hasEvidence rdf:type owl:ObjectProperty ;
    rdfs:domain :Requirement ;
    rdfs:range :Evidence ;
    rdfs:label "has evidence" .

:requiresEvidence rdf:type owl:ObjectProperty ;
    rdfs:domain :Requirement ;
    rdfs:range :Evidence ;
    rdfs:label "requires evidence" .

:assignedTo rdf:type owl:ObjectProperty ;
    rdfs:domain :Requirement ;
    rdfs:range :Stakeholder ;
    rdfs:label "assigned to" .

:appliesTo rdf:type owl:ObjectProperty ;
    rdfs:domain :Requirement ;
    rdfs:range :Stakeholder ;
    rdfs:label "applies to" .

:hasRisk rdf:type owl:ObjectProperty ;
    rdfs:domain :Requirement ;
    rdfs:range :RiskCategory ;
    rdfs:label "has risk" .

:hasMitigation rdf:type owl:ObjectProperty ;
    rdfs:domain :RiskCategory ;
    rdfs:range :Mitigation ;
    rdfs:label "has mitigation" .

:mitigatedBy rdf:type owl:ObjectProperty ;
    rdfs:domain :RiskCategory ;
    rdfs:range :Mitigation ;
    owl:inverseOf :mitigates ;
    rdfs:label "mitigated by" .

:mitigates rdf:type owl:ObjectProperty ;
    rdfs:domain :Mitigation ;
    rdfs:range :RiskCategory ;
    rdfs:label "mitigates" .

:involvesData rdf:type owl:ObjectProperty ;
    rdfs:domain :Requirement ;
    rdfs:range :DataCategory ;
    rdfs:label "involves data" .

:hasAssessmentProcess rdf:type owl:ObjectProperty ;
    rdfs:domain :Framework ;
    rdfs:range :AssessmentProcess ;
    rdfs:label "has assessment process" .

:hasComplianceStatus rdf:type owl:ObjectProperty ;
    rdfs:domain :Requirement ;
    rdfs:range :ComplianceStatus ;
    rdfs:label "has compliance status" .

:isRelatedTo rdf:type owl:ObjectProperty ;
    rdf:type owl:SymmetricProperty ;
    rdfs:domain :Requirement ;
    rdfs:range :Requirement ;
    rdfs:label "is related to" .

:complementedBy rdf:type owl:ObjectProperty ;
    rdfs:domain :AssessmentProcess ;
    rdfs:range :AssessmentProcess ;
    rdfs:label "complemented by" .

:hasImpactOn rdf:type owl:ObjectProperty ;
    rdfs:domain :RiskCategory ;
    rdfs:range :EUCharterRight ;
    rdfs:label "has impact on" .

:hasStakeholder rdf:type owl:ObjectProperty ;
    rdfs:domain :Requirement ;
    rdfs:range :Stakeholder ;
    rdfs:label "has stakeholder" .

# ===== DATA PROPERTIES =====

:requirementID rdf:type owl:DatatypeProperty ;
    rdfs:domain :Requirement ;
    rdfs:range xsd:string ;
    rdfs:label "requirement ID" .

:requirementText rdf:type owl:DatatypeProperty ;
    rdfs:domain :Requirement ;
    rdfs:range xsd:string ;
    rdfs:label "requirement text" .

:sectionReference rdf:type owl:DatatypeProperty ;
    rdfs:domain :Requirement ;
    rdfs:range xsd:string ;
    rdfs:label "section reference" .

:tierLevel rdf:type owl:DatatypeProperty ;
    rdfs:domain :Requirement ;
    rdfs:range xsd:integer ;
    rdfs:label "tier level" .

:isMandatory rdf:type owl:DatatypeProperty ;
    rdfs:domain :Requirement ;
    rdfs:range xsd:boolean ;
    rdfs:label "is mandatory" .

:evidenceDescription rdf:type owl:DatatypeProperty ;
    rdfs:domain :Evidence ;
    rdfs:range xsd:string ;
    rdfs:label "evidence description" .

:noteText rdf:type owl:DatatypeProperty ;
    rdfs:domain :Requirement ;
    rdfs:range xsd:string ;
    rdfs:label "note text" .

:dateExtracted rdf:type owl:DatatypeProperty ;
    rdfs:domain :Requirement ;
    rdfs:range xsd:dateTime ;
    rdfs:label "date extracted" .

:frameworkVersion rdf:type owl:DatatypeProperty ;
    rdfs:domain :Framework ;
    rdfs:range xsd:string ;
    rdfs:label "framework version" .

:legalBasis rdf:type owl:DatatypeProperty ;
    rdfs:domain :Requirement ;
    rdfs:range xsd:string ;
    rdfs:label "legal basis" .

:triggersReviewLevel rdf:type owl:DatatypeProperty ;
    rdfs:domain :Requirement ;
    rdfs:range xsd:string ;
    rdfs:label "triggers review level" .

# ===== SAMPLE INDIVIDUALS (10 REAMS requirements) =====

:R001 rdf:type :Obligation ;
    :requirementID "R001" ;
    :requirementText "Applicant must be identified with name, staff/student number, email, school/department" ;
    :sectionReference "REAMS §2.2.1" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :REAMS ;
    :hasTier :Tier1_Mandatory ;
    :assignedTo :Researcher .

:R005 rdf:type :Obligation ;
    :requirementID "R005" ;
    :requirementText "Applicant must have completed Data Protection Training within last 24 months" ;
    :sectionReference "REAMS §2.2.1" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :REAMS ;
    :hasTier :Tier1_Mandatory ;
    :assignedTo :Researcher ;
    :requiresEvidence :Certificate ;
    :mapsToRight :Art8_DataProtection ;
    :legalBasis "GDPR Art 39(1)(b)" .

:R010 rdf:type :Obligation ;
    :requirementID "R010" ;
    :requirementText "Assess whether research could have detrimental legal, economic or social consequences for participants" ;
    :sectionReference "REAMS §2.3.1" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :REAMS ;
    :hasTier :Tier1_Mandatory ;
    :assignedTo :Researcher ;
    :mapsToRight :Art1_HumanDignity , :Art47_RightToEffectiveRemedy ;
    :hasRisk :PsychologicalHarm , :FinancialHarm ;
    :triggersReviewLevel "Level 3" .

:R019 rdf:type :Obligation ;
    :requirementID "R019" ;
    :requirementText "Will consent be obtained from participants (or proxy/guardian)?" ;
    :sectionReference "REAMS §2.3.2" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :REAMS ;
    :hasTier :Tier1_Mandatory ;
    :assignedTo :Researcher ;
    :requiresEvidence :ConsentForm ;
    :mapsToRight :Art8_DataProtection ;
    :legalBasis "GDPR Art 6-7" ;
    :appliesTo :DataSubject .

:R027 rdf:type :Obligation ;
    :requirementID "R027" ;
    :requirementText "Describe general characteristics of target population (vulnerability status, children, staff/students)" ;
    :sectionReference "REAMS §2.3.2" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :REAMS ;
    :hasTier :Tier1_Mandatory ;
    :assignedTo :Researcher ;
    :mapsToRight :Art24_RightsOfChild , :Art21_NonDiscrimination ;
    :triggersReviewLevel "Level 3" .

:R042 rdf:type :Obligation ;
    :requirementID "R042" ;
    :requirementText "How will consent be obtained and by whom?" ;
    :sectionReference "REAMS §2.7" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :REAMS ;
    :hasTier :Tier1_Mandatory ;
    :assignedTo :Researcher ;
    :requiresEvidence :ConsentForm ;
    :mapsToRight :Art8_DataProtection , :Art7_PrivateLife ;
    :legalBasis "GDPR Art 7" .

:R054 rdf:type :Obligation ;
    :requirementID "R054" ;
    :requirementText "Identify risks to participants: inconvenience, physical, emotional, reputational, financial, privacy, intrusive, harmful" ;
    :sectionReference "REAMS §2.8.3" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :REAMS ;
    :hasTier :Tier1_Mandatory ;
    :assignedTo :Researcher ;
    :mapsToRight :Art1_HumanDignity , :Art3_RightToIntegrity , :Art7_PrivateLife ;
    :hasRisk :PhysicalHarm , :PsychologicalHarm , :ReputationalHarm , :FinancialHarm , :PrivacyBreach .

:R071 rdf:type :Obligation ;
    :requirementID "R071" ;
    :requirementText "Describe security measures for data access, storage, transfer" ;
    :sectionReference "REAMS §2.11.2" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :REAMS ;
    :hasTier :Tier1_Mandatory ;
    :assignedTo :Researcher ;
    :mapsToRight :Art8_DataProtection ;
    :legalBasis "GDPR Art 32" ;
    :involvesData :PersonalData ;
    :hasMitigation :Encryption , :AccessControl .

:R074 rdf:type :Obligation ;
    :requirementID "R074" ;
    :requirementText "For each processing risk: list risk, severity/impact, likelihood, mitigation actions" ;
    :sectionReference "REAMS §2.11.3" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :REAMS ;
    :hasTier :Tier1_Mandatory ;
    :assignedTo :Researcher ;
    :mapsToRight :Art8_DataProtection ;
    :legalBasis "GDPR Art 35" .

:R085 rdf:type :Obligation ;
    :requirementID "R085" ;
    :requirementText "Have you considered anti-discrimination and bias implications of your AI/technology research?" ;
    :sectionReference "General" ;
    :tierLevel 2 ;
    :isMandatory false ;
    :belongsToFramework :REAMS ;
    :hasTier :Tier2_Reflective ;
    :assignedTo :Researcher ;
    :mapsToRight :Art21_NonDiscrimination , :Art23_GenderEquality ;
    :noteText "Key gap — REAMS does not explicitly cover this" .


# ===== INCIDENT KNOWLEDGE GRAPH EXTENSION =====

:Incident rdf:type owl:Class .

:impactsRight rdf:type owl:ObjectProperty ;
    rdfs:domain :Incident ;
    rdfs:range :EUCharterRight .

:demonstratesRisk rdf:type owl:ObjectProperty ;
    rdfs:domain :Incident ;
    rdfs:range :RiskCategory .

:supportsRequirement rdf:type owl:ObjectProperty ;
    rdfs:domain :Incident ;
    rdfs:range :Requirement .

:incidentID rdf:type owl:DatatypeProperty .
:incidentTitle rdf:type owl:DatatypeProperty .
:incidentYear rdf:type owl:DatatypeProperty .
:aiCapability rdf:type owl:DatatypeProperty .
:coderAgreement rdf:type owl:DatatypeProperty .

:AIAAIC_001 rdf:type :Incident ;
 :incidentID "AIAAIC-001" ; :incidentTitle "Amazon Hiring Algorithm Gender Bias" ; :incidentYear "2018" ;
 :aiCapability "Reasoning (NLP)" ; :coderAgreement "PARTIAL" ;
 :impactsRight :Art21_NonDiscrimination, :Art23_GenderEquality ; :supportsRequirement :R085 .

:AIAAIC_002 rdf:type :Incident ;
 :incidentID "AIAAIC-002" ; :incidentTitle "Detroit Police Facial Recognition False Arrest" ; :incidentYear "2020" ;
 :aiCapability "Perception (CV)" ; :coderAgreement "PARTIAL" ;
 :impactsRight :Art6_RightToLiberty, :Art7_PrivateLife, :Art21_NonDiscrimination, :Art47_RightToEffectiveRemedy .

:AIAAIC_003 rdf:type :Incident ;
 :incidentID "AIAAIC-003" ; :incidentTitle "Microsoft Tay Chatbot Harmful Outputs" ; :incidentYear "2016" ;
 :impactsRight :Art1_HumanDignity, :Art21_NonDiscrimination .

:AIAAIC_004 rdf:type :Incident ;
 :incidentID "AIAAIC-004" ; :incidentTitle "COMPAS Recidivism Algorithm Racial Bias" ;
 :impactsRight :Art21_NonDiscrimination, :Art47_RightToEffectiveRemedy, :Art48_PresumptionOfInnocence, :Art6_RightToLiberty .

:AIAAIC_005 rdf:type :Incident ;
 :incidentID "AIAAIC-005" ; :incidentTitle "Google Photos Labeled Black People as Gorillas" ;
 :impactsRight :Art1_HumanDignity, :Art21_NonDiscrimination .

:AIAAIC_006 rdf:type :Incident ;
 :incidentID "AIAAIC-006" ; :incidentTitle "Healthcare Algorithm Racial Bias (Optum)" ;
 :impactsRight :Art21_NonDiscrimination, :Art35_HealthCare, :Art8_DataProtection .

:AIAAIC_007 rdf:type :Incident ;
 :incidentID "AIAAIC-007" ; :incidentTitle "Clearview AI Mass Facial Recognition Scraping" ;
 :impactsRight :Art7_PrivateLife, :Art8_DataProtection, :Art26_DisabilityIntegration .

:AIAAIC_008 rdf:type :Incident ;
 :incidentID "AIAAIC-008" ; :incidentTitle "PredPol Predictive Policing Algorithmic Bias" ;
 :impactsRight :Art21_NonDiscrimination, :Art6_RightToLiberty, :Art47_RightToEffectiveRemedy .

:AIAAIC_009 rdf:type :Incident ;
 :incidentID "AIAAIC-009" ; :incidentTitle "Uber Self-Driving Car Fatal Pedestrian Crash" ;
 :impactsRight :Art2_RightToLife, :Art1_HumanDignity, :Art47_RightToEffectiveRemedy .

:AIAAIC_010 rdf:type :Incident ;
 :incidentID "AIAAIC-010" ; :incidentTitle "UK Post Office Horizon System Wrongful Prosecutions" ;
 :impactsRight :Art47_RightToEffectiveRemedy, :Art48_PresumptionOfInnocence .

:AIAAIC_011 a :Incident ;
    :incidentID "AIAAIC-011" ;
    :incidentTitle "Facebook Discriminatory Ad Targeting" ;
    :incidentYear "2019" ;
    :aiCapability "Reasoning (Recommendation)" ;
    :impactsRight :Art21_NonDiscrimination, :Art23_GenderEquality, :Art26_RightToData ;
    :demonstratesRisk :Discrimination, :PrivacyBreach ;
