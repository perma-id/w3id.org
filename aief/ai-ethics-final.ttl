:R008 rdf:type :Obligation ;
    :requirementID "R008" ;
    :requirementText "Project title, data collection start/end dates, project end date must be specified" ;
    :sectionReference "§2.3.1" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :REAMS ;
    :hasTier :Tier1_Mandatory .


:R009 rdf:type :Obligation ;
    :requirementID "R009" ;
    :requirementText "Specify whether project involves humans/their data OR animals" ;
    :sectionReference "§2.3.1" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :REAMS ;
    :hasTier :Tier1_Mandatory ;
    :noteText "Determines entire question set" .


:R010 rdf:type :Obligation ;
    :requirementID "R010" ;
    :requirementText "Assess whether research could have detrimental legal, economic or social consequences for participants or establishments" ;
    :sectionReference "§2.3.1" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :REAMS ;
    :hasTier :Tier1_Mandatory ;
