:R001 rdf:type :Obligation ;
    :requirementID "R001" ;
    :requirementText "Applicant must be identified with name, staff/student number, email, school/department" ;
    :sectionReference "§2.2.1" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :REAMS ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "Auto-populated from TCD records" ;
    :legalBasis "GDPR Art 5(1)(a)" ;
    :noteText "Mandatory for all" .


:R002 rdf:type :Obligation ;
    :requirementID "R002" ;
    :requirementText "Applicant must confirm role on project (PI / Non-PI / Other)" ;
    :sectionReference "§2.2.1" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :REAMS ;
    :hasTier :Tier1_Mandatory ;
    :noteText "If not PI, PI must also approve" .


:R003 rdf:type :Obligation ;
    :requirementID "R003" ;
    :requirementText "Applicant must have read and understood Trinity Policy on Good Research Practice" ;
    :sectionReference "§2.2.1" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :REAMS ;
