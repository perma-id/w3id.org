:AI029 rdf:type :Obligation ;
    :requirementID "AI029" ;
    :requirementText "Have you considered whether pseudonymised or anonymised data could still lead to identification of affected individuals?" ;
    :sectionReference "General" ;
    :tierLevel 2 ;
    :isMandatory false ;
    :belongsToFramework :EUAIAct ;
    :hasTier :Tier2_Reflective ;
    :legalBasis "Paper + GDPR Recital 26" ;
    :noteText "Charter Mapping: Art 8 Data protection" .


:AI030 rdf:type :Obligation ;
    :requirementID "AI030" ;
    :requirementText "Have you assessed impact at the granular level — not just non-discrimination but which specific grounds (sex, race, disability, age)?" ;
    :sectionReference "General" ;
    :tierLevel 2 ;
    :isMandatory false ;
    :belongsToFramework :EUAIAct ;
    :hasTier :Tier2_Reflective ;
    :legalBasis "Paper discussion" ;
    :noteText "Charter Mapping: Art 21 subcategories" .


:HE001 rdf:type :Obligation ;
    :requirementID "HE001" ;
    :requirementText "AI system must not deprive end-users or affected persons of ability to make decisions about their own lives or remove basic freedoms" ;
    :sectionReference "Human Agency" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :HorizonEurope ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "Ethics self-assessment" ;
    :legalBasis "EU Charter" ;
    :noteText "Charter Mapping: Art 6 Right to liberty; Art 1 Human dignity" .


:HE002 rdf:type :Obligation ;
    :requirementID "HE002" ;
    :requirementText "AI system must not autonomously make decisions about fundamental personal, economic, social or political issues normally decided by humans, without human oversight and redress" ;
    :sectionReference "Human Agency" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :HorizonEurope ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "Ethics self-assessment" ;
    :legalBasis "EU Charter" ;
    :noteText "Charter Mapping: Art 1 Human dignity; Art 47 Right to effective remedy" .


:HE003 rdf:type :Obligation ;
    :requirementID "HE003" ;
    :requirementText "AI system must not subordinate, coerce, deceive, manipulate, objectify or dehumanize end-users or affected persons" ;
    :sectionReference "Human Agency" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :HorizonEurope ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "Ethics self-assessment" ;
    :legalBasis "EU Charter" ;
    :noteText "Charter Mapping: Art 1 Human dignity; Art 3 Integrity" .


:HE004 rdf:type :Obligation ;
    :requirementID "HE004" ;
    :requirementText "AI system must not purposely stimulate attachment or addiction" ;
    :sectionReference "Human Agency" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :HorizonEurope ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "Ethics self-assessment" ;
    :legalBasis "EU Charter" ;
    :noteText "Charter Mapping: Art 3 Integrity of person" .


:HE005 rdf:type :Obligation ;
    :requirementID "HE005" ;
    :requirementText "AI system should give operators and end-users ability to control, direct and intervene in basic operations" ;
    :sectionReference "Human Agency" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :HorizonEurope ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "Design documentation" ;
    :legalBasis "EU Charter" ;
    :noteText "Charter Mapping: Art 6 Right to liberty" .


:HE006 rdf:type :Obligation ;
    :requirementID "HE006" ;
    :requirementText "End-users and affected persons must receive comprehensible information about the AI logic, significance and envisaged consequences" ;
    :sectionReference "Human Agency" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :HorizonEurope ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "User-facing documentation" ;
    :legalBasis "GDPR Art 13-14" ;
    :noteText "Charter Mapping: Art 8 Data protection; Art 11 Freedom of expression" .


:HE007 rdf:type :Obligation ;
    :requirementID "HE007" ;
    :requirementText "AI system must process personal data lawfully, fairly and transparently" ;
    :sectionReference "Privacy & Data" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :HorizonEurope ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "GDPR compliance documentation" ;
    :legalBasis "GDPR Art 5-6" ;
    :noteText "Charter Mapping: Art 8 Data protection" .


:HE008 rdf:type :Obligation ;
    :requirementID "HE008" ;
    :requirementText "Data minimisation and data protection by design and by default must be integrated" ;
    :sectionReference "Privacy & Data" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :HorizonEurope ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "Design documentation" ;
    :legalBasis "GDPR Art 25" ;
    :noteText "Charter Mapping: Art 8 Data protection" .


:HE009 rdf:type :Obligation ;
    :requirementID "HE009" ;
    :requirementText "Appropriate technical and organisational measures must be in place to safeguard rights of data subjects (anonymisation, pseudonymisation, encryption, aggregation)" ;
    :sectionReference "Privacy & Data" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :HorizonEurope ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "Security documentation" ;
    :legalBasis "GDPR Art 32" ;
    :noteText "Charter Mapping: Art 8 Data protection" .


:HE010 rdf:type :Obligation ;
    :requirementID "HE010" ;
    :requirementText "Strong security measures must prevent data breaches and leakages" ;
    :sectionReference "Privacy & Data" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :HorizonEurope ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "Security audit / logging" ;
    :legalBasis "GDPR Art 32-34; Cybersecurity Act" ;
    :noteText "Charter Mapping: Art 8 Data protection" .


:HE011 rdf:type :Obligation ;
    :requirementID "HE011" ;
    :requirementText "Data must be acquired, stored and used in a manner auditable by humans" ;
    :sectionReference "Privacy & Data" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :HorizonEurope ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "Audit trail" ;
    :legalBasis "GDPR" ;
    :noteText "Charter Mapping: Art 8 Data protection" .


:HE012 rdf:type :Obligation ;
    :requirementID "HE012" ;
    :requirementText "Research proposal must specify steps to ensure data about people is representative of target population and reflects diversity or is sufficiently neutral" ;
    :sectionReference "Fairness" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :HorizonEurope ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "Proposal text / data statement" ;
    :legalBasis "EU Charter" ;
    :noteText "Charter Mapping: Art 21 Non-discrimination" ;
    :noteText "MUST requirement" .


:HE013 rdf:type :Obligation ;
    :requirementID "HE013" ;
    :requirementText "Document how bias in input data and algorithmic design will be identified and avoided" ;
    :sectionReference "Fairness" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :HorizonEurope ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "Bias assessment report" ;
    :legalBasis "EU Charter" ;
    :noteText "Charter Mapping: Art 21 Non-discrimination; Art 23 Equality" .


:HE014 rdf:type :Obligation ;
    :requirementID "HE014" ;
    :requirementText "AI system should be designed for universal accessibility — usable by end-users with different abilities" ;
    :sectionReference "Fairness" ;
    :tierLevel 2 ;
    :isMandatory false ;
    :belongsToFramework :HorizonEurope ;
    :hasTier :Tier2_Reflective ;
    :requiresEvidence "Accessibility compliance" ;
    :legalBasis "Accessibility guidelines" ;
    :noteText "Charter Mapping: Art 26 Integration of persons with disabilities" ;
    :noteText "Encouraged not mandatory" .


:HE015 rdf:type :Obligation ;
    :requirementID "HE015" ;
    :requirementText "Possible negative social impacts on certain groups must be mitigated, including impacts beyond algorithmic bias" ;
    :sectionReference "Fairness" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :HorizonEurope ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "Impact assessment" ;
    :legalBasis "EU Charter" ;
    :noteText "Charter Mapping: Art 21 Non-discrimination; Art 20 Equality before law" ;
    :noteText "MUST requirement" .


:HE016 rdf:type :Obligation ;
    :requirementID "HE016" ;
    :requirementText "Methods to identify and mitigate negative social impacts in medium and longer term must be documented in proposal" ;
    :sectionReference "Fairness" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :HorizonEurope ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "Proposal text" ;
    :legalBasis "EU Charter" ;
    :noteText "Charter Mapping: Art 21 Non-discrimination" .


:HE017 rdf:type :Obligation ;
    :requirementID "HE017" ;
    :requirementText "AI system must not unduly or unfairly reduce psychological and emotional well-being of end-users and stakeholders" ;
    :sectionReference "Well-being" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :HorizonEurope ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "Well-being assessment" ;
    :legalBasis "EU Charter" ;
    :noteText "Charter Mapping: Art 1 Human dignity; Art 3 Integrity" .


:HE018 rdf:type :Obligation ;
    :requirementID "HE018" ;
    :requirementText "AI development must be mindful of environmental sustainability — document environmental impact and mitigation steps" ;
    :sectionReference "Well-being" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :HorizonEurope ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "Environmental impact statement" ;
    :legalBasis "Sustainable Development Objectives" ;
    :noteText "Charter Mapping: Art 37 Environmental protection" ;
    :noteText "MUST requirement" .


:HE019 rdf:type :Obligation ;
    :requirementID "HE019" ;
    :requirementText "AI systems in media, communications, politics, social analytics must be assessed for potential to negatively impact democratic processes and social relations" ;
    :sectionReference "Well-being" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :HorizonEurope ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "Social impact assessment" ;
    :legalBasis "EU Charter" ;
    :noteText "Charter Mapping: Art 11 Freedom of expression; Art 12 Freedom of assembly" .


:HE020 rdf:type :Obligation ;
    :requirementID "HE020" ;
    :requirementText "AI and robotics systems must not reduce safety in the workplace" ;
    :sectionReference "Well-being" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :HorizonEurope ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "Safety compliance" ;
    :legalBasis "IEEE P1228" ;
    :noteText "Charter Mapping: Art 31 Fair working conditions" .


:HE021 rdf:type :Obligation ;
    :requirementID "HE021" ;
    :requirementText "It must be made clear to end-users they are interacting with an AI system" ;
    :sectionReference "Transparency" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :HorizonEurope ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "User notification / disclosure" ;
    :legalBasis "EU Charter" ;
    :noteText "Charter Mapping: Art 11 Freedom of expression" ;
    :noteText "Especially chatbots" .


:HE022 rdf:type :Obligation ;
    :requirementID "HE022" ;
    :requirementText "Purpose, capabilities, limitations, benefits and risks of AI system must be openly communicated to end-users and stakeholders" ;
    :sectionReference "Transparency" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :HorizonEurope ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "User documentation" ;
    :legalBasis "EU Charter" ;
    :noteText "Charter Mapping: Art 11 Freedom of expression" .


:HE023 rdf:type :Obligation ;
    :requirementID "HE023" ;
    :requirementText "Traceability measures must be considered for the AI system's entire lifecycle" ;
    :sectionReference "Transparency" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :HorizonEurope ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "Traceability documentation" ;
    :legalBasis "EU Charter" .


:HE024 rdf:type :Obligation ;
    :requirementID "HE024" ;
    :requirementText "Research proposal should explain how decisions made by system will be explainable to users, including reasons for decisions" ;
    :sectionReference "Transparency" ;
    :tierLevel 2 ;
    :isMandatory false ;
    :belongsToFramework :HorizonEurope ;
    :hasTier :Tier2_Reflective ;
    :requiresEvidence "Explainability documentation" ;
    :legalBasis "EU Charter" ;
    :noteText "Particularly for high-impact decisions" .


:HE025 rdf:type :Obligation ;
    :requirementID "HE025" ;
    :requirementText "Development processes must keep records of all relevant decisions regarding ethical compliance" ;
    :sectionReference "Transparency" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :HorizonEurope ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "Ethics decision log" ;
    :legalBasis "EU Charter" ;
    :noteText "MUST requirement" .


:HE026 rdf:type :Obligation ;
    :requirementID "HE026" ;
    :requirementText "Document how ethically and socially undesirable effects will be detected, stopped and prevented from reoccurring" ;
    :sectionReference "Accountability" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :HorizonEurope ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "Detection/remediation plan" ;
    :legalBasis "EU Charter" ;
    :noteText "MUST requirement" .


:HE027 rdf:type :Obligation ;
    :requirementID "HE027" ;
    :requirementText "AI system must allow for human oversight and control over decision cycles and operation, unless compelling justification provided" ;
    :sectionReference "Accountability" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :HorizonEurope ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "Oversight documentation" ;
    :legalBasis "EU Charter" ;
    :noteText "Charter Mapping: Art 47 Right to effective remedy" .


:HE028 rdf:type :Obligation ;
    :requirementID "HE028" ;
    :requirementText "Research proposal should include evaluation of possible ethics risks including risk assessment procedures and post-deployment mitigation" ;
    :sectionReference "Accountability" ;
    :tierLevel 2 ;
    :isMandatory false ;
    :belongsToFramework :HorizonEurope ;
    :hasTier :Tier2_Reflective ;
    :requiresEvidence "Risk assessment" ;
    :legalBasis "EU Charter" ;
    :noteText "Scaled to research type" .


:HE029 rdf:type :Obligation ;
    :requirementID "HE029" ;
    :requirementText "Consider how end-users, data subjects and third parties can report complaints, ethical concerns or adverse events" ;
    :sectionReference "Accountability" ;
    :tierLevel 2 ;
    :isMandatory false ;
    :belongsToFramework :HorizonEurope ;
    :hasTier :Tier2_Reflective ;
    :requiresEvidence "Complaint mechanism" ;
    :legalBasis "EU Charter" ;
    :noteText "Charter Mapping: Art 47 Right to effective remedy" .


:HE030 rdf:type :Obligation ;
    :requirementID "HE030" ;
    :requirementText "All AI systems should be auditable by independent third parties — system should generate human-accessible logs" ;
    :sectionReference "Accountability" ;
    :tierLevel 2 ;
    :isMandatory false ;
    :belongsToFramework :HorizonEurope ;
    :hasTier :Tier2_Reflective ;
    :requiresEvidence "Audit logs" ;
    :legalBasis "EU Charter" .


:HE031 rdf:type :Obligation ;
    :requirementID "HE031" ;
    :requirementText "Ensure processing of personal data complies with GDPR — prepare specific data protection policy" ;
    :sectionReference "Data Collection" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :HorizonEurope ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "Data protection policy" ;
    :legalBasis "GDPR" ;
    :noteText "Charter Mapping: Art 8 Data protection" .


:HE032 rdf:type :Obligation ;
    :requirementID "HE032" ;
    :requirementText "Input, training and output data must all be analysed for bias — verify data accounts for diversity in gender, race, age, sexual orientation, national origin, religion, health, disability" ;
    :sectionReference "Data Collection" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :HorizonEurope ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "Bias assessment" ;
    :legalBasis "GDPR; EU Charter" ;
    :noteText "Charter Mapping: Art 21 Non-discrimination" .


:HE033 rdf:type :Obligation ;
    :requirementID "HE033" ;
    :requirementText "Analyse training data for relevance and representativeness — undertake formal bias assessment" ;
    :sectionReference "Data Collection" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :HorizonEurope ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "Data quality report" ;
    :legalBasis "EU Charter" ;
    :noteText "Charter Mapping: Art 21 Non-discrimination" .


:HE034 rdf:type :Obligation ;
    :requirementID "HE034" ;
    :requirementText "Ensure ability to go back to each state the system has been in to determine training data used at any point" ;
    :sectionReference "Data Collection" ;
    :tierLevel 2 ;
    :isMandatory false ;
    :belongsToFramework :HorizonEurope ;
    :hasTier :Tier2_Reflective ;
    :requiresEvidence "Versioning / provenance system" ;
    :legalBasis "EU Charter" ;
    :noteText "Whenever possible" .


:HE035 rdf:type :Obligation ;
    :requirementID "HE035" ;
    :requirementText "If creating inferred personal data or aggregating datasets, new data must receive same protection level as original data" ;
    :sectionReference "Design & Build" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :HorizonEurope ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "Data governance documentation" ;
    :legalBasis "GDPR" ;
    :noteText "Charter Mapping: Art 8 Data protection" .


:HE036 rdf:type :Obligation ;
    :requirementID "HE036" ;
    :requirementText "Ensure no new personal data collected or created during development or use unless necessary" ;
    :sectionReference "Design & Build" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :HorizonEurope ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "Data minimisation documentation" ;
    :legalBasis "GDPR Art 5(1)(c)" ;
    :noteText "Charter Mapping: Art 8 Data protection" .


:HE037 rdf:type :Obligation ;
    :requirementID "HE037" ;
    :requirementText "Check for algorithmic bias during detailed development phase using methods such as counterfactual evaluation" ;
    :sectionReference "Design & Build" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :HorizonEurope ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "Bias testing report" ;
    :legalBasis "EU Charter" ;
    :noteText "Charter Mapping: Art 21 Non-discrimination" .


:HE038 rdf:type :Obligation ;
    :requirementID "HE038" ;
    :requirementText "Ensure interface design honours universal accessibility principles" ;
    :sectionReference "Design & Build" ;
    :tierLevel 2 ;
    :isMandatory false ;
    :belongsToFramework :HorizonEurope ;
    :hasTier :Tier2_Reflective ;
    :requiresEvidence "Accessibility review" ;
    :legalBasis "Accessibility guidelines" ;
    :noteText "Charter Mapping: Art 26 Integration of persons with disabilities" .


:HE039 rdf:type :Obligation ;
    :requirementID "HE039" ;
    :requirementText "Establish traceability and accountability measures covering: design methods, testing methods, system outcomes, and alternative decision scenarios" ;
    :sectionReference "Design & Build" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :HorizonEurope ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "Traceability documentation" ;
    :legalBasis "EU Charter" .


:HE040 rdf:type :Obligation ;
    :requirementID "HE040" ;
    :requirementText "Code must be documented and explained within software and ancillary documentation" ;
    :sectionReference "Design & Build" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :HorizonEurope ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "Code documentation" ;
    :legalBasis "EU Charter" .


:HE041 rdf:type :Obligation ;
    :requirementID "HE041" ;
    :requirementText "Use formal methodologies for explainability where possible (XAI, Transparency by Design, Model Cards)" ;
    :sectionReference "Design & Build" ;
    :tierLevel 2 ;
    :isMandatory false ;
    :belongsToFramework :HorizonEurope ;
    :hasTier :Tier2_Reflective ;
    :requiresEvidence "Explainability artefacts" ;
