:R011 rdf:type :Obligation ;
    :requirementID "R011" ;
    :requirementText "Declare intentions of study: deception, illegal activity, intrusive/harmful topics, military role, dual purpose" ;
    :sectionReference "§2.3.1" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :REAMS ;
    :hasTier :Tier1_Mandatory ;
    :noteText "Charter Mapping: Art 1 Human dignity; Art 3 Right to integrity" ;
    :noteText "Any selection except 'none' → Level 3" .


:R012 rdf:type :Obligation ;
    :requirementID "R012" ;
    :requirementText "State research aims, objectives, research question or hypothesis (100 words)" ;
