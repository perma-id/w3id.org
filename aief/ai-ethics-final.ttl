    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :HorizonEurope ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "Audit report" ;
    :legalBasis "EU Charter" .


:HE044 rdf:type :Obligation ;
    :requirementID "HE044" ;
