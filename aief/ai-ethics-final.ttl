    :legalBasis "Research integrity" ;
    :noteText "PhD: CA7000; Staff: Epigeum" .


:R005 rdf:type :Obligation ;
    :requirementID "R005" ;
    :requirementText "Applicant must have completed Data Protection Training within last 24 months" ;
    :sectionReference "§2.2.1" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :REAMS ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "Certificate upload required" ;
    :legalBasis "GDPR Art 39(1)(b)" .


:R006 rdf:type :Obligation ;
    :requirementID "R006" ;
    :requirementText "All Trinity collaborators must be listed with role, name, email, school" ;
    :sectionReference "§2.2.2" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :REAMS ;
