:R004 rdf:type :Obligation ;
    :requirementID "R004" ;
    :requirementText "Applicant must have completed Research Integrity Training Module" ;
    :sectionReference "§2.2.1" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :REAMS ;
    :hasTier :Tier1_Mandatory ;
