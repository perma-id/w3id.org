    :legalBasis "EU Charter" ;
    :noteText "Charter Mapping: Art 11 Freedom of expression; Art 12 Freedom of assembly" .


:HE052 rdf:type :Obligation ;
    :requirementID "HE052" ;
    :requirementText "Have you assessed the environmental footprint of your AI system's compute and supply chain?" ;
    :sectionReference "General" ;
    :tierLevel 2 ;
    :isMandatory false ;
    :belongsToFramework :HorizonEurope ;
    :hasTier :Tier2_Reflective ;
    :legalBasis "Sustainable Development Objectives" ;
    :noteText "Charter Mapping: Art 37 Environmental protection" .


:ACM001 rdf:type :Obligation ;
    :requirementID "ACM001" ;
    :requirementText "Research must contribute to society and human well-being — discuss how applications may harm individuals, groups or society and ways to mitigate such harms" ;
    :sectionReference "ACL §1.1" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :ACMConference ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "Ethics statement in paper" ;
    :legalBasis "ACL Code of Ethics §1.1" ;
    :noteText "Charter Mapping: Art 1 Human dignity" .


:ACM002 rdf:type :Obligation ;
    :requirementID "ACM002" ;
    :requirementText "Avoid harm — consider how data, code or other outcomes of research may cause harm" ;
    :sectionReference "ACL §1.2" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :ACMConference ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "Ethics statement in paper" ;
    :legalBasis "ACL Code of Ethics §1.2" ;
    :noteText "Charter Mapping: Art 3 Integrity of person" .


:ACM003 rdf:type :Obligation ;
    :requirementID "ACM003" ;
    :requirementText "Be fair and take action not to discriminate — consider and ameliorate biases the approach may perpetuate" ;
    :sectionReference "ACL §1.4" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :ACMConference ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "Bias analysis section" ;
    :legalBasis "ACL Code of Ethics §1.4" ;
    :noteText "Charter Mapping: Art 21 Non-discrimination" .


:ACM004 rdf:type :Obligation ;
    :requirementID "ACM004" ;
    :requirementText "Consider and ameliorate biases in data and biased code/model outputs" ;
    :sectionReference "ACL §1.4" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :ACMConference ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "Data statement / bias assessment" ;
    :legalBasis "ACL Code of Ethics §1.4" ;
    :noteText "Charter Mapping: Art 21 Non-discrimination" .


:ACM005 rdf:type :Obligation ;
    :requirementID "ACM005" ;
    :requirementText "Respect intellectual property and data/code ownership — cite creators of artefacts used and use them as intended (respect licences)" ;
    :sectionReference "ACL §1.5" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :ACMConference ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "Citation and licence compliance" ;
    :legalBasis "ACL Code of Ethics §1.5" ;
    :noteText "Charter Mapping: Art 17 Right to property" .


:ACM006 rdf:type :Obligation ;
    :requirementID "ACM006" ;
    :requirementText "Respect privacy — obtain informed consent where required and protect personally identifiable information" ;
    :sectionReference "ACL §1.6" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :ACMConference ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "IRB/ethics approval; consent forms" ;
    :legalBasis "ACL Code of Ethics §1.6" ;
    :noteText "Charter Mapping: Art 7 Private life; Art 8 Data protection" .


:ACM007 rdf:type :Obligation ;
    :requirementID "ACM007" ;
    :requirementText "Give comprehensive evaluation of systems and their impacts including analysis of possible risks of applications" ;
    :sectionReference "ACL §2.5" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :ACMConference ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "Risk analysis section in paper" ;
    :legalBasis "ACL Code of Ethics §2.5" ;
    :noteText "Charter Mapping: Art 1 Human dignity" .


:ACM008 rdf:type :Obligation ;
    :requirementID "ACM008" ;
    :requirementText "Consider possible risks and impacts of the research approach itself (not just applications)" ;
    :sectionReference "ACL §2.5" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :ACMConference ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "Method risk discussion" ;
    :legalBasis "ACL Code of Ethics §2.5" .


:ACM009 rdf:type :Obligation ;
    :requirementID "ACM009" ;
    :requirementText "Access computing and communication resources only when authorised or compelled by public good" ;
    :sectionReference "ACL §2.8" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :ACMConference ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "Data access documentation" ;
    :legalBasis "ACL Code of Ethics §2.8" ;
    :noteText "Charter Mapping: Art 8 Data protection" .


:ACM010 rdf:type :Obligation ;
    :requirementID "ACM010" ;
    :requirementText "Design and implement systems that are robustly and usably secure — especially systems close to production deployment" ;
    :sectionReference "ACL §2.9" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :ACMConference ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "Security assessment" ;
    :legalBasis "ACL Code of Ethics §2.9" .


:ACM011 rdf:type :Obligation ;
    :requirementID "ACM011" ;
    :requirementText "Manage personnel and resources to enhance quality of working life — consider how participation of annotators/crowdworkers may cause benefits or harms" ;
    :sectionReference "ACL §3.3" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :ACMConference ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "Annotator welfare documentation" ;
    :legalBasis "ACL Code of Ethics §3.3" ;
    :noteText "Charter Mapping: Art 31 Fair working conditions" .


:ACM012 rdf:type :Obligation ;
    :requirementID "ACM012" ;
    :requirementText "Consider and ameliorate negative impacts of approach on political, social or natural environment" ;
    :sectionReference "ACL §1.1" ;
    :tierLevel 2 ;
    :isMandatory false ;
    :belongsToFramework :ACMConference ;
    :hasTier :Tier2_Reflective ;
    :requiresEvidence "Environmental/social impact statement" ;
    :legalBasis "ACL Code of Ethics §1.1" ;
    :noteText "Charter Mapping: Art 37 Environmental protection" .


:ACM013 rdf:type :Obligation ;
    :requirementID "ACM013" ;
    :requirementText "Discuss dual use potential — ways research could be misused and mitigations" ;
    :sectionReference "ACL Dual Use" ;
    :tierLevel 2 ;
    :isMandatory false ;
    :belongsToFramework :ACMConference ;
    :hasTier :Tier2_Reflective ;
    :requiresEvidence "Dual use discussion" ;
    :legalBasis "ACL Code of Ethics §1.2, §2.5" ;
    :noteText "Charter Mapping: Art 1 Human dignity" .


:ACM014 rdf:type :Obligation ;
    :requirementID "ACM014" ;
    :requirementText "All human research subjects or participants must receive appropriate compensation — respect minimum hourly rate in region where work is carried out" ;
    :sectionReference "NeurIPS Human Subjects" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :ACMConference ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "Payment documentation" ;
    :legalBasis "NeurIPS Code of Ethics" ;
    :noteText "Charter Mapping: Art 31 Fair working conditions" .


:ACM015 rdf:type :Obligation ;
    :requirementID "ACM015" ;
    :requirementText "Research involving human participants must follow existing institutional protocols (IRB or equivalent) — if no formal process exists, undergo equivalent informal ethics review" ;
    :sectionReference "NeurIPS Human Subjects" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :ACMConference ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "IRB/ethics approval or peer review" ;
    :legalBasis "NeurIPS Code of Ethics" ;
    :noteText "Charter Mapping: Art 1 Human dignity" .


:ACM016 rdf:type :Obligation ;
    :requirementID "ACM016" ;
    :requirementText "Datasets should minimise exposure of personally identifiable information unless informed consent is provided" ;
    :sectionReference "NeurIPS Privacy" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :ACMConference ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "Data anonymisation documentation" ;
    :legalBasis "NeurIPS Code of Ethics" ;
    :noteText "Charter Mapping: Art 7 Private life; Art 8 Data protection" .


:ACM017 rdf:type :Obligation ;
    :requirementID "ACM017" ;
    :requirementText "Datasets with real data of real people must have explicit consent of participants, or explain why consent was not obtained" ;
    :sectionReference "NeurIPS Consent" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :ACMConference ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "Consent documentation" ;
    :legalBasis "NeurIPS Code of Ethics" ;
    :noteText "Charter Mapping: Art 8 Data protection" .


:ACM018 rdf:type :Obligation ;
    :requirementID "ACM018" ;
    :requirementText "Authors must confirm datasets are still available for use — deprecated datasets should not be used except for audit or critical assessment" ;
    :sectionReference "NeurIPS Deprecated Data" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :ACMConference ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "Dataset status verification" ;
    :legalBasis "NeurIPS Code of Ethics" .


:ACM019 rdf:type :Obligation ;
    :requirementID "ACM019" ;
    :requirementText "Respect terms of datasets with defined licences (CC 4.0, MIT etc)" ;
    :sectionReference "NeurIPS Copyright" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :ACMConference ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "Licence compliance" ;
    :legalBasis "NeurIPS Code of Ethics" ;
    :noteText "Charter Mapping: Art 17 Right to property" .


:ACM020 rdf:type :Obligation ;
    :requirementID "ACM020" ;
    :requirementText "Assess and communicate degree to which datasets are representative of intended population — claims of diverse representation must be substantiated" ;
    :sectionReference "NeurIPS Representation" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :ACMConference ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "Representativeness statement" ;
    :legalBasis "NeurIPS Code of Ethics" ;
    :noteText "Charter Mapping: Art 21 Non-discrimination" .


:ACM021 rdf:type :Obligation ;
    :requirementID "ACM021" ;
    :requirementText "Consider whether technology can be used to harm, injure or kill people through direct application, side effects or misuse" ;
    :sectionReference "NeurIPS Safety" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :ACMConference ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "Safety assessment" ;
    :legalBasis "NeurIPS Code of Ethics" ;
    :noteText "Charter Mapping: Art 2 Right to life; Art 3 Integrity" ;
    :noteText "No weapons research accepted" .


:ACM022 rdf:type :Obligation ;
    :requirementID "ACM022" ;
    :requirementText "Consider risk that applications could open security vulnerabilities or cause serious accidents — recommend or implement protections" ;
    :sectionReference "NeurIPS Security" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :ACMConference ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "Security risk assessment" ;
    :legalBasis "NeurIPS Code of Ethics" .


:ACM023 rdf:type :Obligation ;
    :requirementID "ACM023" ;
    :requirementText "Consider whether technology can be used to discriminate, exclude or negatively impact people including healthcare, education or credit access" ;
    :sectionReference "NeurIPS Discrimination" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :ACMConference ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "Discrimination impact assessment" ;
    :legalBasis "NeurIPS Code of Ethics" ;
    :noteText "Charter Mapping: Art 21 Non-discrimination; Art 35 Health care" .


:ACM024 rdf:type :Obligation ;
    :requirementID "ACM024" ;
    :requirementText "Consult local laws before collecting or analysing bulk surveillance data — surveillance must not predict protected categories or endanger individual well-being" ;
    :sectionReference "NeurIPS Surveillance" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :ACMConference ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "Legal compliance check" ;
    :legalBasis "NeurIPS Code of Ethics" ;
    :noteText "Charter Mapping: Art 7 Private life; Art 8 Data protection" .


:ACM025 rdf:type :Obligation ;
    :requirementID "ACM025" ;
    :requirementText "Communicate whether approach could facilitate deceptive interactions causing harm (theft, fraud, harassment), impersonate public figures, influence political processes, or promote hate speech" ;
    :sectionReference "NeurIPS Deception" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :ACMConference ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "Misuse risk statement" ;
    :legalBasis "NeurIPS Code of Ethics" ;
    :noteText "Charter Mapping: Art 1 Human dignity; Art 11 Freedom of expression" .


:ACM026 rdf:type :Obligation ;
    :requirementID "ACM026" ;
    :requirementText "Consider whether research negatively impacts environment — fossil fuel extraction, consumption, greenhouse gas production" ;
    :sectionReference "NeurIPS Environment" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :ACMConference ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "Environmental impact statement" ;
    :legalBasis "NeurIPS Code of Ethics" ;
    :noteText "Charter Mapping: Art 37 Environmental protection" .


:ACM027 rdf:type :Obligation ;
    :requirementID "ACM027" ;
    :requirementText "Research must not build upon or facilitate illegal activity — strongly discourage work that denies rights to privacy, speech, health, liberty, security, legal personhood, freedom of conscience/religion" ;
    :sectionReference "NeurIPS Human Rights" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :ACMConference ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "Human rights compliance" ;
    :legalBasis "NeurIPS Code of Ethics" ;
    :noteText "Charter Mapping: Art 1-50 (multiple)" .


:ACM028 rdf:type :Obligation ;
    :requirementID "ACM028" ;
    :requirementText "Inspect suspected biases or limitations in models/datasets — ascertain whether they encode bias against gender, race, sexuality or other protected characteristics" ;
    :sectionReference "NeurIPS Bias" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :ACMConference ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "Bias audit" ;
    :legalBasis "NeurIPS Code of Ethics" ;
    :noteText "Charter Mapping: Art 21 Non-discrimination; Art 23 Equality" .


:ACM029 rdf:type :Obligation ;
    :requirementID "ACM029" ;
    :requirementText "Provide data and model documentation via structured templates (Model Cards, Datasheets for Datasets)" ;
    :sectionReference "NeurIPS Mitigation" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :ACMConference ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "Model Card / Datasheet" ;
    :legalBasis "NeurIPS Code of Ethics" .


:ACM030 rdf:type :Obligation ;
    :requirementID "ACM030" ;
    :requirementText "Provide licences for released data or models including intended use and limitations" ;
    :sectionReference "NeurIPS Mitigation" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :ACMConference ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "Licence document" ;
    :legalBasis "NeurIPS Code of Ethics" .


:ACM031 rdf:type :Obligation ;
    :requirementID "ACM031" ;
    :requirementText "Use privacy protocols, encryption and anonymisation to reduce risk of data leakage — stronger measures for sensitive data" ;
    :sectionReference "NeurIPS Mitigation" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :ACMConference ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "Security documentation" ;
    :legalBasis "NeurIPS Code of Ethics" ;
    :noteText "Charter Mapping: Art 8 Data protection" .


:ACM032 rdf:type :Obligation ;
    :requirementID "ACM032" ;
    :requirementText "High-risk models must be released with safeguards for controlled use (e.g. code of conduct for access)" ;
    :sectionReference "NeurIPS Mitigation" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :ACMConference ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "Release policy" ;
    :legalBasis "NeurIPS Code of Ethics" .


:ACM033 rdf:type :Obligation ;
    :requirementID "ACM033" ;
    :requirementText "Make accessible all information required to understand research artefacts (code, environment, weights, hyperparameters) to enable external scrutiny" ;
    :sectionReference "NeurIPS Mitigation" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :ACMConference ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "Reproducibility package" ;
    :legalBasis "NeurIPS Code of Ethics" .


:ACM034 rdf:type :Obligation ;
    :requirementID "ACM034" ;
    :requirementText "Disclose information sufficient for reproduction of results" ;
    :sectionReference "NeurIPS Mitigation" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :ACMConference ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "Reproducibility statement" ;
    :legalBasis "NeurIPS Code of Ethics" .


:ACM035 rdf:type :Obligation ;
    :requirementID "ACM035" ;
    :requirementText "Ensure adequate awareness of regional legal requirements — additional justification required where compliance could not be met due to human rights issues" ;
    :sectionReference "NeurIPS Mitigation" ;
    :tierLevel 1 ;
    :isMandatory true ;
    :belongsToFramework :ACMConference ;
    :hasTier :Tier1_Mandatory ;
    :requiresEvidence "Legal compliance statement" ;
    :legalBasis "NeurIPS Code of Ethics" .


:ACM036 rdf:type :Obligation ;
    :requirementID "ACM036" ;
    :requirementText "Have you considered whether your NLP/ML system could out, profile or endanger vulnerable individuals?" ;
    :sectionReference "General" ;
    :tierLevel 2 ;
    :isMandatory false ;
    :belongsToFramework :ACMConference ;
    :hasTier :Tier2_Reflective ;
    :legalBasis "ACL example review" ;
    :noteText "Charter Mapping: Art 1 Human dignity; Art 7 Private life" .


:ACM037 rdf:type :Obligation ;
    :requirementID "ACM037" ;
    :requirementText "Have you considered whether crowdworkers/annotators were paid a local living minimum wage and treated fairly?" ;
    :sectionReference "General" ;
    :tierLevel 2 ;
    :isMandatory false ;
    :belongsToFramework :ACMConference ;
    :hasTier :Tier2_Reflective ;
    :legalBasis "NeurIPS + ACL §3.3" ;
    :noteText "Charter Mapping: Art 31 Fair working conditions" .


:ACM038 rdf:type :Obligation ;
    :requirementID "ACM038" ;
    :requirementText "Have you considered the carbon footprint of training and deploying your model?" ;
    :sectionReference "General" ;
    :tierLevel 2 ;
    :isMandatory false ;
    :belongsToFramework :ACMConference ;
    :hasTier :Tier2_Reflective ;
    :legalBasis "NeurIPS environment guidance" ;
    :noteText "Charter Mapping: Art 37 Environmental protection" .


