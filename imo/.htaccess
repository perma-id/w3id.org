Header set Access-Control-Allow-Origin *
Options +FollowSymLinks
RewriteEngine on

# Redirect the JSON-LD context to its canonical location
RewriteRule ^([^/]+)/([0-9]+\.[0-9]+\.[0-9]+)/context(\.jsonld|\.json)?$ https://isye.gitlab.io/mks/jsonld/$2/$1/context.jsonld [R=302,L]
RewriteRule ^([0-9]+\.[0-9]+\.[0-9]+)/context(\.jsonld|\.json)?$ https://isye.gitlab.io/mks/jsonld/$1/context.jsonld [R=302,L]
RewriteRule ^([^/]+)/context(\.jsonld|\.json)?$ https://isye.gitlab.io/mks/jsonld/$1/context.jsonld [R=302,L]
RewriteRule ^context(\.jsonld|\.json)?$ https://isye.gitlab.io/mks/jsonld/context.jsonld [R=302,L]

# Redirect all requests to the IMO GitLab Pages site
RewriteRule ^(.*)$ https://isye.gitlab.io/mks/imo/$1 [R=302,L]
