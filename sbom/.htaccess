# SBOM Bridge Ontology for Mapping
# https://w3id.org/sbom/
# Maintainer: Arthit Suriyawongkul <suriyawa@tcd.ie>
# GitHub username: bact
# Source: https://github.com/openregtech/sbom

Options +FollowSymLinks
Options -MultiViews

RewriteEngine on

# Root: https://w3id.org/sbom/

## RDF clients -> main ontology (Turtle)

RewriteCond %{HTTP_ACCEPT} text/turtle
RewriteRule ^$ https://openregtech.github.io/sbom/sbom.ttl [R=303,NE,L]

## Browsers -> GitHub Pages documentation (index.html)

RewriteCond %{HTTP_ACCEPT} text/html [OR]
RewriteCond %{HTTP_ACCEPT} application/xhtml\+xml
RewriteRule ^$ https://openregtech.github.io/sbom/ [R=303,NE,L]

## Default (curl, wget, unknown) -> Turtle

RewriteRule ^$ https://openregtech.github.io/sbom/sbom.ttl [R=303,NE,L]

# Sub-paths: https://w3id.org/sbom/<path>

## RDF clients -> GitHub Pages sub-path

RewriteCond %{HTTP_ACCEPT} text/turtle [OR]
RewriteCond %{HTTP_ACCEPT} application/rdf\+xml [OR]
RewriteCond %{HTTP_ACCEPT} application/ld\+json [OR]
RewriteCond %{HTTP_ACCEPT} application/n-triples
RewriteRule ^(.+)$ https://openregtech.github.io/sbom/$1 [R=303,NE,L]

## Browsers -> GitHub Pages sub-path

RewriteCond %{HTTP_ACCEPT} text/html [OR]
RewriteCond %{HTTP_ACCEPT} application/xhtml\+xml
RewriteRule ^(.+)$ https://openregtech.github.io/sbom/$1 [R=303,NE,L]

## Default -> GitHub Pages sub-path

RewriteRule ^(.+)$ https://openregtech.github.io/sbom/$1 [R=303,NE,L]
