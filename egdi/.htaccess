# Example
#
# https://w3id.org/egdi/project/<id> redirects to <LANDING_PAGE>/projects/<id>
#
# ## Contact
# This space is administered by:
# aljaz.srsa@geo-zs.si
# GitHub username: asrsa-geozs

RewriteEngine on

# Project endpoints
RewriteRule ^project/([0-9]+)/?$ https://ki-landing.gic.geo-zs.si/projects/$1 [R=302,L]

# New human-readable: author-year-libraryID-itemID
# e.g. reference/smith-2024-1234567-ABC12DEF
RewriteRule ^reference/[a-zA-Z]+-[0-9]{4}-([0-9]+)-([A-Z0-9]{8})/?$ https://ki-landing.gic.geo-zs.si/references/$1/$2 [R=302,L]

# Citation / reference endpoints 
RewriteRule ^reference/([0-9]+)/?$ https://ki-landing.gic.geo-zs.si/references/$1 [R=302,L]

# Expert endpoints
RewriteRule ^expert/([0-9]+)/?$ https://ki-landing.gic.geo-zs.si/experts/$1 [R=302,L]

# Organisation endpoints
RewriteRule ^organisation/([0-9]+)/?$ https://ki-landing.gic.geo-zs.si/organisations/$1 [R=302,L]

# Container / resource endpoints
RewriteRule ^resource/([0-9]+)/?$ https://ki-landing.gic.geo-zs.si/containers/$1 [R=302,L]
