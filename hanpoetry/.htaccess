Options +FollowSymLinks
RewriteEngine on

# Ontology
RewriteRule ^ontology$ https://raw.githubusercontent.com/TASYU78/Hanpoetry/main/Ontology/HanpoetryOntology.ttl [R=302,L]

# Vocabulary (SKOS)
RewriteRule ^concept/core$ https://raw.githubusercontent.com/TASYU78/Hanpoetry/main/Vocabulary/core/core_concepts.ttl [R=302,L]
RewriteRule ^concept/tang$ https://raw.githubusercontent.com/TASYU78/Hanpoetry/main/Vocabulary/tang/tang_concepts.ttl [R=302,L]
RewriteRule ^concept/heian$ https://raw.githubusercontent.com/TASYU78/Hanpoetry/main/Vocabulary/heian/heian_concepts.ttl [R=302,L]

# RDF datasets
RewriteRule ^resource/tang/collection$ https://raw.githubusercontent.com/TASYU78/Hanpoetry/main/Tang_db/RDF/Collection.ttl [R=302,L]

RewriteRule ^resource/tang/poem$ https://raw.githubusercontent.com/TASYU78/Hanpoetry/main/Tang_db/RDF/Poem.ttl [R=302,L]

RewriteRule ^resource/tang/person$ https://raw.githubusercontent.com/TASYU78/Hanpoetry/main/Tang_db/RDF/Person.ttl [R=302,L]

RewriteRule ^resource/tang/knowledge$ https://raw.githubusercontent.com/TASYU78/Hanpoetry/main/Tang_db/RDF/Knowledge.ttl [R=302,L]

RewriteRule ^resource/heian/collection$ https://raw.githubusercontent.com/TASYU78/Hanpoetry/main/Heian_db/RDF/Collection.ttl [R=302,L]

RewriteRule ^resource/heian/poem$ https://raw.githubusercontent.com/TASYU78/Hanpoetry/main/Heian_db/RDF/Poem.ttl [R=302,L]

RewriteRule ^resource/heian/person$ https://raw.githubusercontent.com/TASYU78/Hanpoetry/main/Heian_db/RDF/Person.ttl [R=302,L]

RewriteRule ^resource/heian/knowledge$ https://raw.githubusercontent.com/TASYU78/Hanpoetry/main/Heian_db/RDF/Knowledge.ttl [R=302,L]

# TEI resources (Heian)
RewriteRule ^resource/heian/tei/(.*)$ https://raw.githubusercontent.com/TASYU78/Hanpoetry/main/Heian_db/TEI/$1 [R=302,L]

# TEI resources (Tang)
RewriteRule ^resource/tang/tei/(.*)$ https://raw.githubusercontent.com/TASYU78/Hanpoetry/main/Tang_db/TEI/$1 [R=302,L]
