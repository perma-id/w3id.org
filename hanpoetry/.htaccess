Options +FollowSymLinks
RewriteEngine on

############################################
# Ontology
############################################

RewriteRule ^ontology$ https://raw.githubusercontent.com/TASYU78/Hanpoetry/main/Ontology/HanpoetryOntology.ttl [R=302,L]

############################################
# SKOS Vocabularies
############################################

RewriteRule ^concept/core(/.*)?$ https://raw.githubusercontent.com/TASYU78/Hanpoetry/main/Vocabulary/core/core_concepts.ttl [R=302,L]
RewriteRule ^concept/tang(/.*)?$ https://raw.githubusercontent.com/TASYU78/Hanpoetry/main/Vocabulary/tang/tang_concepts.ttl [R=302,L]
RewriteRule ^concept/heian(/.*)?$ https://raw.githubusercontent.com/TASYU78/Hanpoetry/main/Vocabulary/heian/heian_concepts.ttl [R=302,L]

############################################
# Tang RDF datasets
############################################

# Collection
RewriteRule ^resource/tang/collection$ https://raw.githubusercontent.com/TASYU78/Hanpoetry/main/Tang_db/RDF/Collection.ttl [R=302,L]
RewriteRule ^resource/tang/collection/([^/]+)$ https://raw.githubusercontent.com/TASYU78/Hanpoetry/main/Tang_db/RDF/Collection.ttl#$1 [R=302,L]

# Poem
RewriteRule ^resource/tang/poem$ https://raw.githubusercontent.com/TASYU78/Hanpoetry/main/Tang_db/RDF/Poem.ttl [R=302,L]
RewriteRule ^resource/tang/poem/([^/]+)$ https://raw.githubusercontent.com/TASYU78/Hanpoetry/main/Tang_db/RDF/Poem.ttl#$1 [R=302,L]

# Person
RewriteRule ^resource/tang/person$ https://raw.githubusercontent.com/TASYU78/Hanpoetry/main/Tang_db/RDF/Person.ttl [R=302,L]
RewriteRule ^resource/tang/person/([^/]+)$ https://raw.githubusercontent.com/TASYU78/Hanpoetry/main/Tang_db/RDF/Person.ttl#$1 [R=302,L]

# Knowledge
RewriteRule ^resource/tang/knowledge$ https://raw.githubusercontent.com/TASYU78/Hanpoetry/main/Tang_db/RDF/Knowledge.ttl [R=302,L]
RewriteRule ^resource/tang/knowledge/([^/]+)$ https://raw.githubusercontent.com/TASYU78/Hanpoetry/main/Tang_db/RDF/Knowledge.ttl#$1 [R=302,L]

# Manifestation
RewriteRule ^resource/tang/manifestation$ https://raw.githubusercontent.com/TASYU78/Hanpoetry/main/Tang_db/RDF/Manifestation.ttl [R=302,L]
RewriteRule ^resource/tang/manifestation/([^/]+)$ https://raw.githubusercontent.com/TASYU78/Hanpoetry/main/Tang_db/RDF/Manifestation.ttl#$1 [R=302,L]

# Range
RewriteRule ^resource/tang/range$ https://raw.githubusercontent.com/TASYU78/Hanpoetry/main/Tang_db/RDF/Range.ttl [R=302,L]
RewriteRule ^resource/tang/range/([^/]+)$ https://raw.githubusercontent.com/TASYU78/Hanpoetry/main/Tang_db/RDF/Range.ttl#$1 [R=302,L]

# Canvas
RewriteRule ^resource/tang/canvas$ https://raw.githubusercontent.com/TASYU78/Hanpoetry/main/Tang_db/RDF/Canvas.ttl [R=302,L]
RewriteRule ^resource/tang/canvas/([^/]+)$ https://raw.githubusercontent.com/TASYU78/Hanpoetry/main/Tang_db/RDF/Canvas.ttl#$1 [R=302,L]
############################################
# Heian RDF datasets
############################################

# Collection
RewriteRule ^resource/heian/collection$ https://raw.githubusercontent.com/TASYU78/Hanpoetry/main/Heian_db/RDF/Collection.ttl [R=302,L]
RewriteRule ^resource/heian/collection/([^/]+)$ https://raw.githubusercontent.com/TASYU78/Hanpoetry/main/Heian_db/RDF/Collection.ttl#$1 [R=302,L]

# Poem
RewriteRule ^resource/heian/poem$ https://raw.githubusercontent.com/TASYU78/Hanpoetry/main/Heian_db/RDF/Poem.ttl [R=302,L]
RewriteRule ^resource/heian/poem/([^/]+)$ https://raw.githubusercontent.com/TASYU78/Hanpoetry/main/Heian_db/RDF/Poem.ttl#$1 [R=302,L]

# Person
RewriteRule ^resource/heian/person$ https://raw.githubusercontent.com/TASYU78/Hanpoetry/main/Heian_db/RDF/Person.ttl [R=302,L]
RewriteRule ^resource/heian/person/([^/]+)$ https://raw.githubusercontent.com/TASYU78/Hanpoetry/main/Heian_db/RDF/Person.ttl#$1 [R=302,L]

# Knowledge
RewriteRule ^resource/heian/knowledge$ https://raw.githubusercontent.com/TASYU78/Hanpoetry/main/Heian_db/RDF/Knowledge.ttl [R=302,L]
RewriteRule ^resource/heian/knowledge/([^/]+)$ https://raw.githubusercontent.com/TASYU78/Hanpoetry/main/Heian_db/RDF/Knowledge.ttl#$1 [R=302,L]

# Manifestation
RewriteRule ^resource/heian/manifestation$ https://raw.githubusercontent.com/TASYU78/Hanpoetry/main/Heian_db/RDF/Manifestation.ttl [R=302,L]
RewriteRule ^resource/heian/manifestation/([^/]+)$ https://raw.githubusercontent.com/TASYU78/Hanpoetry/main/Heian_db/RDF/Manifestation.ttl#$1 [R=302,L]

# Range
RewriteRule ^resource/heian/range$ https://raw.githubusercontent.com/TASYU78/Hanpoetry/main/Heian_db/RDF/Range.ttl [R=302,L]
RewriteRule ^resource/heian/range/([^/]+)$ https://raw.githubusercontent.com/TASYU78/Hanpoetry/main/Heian_db/RDF/Range.ttl#$1 [R=302,L]

# Canvas
RewriteRule ^resource/heian/canvas$ https://raw.githubusercontent.com/TASYU78/Hanpoetry/main/Heian_db/RDF/Canvas.ttl [R=302,L]
RewriteRule ^resource/heian/canvas/([^/]+)$ https://raw.githubusercontent.com/TASYU78/Hanpoetry/main/Heian_db/RDF/Canvas.ttl#$1 [R=302,L]

############################################
# TEI Resources
############################################

RewriteRule ^resource/heian/tei/(.+)$ https://raw.githubusercontent.com/TASYU78/Hanpoetry/main/Heian_db/TEI/$1 [R=302,L]
RewriteRule ^resource/tang/tei/(.+)$ https://raw.githubusercontent.com/TASYU78/Hanpoetry/main/Tang_db/TEI/$1 [R=302,L]
