Header set Access-Control-Allow-Origin *
Header set Access-Control-Allow-Headers DNT,X-Mx-ReqToken,Keep-Alive,User-Agent,X-Requested-With,If-Modified-Since
Options +FollowSymLinks
RewriteEngine on

RewriteRule ^$ https://hse-ucd.github.io/ [R=302,L]

# @prefix phi: <https://w3id.org/hse/ontology/phi#>
RewriteRule ^ontology/phi$ https://hse-ucd.github.io/hse-ontology/phi [NE,R=302,L]
RewriteRule ^ontology/phi/$ https://hse-ucd.github.io/hse-ontology/phi [NE,R=302,L]

# @prefix phd: <https://w3id.org/hse/ontology/phd#>
RewriteRule ^ontology/phd$ https://hse-ucd.github.io/hse-ontology/phd [NE,R=302,L]
RewriteRule ^ontology/phd/$ https://hse-ucd.github.io/hse-ontology/phd [NE,R=302,L]

# @prefix pht: <https://w3id.org/hse/terminology#>
RewriteRule ^terminology$ https://hse-ucd.github.io/hse-terminology/ [NE,R=302,L]
RewriteRule ^terminology/$ https://hse-ucd.github.io/hse-terminology/ [NE,R=302,L]
