
Options +FollowSymLinks

RewriteEngine On

# Add redirect for testing via demo RVA server and using new W3ID domain: https://w3id.org/iucn-get/
RewriteRule ^(.*)$ https://demo.vocabs.ardc.edu.au/repository/api/lda/ands-nc/iucn-get-example/2-1/resource?uri=https://w3id.org/iucn-get/$1 [B,L,NE,QSA,R=307]