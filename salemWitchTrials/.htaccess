# 1. Enable Rewriting
RewriteEngine On

# 2. Redirect for the Knowledge Graph
RewriteRule ^graph(/.*)?$ https://hexwitches.github.io/salemWitchTrials/rdf_dataset/swt_graph.ttl [R=303,L]

# 3. Redirect for the Website Pages
RewriteRule ^([^/.]+)$ https://hexwitches.github.io/salemWitchTrials/$1.html [R=303,L]

# 4. Redirect for the Website Base
RewriteRule ^$ https://hexwitches.github.io/salemWitchTrials/ [R=303,L]
