Options +FollowSymLinks
RewriteEngine on

RewriteRule ^ontology\.ttl$ https://erdemonal.github.io/eautonome/eautonome.ttl [R=303,L]
RewriteRule ^dataset/?$ https://erdemonal.github.io/eautonome/dataset.ttl [R=303,L]
RewriteRule ^readme/?$ https://github.com/erdemonal/eautonome/blob/main/README.md [R=303,L]

RewriteRule ^/?$ https://erdemonal.github.io/eautonome/index.html [R=303,L]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^([a-zA-Z0-9_-]+)$ https://erdemonal.github.io/eautonome/index.html [R=303,L]
