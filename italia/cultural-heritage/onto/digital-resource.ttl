@prefix dr: <https://w3id.org/italia/cultural-heritage/ontology/digital-resource/> .
@prefix l0: <https://w3id.org/italia/onto/l0/> .
@prefix ns: <http://www.w3.org/2006/vcard/ns#> .
@prefix sm: <https://w3id.org/italia/onto/SM/> .
@prefix ti: <https://w3id.org/italia/onto/TI/> .
@prefix crm: <http://www.cidoc-crm.org/cidoc-crm/> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix dul: <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix admsapit: <https://w3id.org/italia/onto/ADMS/> .
@prefix arco: <https://w3id.org/arco/ontology/arco/> .
@prefix core: <https://w3id.org/arco/ontology/core/> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix a-cat: <https://w3id.org/arco/ontology/catalogue/> .
@prefix a-lite: <https://w3id.org/arco/ontology/arco-lite/> .
@prefix crmdig: <http://www.cidoc-crm.org/extensions/crmdig/> .
@base <https://w3id.org/italia/cultural-heritage/ontology/digital-resource/> .

<https://w3id.org/italia/cultural-heritage/ontology/digital-resource/> rdf:type owl:Ontology ;
                                                                        owl:imports <https://w3id.org/italia/onto/l0> ;
                                                                        dct:accrualPeriodicity <http://publications.europa.eu/resource/authority/frequency/IRREG> ;
                                                                        dct:creator <https://w3id.org/italia/cultural-heritage/data/private-organisation/13866741005> ,
                                                                                    <https://w3id.org/italia/cultural-heritage/data/public-organization/m_bac-D390VG> ;
                                                                        dct:description "Questa ontologia consente di rappresentare dati relativi alle risorse digitali sviluppati all'interno del sistema IPAC della Digital Library (ICDP)."@it ,
                                                                                        "This ontology enables the representation of master data of digital resources developed in the Digital Library's IPAC system (ICDP)."@en ;
                                                                        dct:identifier "https://w3id.org/italia/cultural-heritage/ontology/digital-resource" ;
                                                                        dct:issued "2025-07-24"^^xsd:date ;
                                                                        dct:language <http://publications.europa.eu/resource/authority/language/ENG> ,
                                                                                      <http://publications.europa.eu/resource/authority/language/ITA> ;
                                                                        dct:modified "2025-03-19"^^xsd:date ;
                                                                        dct:publisher <https://w3id.org/italia/cultural-heritage/data/public-organization/m_bac-D390VG> ;
                                                                        dct:rightsHolder <https://w3id.org/italia/cultural-heritage/data/public-organization/m_bac-D390VG> ;
                                                                        dct:title "Digital Resource Ontology"@en ,
                                                                                  "Ontologia delle risorse digitali"@it ;
                                                                        rdfs:comment "Questa ontologia consente di rappresentare dati relativi alle risorse digitali sviluppati all'interno del sistema IPAC della Digital Library (ICDP)."@it ,
                                                                                      "This ontology enables the representation of master data of digital resources developed in the Digital Library's IPAC system (ICDP)."@en ;
                                                                        rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
                                                                        rdfs:label "Digital Resource Ontology"@en ,
                                                                                    "Ontologia delle risorse digitali"@it ;
                                                                        owl:versionInfo "Version 0.1 - creation of the ontology"@en ,
                                                                                        "Versione 0.1 - creazione dell'ontologia"@it ;
                                                                        dcat:contactPoint <https://w3id.org/italia/cultural-heritage/data/contact-point/m_bac-D390VG> ;
                                                                        dcat:keyword "digital library"@en ,
                                                                                      "digital resource"@en ,
                                                                                      "distribution"@en ,
                                                                                      "manifest"@en ,
                                                                                      "risorse multimediali"@it ;
                                                                        dcat:theme <http://publications.europa.eu/resource/authority/data-theme/EDUC> ;
                                                                        admsapit:acronym "DR" ;
                                                                        admsapit:hasFormalityLevel admsapit:Formal ;
                                                                        admsapit:hasKeyClass dr:CreativeDigitalResource ,
                                                                                              dr:DigitalCollection ,
                                                                                              dr:DigitalResource ,
                                                                                              dr:DigitalResourceDistribution ,
                                                                                              dr:Manifest ,
                                                                                              dr:Structure ;
                                                                        admsapit:hasOntologyLanguage admsapit:OWL ;
                                                                        admsapit:hasSemanticAssetDistribution <https://w3id.org/italia/cultural-heritage/data/distribution/DR-RDF-TURTLE> ,
                                                                                                              <https://w3id.org/italia/cultural-heritage/data/distribution/DR-RDF-XML> ;
                                                                        admsapit:hasTask admsapit:AnnotationTask ,
                                                                                          admsapit:QueryFormulationTask ;
                                                                        admsapit:officialURI "https://w3id.org/italia/cultural-hertigate/onto/digital-resource"^^xsd:anyURI ;
                                                                        admsapit:prefix "ch-dr" ;
                                                                        admsapit:status "draft" ;
                                                                        admsapit:target "Cittadini"@it ,
                                                                                        "Imprese"@it ,
                                                                                        "Pubbliche Amministrazioni"@it ;
                                                                        admsapit:type admsapit:DomainOntology .

#################################################################
#    Annotation properties
#################################################################

###  https://w3id.org/arco/ontology/catalogue/iccdNormTag
a-cat:iccdNormTag rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  http://purl.org/dc/terms/license
dct:license rdf:type owl:ObjectProperty .


###  https://w3id.org/arco/ontology/core/hasConcept
core:hasConcept rdf:type owl:ObjectProperty .


###  https://w3id.org/arco/ontology/core/hasType
core:hasType rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf core:hasConcept ;
             owl:inverseOf core:isTypeOf ;
             rdfs:domain owl:Thing ;
             rdfs:range core:Type ;
             rdfs:comment "La object property che associa un qualunque oggetto a un tipo."@it ,
                          "The object property that associates any object with a type."@en ;
             rdfs:isDefinedBy <https://w3id.org/arco/ontology/core> ;
             rdfs:label "ha tipo"@it ,
                        "has type"@en ;
             owl:versionInfo "stabile"@it ,
                             "stable"@en .


###  https://w3id.org/arco/ontology/core/isConceptOf
core:isConceptOf rdf:type owl:ObjectProperty .


###  https://w3id.org/arco/ontology/core/isTypeOf
core:isTypeOf rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf core:isConceptOf ;
              rdfs:domain core:Type ;
              rdfs:range owl:Thing ;
              rdfs:comment "La object property che associa un tipo a un qualunque oggetto."@it ,
                           "The object property that associates a type to any object."@en ;
              rdfs:isDefinedBy <https://w3id.org/arco/ontology/core> ;
              rdfs:label "is type of"@en ,
                         "è tipo di"@it ;
              owl:versionInfo "stabile"@it ,
                              "stable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/belongsToStructure
dr:belongsToStructure rdf:type owl:ObjectProperty ;
                      owl:inverseOf dr:includesDigitalResource ;
                      rdfs:domain dr:DigitalResource ;
                      rdfs:range dr:Structure ;
                      rdfs:comment "Questa proprietà rappresenta la relazione che collega una risorsa digitale alla struttura, fisica o logica, che la descrive. "@it ,
                                   "This property represents the relationship that links a digital resource to the structure, physical or logical, that describes it."@en ;
                      rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
                      rdfs:label "appartiene a struttura"@it ,
                                 "belongs to structure"@en ;
                      owl:versionInfo "instabile"@it ,
                                      "instable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/hasAssociatedDigitalResource
dr:hasAssociatedDigitalResource rdf:type owl:ObjectProperty ;
                                rdfs:subPropertyOf dr:hasDigitalResource ;
                                owl:inverseOf dr:isAssociatedDigitalResourceOf ;
                                rdfs:domain l0:Entity ;
                                rdfs:range dr:DigitalResource ;
                                rdfs:comment "Questa proprietà rappresenta la relazione tra una qualsiasi entità e una risorsa digitale a lei associata."@it ,
                                             "This property represents the relationship between any entity and its associated digital asset."@en ;
                                rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
                                rdfs:label "ha risorsa digitale associata"@it ,
                                           "has associated digital resource"@en ;
                                owl:versionInfo "instabile"@it ,
                                                "instable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/hasChecksum
dr:hasChecksum rdf:type owl:ObjectProperty ;
               owl:inverseOf dr:isChecksumOf ;
               rdfs:domain dr:DigitalResourceDistribution ;
               rdfs:range dr:Checksum ;
               rdfs:comment "Questa proprietà rappresenta la relazione che collega la classe DistribuzioneRisorsaDigitale al meccanismo che permette di verificare che il contenuto di una distribuzione non sia stato modificato (Checksum)."@it ,
                            "This property represents the relationship that connects the DistribuzioneRisorsaDigitale class to the mechanism that allows you to verify that the contents of a distribution have not been modified (Checksum)."@en ;
               rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
               rdfs:label "ha checksum"@it ,
                          "has checksum"@en ;
               owl:versionInfo "instabile"@it ,
                               "instable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/hasContent
dr:hasContent rdf:type owl:ObjectProperty ;
              owl:inverseOf dr:isContentOf ;
              rdfs:domain dr:CreativeDigitalResource ;
              rdfs:range dr:CreativeDigitalResource ;
              rdfs:comment "Questa proprietà rappresenta la relazione che collega la risorsa digitale intellettuale (ad esempio il capitolo di un libro) a un’altra risorsa digitale intellettuale contenuta in essa (ad esempio un paragrafo di quel capitolo)."@it ,
                           "This property represents the relationship that connects the digital intellectual resource (for example, a book chapter) to another digital intellectual resource contained within it (for example, a paragraph in that chapter)."@en ;
              rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
              rdfs:label "ha contenuto"@it ,
                         "has content"@en ;
              owl:versionInfo "instabile"@it ,
                              "instable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/hasContentDerivation
dr:hasContentDerivation rdf:type owl:ObjectProperty ;
                        owl:inverseOf dr:isContentDerivationOf ;
                        rdfs:domain dr:DigitalResourceDistribution ;
                        rdfs:range dr:ContentDerivation ;
                        rdfs:comment "Questa proprietà rappresenta la relazione che collega la distribuzione di una risorsa digitale con un contenuto derivato."@it ,
                                     "This property represents the relationship that links the distribution of a digital resource with a content derivation"@en ;
                        rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
                        rdfs:label "ha derivazione di contenuto"@it ,
                                   "has content derivation"@en ;
                        owl:versionInfo "instabile"@it ,
                                        "instable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/hasCoverImage
dr:hasCoverImage rdf:type owl:ObjectProperty ;
                 owl:inverseOf dr:isCoverImageOf ;
                 rdfs:domain dr:CreativeDigitalResource ;
                 rdfs:range dr:DigitalResource ;
                 rdfs:comment "Questa proprietà rappresenta la relazione che collega una risorsa digitale intellettuale alla risorsa digitale che funge da immagine di copertina."@it ,
                              "This property represents the relationship that connects a digital intellectual asset to the digital asset that serves as its cover image."@en ;
                 rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
                 rdfs:label "ha immagine di copertina"@it ,
                            "has cover image"@en ;
                 owl:versionInfo "instabile"@it ,
                                 "instable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/hasDerivedContent
dr:hasDerivedContent rdf:type owl:ObjectProperty ;
                     owl:inverseOf dr:isDerivedContentOf ;
                     rdfs:domain dr:ContentDerivation ;
                     rdfs:range dr:DigitalResourceDistribution ;
                     rdfs:comment "Questa proprietà rappresenta la relazione che collega una derivazione di contenuto a una nuova distribuzione della risorsa digitale derivata da processi di elaborazione automatica."@it ,
                                  "This property represents the relationship that links a content derivation to a new distribution of the digital resource derived from automatic processing."@en ;
                     rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
                     rdfs:label "ha contenuto derivato"@it ,
                                "has derived content"@en ;
                     owl:versionInfo "instabile"@it ,
                                     "instable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/hasDerivedEntity
dr:hasDerivedEntity rdf:type owl:ObjectProperty ;
                    owl:inverseOf dr:isDerivedEntityOf ;
                    rdfs:domain dr:EntityDerivation ;
                    rdfs:range l0:Entity ;
                    rdfs:comment "Questa proprietà rappresenta la relazione che collega la risorsa digitale con qualsiasi entità del mondo che è derivata, attraverso diverse tecniche di estrazione, dalla risorsa digitale."@it ,
                                 "This property represents the relationship that connects the digital asset with any entity in the world that is derived, through various extraction techniques, from the digital resource."@en ;
                    rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
                    rdfs:label "ha entità derivata"@it ,
                               "has derived entity"@en ;
                    owl:versionInfo "instabile"@it ,
                                    "instable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/hasDigitalResource
dr:hasDigitalResource rdf:type owl:ObjectProperty ;
                      owl:inverseOf dr:isDigitalResourceOf ;
                      rdfs:domain l0:Entity ;
                      rdfs:range dr:DigitalResource ;
                      rdfs:comment "Questa proprietà rappresenta la relazione che collega un’entità generica con una risorsa digitale correlata. Si specifica con le sottoproprietà haRisorsaDigitaleAssociata e haRisorsaDigitaleReferenziata se il collegamento è di associazione o referenza."@it ,
                                   "This property represents the relationship between a generic entity and a related digital resource. The hasAssociatedDigitalResource and hasReferencedDigitalResource subproperties specify whether the link is an association or a reference link."@en ;
                      rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
                      rdfs:label "ha risorsa digitale"@it ,
                                 "has digital resource"@en ;
                      owl:versionInfo "instabile"@it ,
                                      "instable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/hasDistribution
dr:hasDistribution rdf:type owl:ObjectProperty ;
                   owl:inverseOf dr:isDistributionOf ;
                   rdfs:domain dr:DigitalResource ;
                   rdfs:range dr:DigitalResourceDistribution ;
                   rdfs:comment "Questa proprietà rappresenta la relazione che lega la risorsa digitale a una specifica rappresentazione della stessa."@it ,
                                "This property represents the relationship that links the digital resource to a specific representation of it."@en ;
                   rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
                   rdfs:label "ha distribuzione"@it ,
                              "has distribution"@en ;
                   owl:versionInfo "instabile"@it ,
                                   "instable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/hasEntityDerivation
dr:hasEntityDerivation rdf:type owl:ObjectProperty ;
                       owl:inverseOf dr:isEntityDerivationOf ;
                       rdfs:domain dr:DigitalResource ;
                       rdfs:range dr:EntityDerivation ;
                       rdfs:comment "Questa proprietà rappresenta la relazione che lega una risorsa digitale a una derivazione di entità."@it ,
                                    "This property represents the relationship that binds a digital asset to an entity derivation."@en ;
                       rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
                       rdfs:label "ha derivazione di entità"@it ,
                                  "has entity derivation"@en ;
                       owl:versionInfo "instabile"@it ,
                                       "instable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/hasExtractionTechnique
dr:hasExtractionTechnique rdf:type owl:ObjectProperty ;
                          owl:inverseOf dr:isExtractionTechniqueOf ;
                          rdfs:domain dr:EntityDerivation ;
                          rdfs:range dr:ExtractionTechnique ;
                          rdfs:comment "Questa proprietà rappresenta la relazione che lega una derivazione di entità a una sua tecnica di estrazione."@it ,
                                       "This property represents the relationship between an entity derivation and its extraction technique."@en ;
                          rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
                          rdfs:label "ha tecnica di estrazione"@it ,
                                     "has extraction technique"@en ;
                          owl:versionInfo "instabile"@it ,
                                          "instable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/hasIncludingSituation
dr:hasIncludingSituation rdf:type owl:ObjectProperty ;
                         owl:inverseOf dr:isIncludingSituationOf ;
                         rdfs:domain dr:CreativeDigitalResource ;
                         rdfs:comment "Questa proprietà rappresenta la relazione tra una risorsa digitale intellettuale e una situazione di inclusione che permette di affermare che una risorsa digitale è inclusa in una risorsa digitale intellettuale."@it ,
                                      "This property represents the relationship between a creative digital resource and an inclusion situation that allows to affirm that a digital resource is included in an intellectual digital resource."@en ;
                         rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
                         rdfs:label "ha situazione di inclusione"@it ,
                                    "has including situation"@en ;
                         owl:versionInfo "instabile"@it ,
                                         "instable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/hasMediaType
dr:hasMediaType rdf:type owl:ObjectProperty ;
                owl:inverseOf dr:isMediaTypeOf ;
                rdfs:domain dr:DigitalResourceDistribution ;
                rdfs:range dr:MediaType ;
                rdfs:comment "Questa proprietà collega una distribuzione al suo tipo di file."@it ,
                             "This property relates a digital resource distribution to its media type."@en ;
                rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
                rdfs:label "ha tipo di media"@it ,
                           "has media type"@en ;
                owl:versionInfo "instabile"@it ,
                                "unstable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/hasObjectOfRelation
dr:hasObjectOfRelation rdf:type owl:ObjectProperty ;
                       owl:inverseOf dr:isObjectOfRelation ;
                       rdfs:domain dr:NamedRelation ;
                       rdfs:range owl:Thing ;
                       rdfs:comment "Questa relazione collega una NamedRelation, la reificazione di una relazione tra entità, con il suo oggetto."@it ,
                                    "This relationship relates a NamedRelation, the reification of a relationship between entities, with its object."@en ;
                       rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
                       rdfs:label "ha oggetto di relazione"@it ,
                                  "has object of relation"@en ;
                       owl:versionInfo "instabile"@it ,
                                       "unstable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/hasReferencedDigitalResource
dr:hasReferencedDigitalResource rdf:type owl:ObjectProperty ;
                                rdfs:subPropertyOf dr:hasDigitalResource ;
                                owl:inverseOf dr:isReferencedDigitalResourceOf ;
                                rdfs:domain l0:Entity ;
                                rdfs:range dr:DigitalResource ;
                                rdfs:comment "Questa proprietà rappresenta la relazione tra un'entità e una precisa risorsa digitale."@it ,
                                             "This property represents the relationship between an entity and a specific digital resource."@en ;
                                rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
                                rdfs:label "ha risorsa digitale referenziata"@it ,
                                           "has referenced digital resource"@en ;
                                owl:versionInfo "instabile"@it ,
                                                "instable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/hasStartingSituation
dr:hasStartingSituation rdf:type owl:ObjectProperty ;
                        owl:inverseOf dr:isStartingSituationOf ;
                        rdfs:domain dr:CreativeDigitalResource ;
                        rdfs:comment "Questa proprietà rappresenta la relazione che collega una risorsa digitale intellettuale a una situazione di inizio."@it ,
                                     "This property represents the relationship that connects a creative digital resource to an starting situation."@en ;
                        rdfs:isDefinedBy "https://w3id.org/italia/cultural-heritage/ontology/digital-resource"@en ;
                        rdfs:label "ha situazione di inizio"@it ,
                                   "has starting situation"@en ;
                        owl:versionInfo "instabile"@it ,
                                        "instable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/hasStructure
dr:hasStructure rdf:type owl:ObjectProperty ;
                owl:inverseOf dr:isStructureOf ;
                rdfs:domain dr:CreativeDigitalResource ;
                rdfs:range dr:Structure ;
                rdfs:comment "Questa proprietà rappresenta la relazione che collega una risorsa digitale intellettuale alla struttura, logica o fisica, che la descrive."@it ,
                             "This property represents the relationship that connects a creative digital resource to the structure, logical or physical, that describes it."@en ;
                rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
                rdfs:label "ha struttura"@it ,
                           "has structure"@en ;
                owl:versionInfo "instabile"@it ,
                                "instable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/hasSubjectOfRelation
dr:hasSubjectOfRelation rdf:type owl:ObjectProperty ;
                        owl:inverseOf dr:isSubjectOfRelation ;
                        rdfs:domain dr:NamedRelation ;
                        rdfs:range owl:Thing ;
                        rdfs:comment "Questa relazione collega una NamedRelation, la reificazione di una relazione tra entità, con il suo soggetto."@it ,
                                     "This relationship relates a NamedRelation, the reification of a relationship between entities, with its subject."@en ;
                        rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
                        rdfs:label "ha soggetto di relazione"@it ,
                                   "has subject of relation"@en ;
                        owl:versionInfo "instabile"@it ,
                                        "unstable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/includes
dr:includes rdf:type owl:ObjectProperty ;
            owl:inverseOf dr:isIncludedIn ;
            rdfs:range dr:DigitalResource ;
            rdfs:comment "Questa proprietà rappresenta la relazione che collega una risorsa digitale intellettuale alla risorsa digitale contenuta in essa, inserendo le coordinate nell’attributo di relazione è possibile specificare il preciso punto di inizio."@it ,
                         "This property represents the relationship that connects a creative digital resource to the digital resource contained within it. By entering the coordinates in the relationship attribute, it is possible to specify the precise starting point."@en ;
            rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
            rdfs:label "include"@it ,
                       "includes"@en ;
            owl:versionInfo "instabile"@it ,
                            "instable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/includesDigitalResource
dr:includesDigitalResource rdf:type owl:ObjectProperty ;
                           rdfs:domain dr:Structure ;
                           rdfs:range dr:DigitalResource ;
                           rdfs:comment "Questa proprietà rappresenta la relazione che collega la struttura e la risorsa digitale che iclude."@it ,
                                        "This property represents the relationship that links the structure and the digital resource it includes."@en ;
                           rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
                           rdfs:label "include risorsa digitale"@it ,
                                      "includes digital resource"@en ;
                           owl:priorVersion "instabile"@it ,
                                            "instable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/isAssociatedDigitalResourceOf
dr:isAssociatedDigitalResourceOf rdf:type owl:ObjectProperty ;
                                 rdfs:subPropertyOf dr:isDigitalResourceOf ;
                                 rdfs:domain dr:DigitalResource ;
                                 rdfs:range l0:Entity ;
                                 rdfs:comment "Questa proprietà rappresenta la relazione tra una risorsa digitale associata a una qualsiasi entità del mondo."@it ,
                                              "This property represents the relationship between a digital resource associated with any entity in the world."@en ;
                                 rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
                                 rdfs:label "is associated digital resource of"@en ,
                                            "è risorsa digitale associata di"@it ;
                                 owl:versionInfo "instabile"@it ,
                                                 "instable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/isChecksumOf
dr:isChecksumOf rdf:type owl:ObjectProperty ;
                rdfs:domain dr:Checksum ;
                rdfs:range dr:DigitalResourceDistribution ;
                rdfs:comment "Questa proprietà rappresenta la relazione che collega il checksum (meccanismo che può essere utilizzato per verificare che il contenuto di una distribuzione non sia stato modificato) alla distribuzione della risorsa digitale."@it ,
                             "This property represents the relationship between the checksum (a mechanism that can be used to verify that the contents of a distribution have not been modified) and the distribution of the digital resource."@en ;
                rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
                rdfs:label "is checksum of"@en ,
                           "è checksum di"@it ;
                owl:versionInfo "instabile"@it ,
                                "instable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/isContentDerivationOf
dr:isContentDerivationOf rdf:type owl:ObjectProperty ;
                         rdfs:domain dr:ContentDerivation ;
                         rdfs:range dr:DigitalResourceDistribution ;
                         rdfs:comment "Questa proprietà rappresenta la relazione che collega un contenuto derivato alla distribuzione di una risorsa digitale."@it ,
                                      "This property represents the relationship that links a content derivation to the distribution of a digital resource."@en ;
                         rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
                         rdfs:label "is content derivation of"@en ,
                                    "è derivazione di contenuto di"@it ;
                         owl:versionInfo "instabile"@it ,
                                         "instable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/isContentOf
dr:isContentOf rdf:type owl:ObjectProperty ;
               rdfs:domain dr:CreativeDigitalResource ;
               rdfs:range dr:CreativeDigitalResource ;
               rdfs:comment "Questa proprietà rappresenta la relazione che collega una risorsa digitale intellettuale (ad esempio un paragrafo di un capitolo di un libro) a un’altra risorsa digitale intellettuale che la contiene (ad esempio il capitolo di quel libro)."@it ,
                            "This property represents the relationship that connects a creative digital resource (for example, a paragraph in a book chapter) to another creative digital resource that contains it (for example, the chapter in that book)."@en ;
               rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
               rdfs:label "is content of"@en ,
                          "è contenuto di"@it ;
               owl:versionInfo "instabile"@it ,
                               "instable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/isCoverImageOf
dr:isCoverImageOf rdf:type owl:ObjectProperty ;
                  rdfs:domain dr:DigitalResource ;
                  rdfs:range dr:CreativeDigitalResource ;
                  rdfs:comment "Questa proprietà rappresenta la relazione che collega una risorsa digitale che funge da immagine di copertina  alla sua risorsa digitale intellettuale."@it ,
                               "This property represents the relationship between a digital resource that serves as a cover image and its creative digital resource."@en ;
                  rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
                  rdfs:label "is cover image of"@en ,
                             "è immagine di copertina di"@it ;
                  owl:versionInfo "instabile"@it ,
                                  "instable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/isDerivedContentOf
dr:isDerivedContentOf rdf:type owl:ObjectProperty ;
                      rdfs:domain dr:DigitalResourceDistribution ;
                      rdfs:range dr:ContentDerivation ;
                      rdfs:comment "Questa proprietà rappresenta la relazione che collega una nuova distribuzione della risorsa digitale derivata da processi di elaborazione automatica alla derivazione di contenuto."@en ,
                                   "This property represents the relationship that links a new distribution of the digital resource derived from automatic processing to the derivation of content."@en ;
                      rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
                      rdfs:label "is derived content of"@en ,
                                 "è derivazione di contenuto di"@it ;
                      owl:versionInfo "instabilr"@it ,
                                      "instable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/isDerivedEntityOf
dr:isDerivedEntityOf rdf:type owl:ObjectProperty ;
                     rdfs:domain l0:Entity ;
                     rdfs:range dr:EntityDerivation ;
                     rdfs:comment "Questa proprietà rappresenta la relazione che collega qualsiasi entità del mondo a una derivazione di entità, ottenuta attraverso diverse tecniche di estrazione."@it ,
                                  "This property represents the relationship that connects any entity in the world to an entity derivation, obtained through various extraction techniques."@en ;
                     rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
                     rdfs:label "is derived entity of"@en ,
                                "è entità derivata di"@it ;
                     owl:versionInfo "instabile"@it ,
                                     "instable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/isDigitalResourceOf
dr:isDigitalResourceOf rdf:type owl:ObjectProperty ;
                       rdfs:domain dr:DigitalResource ;
                       rdfs:range l0:Entity ;
                       rdfs:comment "Questa proprietà rappresenta la relazione che collega una risorsa digitale correlata a un’entità generica. Si specifica con le sottoproprietà inverse eRisorsaDigitaleAssociataDi e eRisorsaDigitaleReferenziataDi, se il collegamento è di associazione o referenza."@it ,
                                    "This property represents the relationship between a related digital resource and a generic entity. It is specified with the inverse subproperties isReferencedDigitalResourceOf and isAssociatedDigitalResourceOf, whether the link is an association or a reference."@en ;
                       rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
                       rdfs:label "is digital resource of"@en ,
                                  "è risorsa digitale di"@it ;
                       owl:versionInfo "instabile"@it ,
                                       "instable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/isDistributionOf
dr:isDistributionOf rdf:type owl:ObjectProperty ;
                    rdfs:domain dr:DigitalResourceDistribution ;
                    rdfs:range dr:DigitalResource ;
                    rdfs:comment "Questa proprietà rappresenta la relazione che lega una specifica rappresentazione di una risorsa digitale ad essa."@it ,
                                 "This property represents the relationship that binds a specific representation of a digital resource to it."@en ;
                    rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
                    rdfs:label "is distribution of"@en ,
                               "è distribuzione di"@it ;
                    owl:versionInfo "instabile"@it ,
                                    "instable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/isEntityDerivationOf
dr:isEntityDerivationOf rdf:type owl:ObjectProperty ;
                        rdfs:domain dr:EntityDerivation ;
                        rdfs:range dr:DigitalResource ;
                        rdfs:comment "Questa proprietà rappresenta la relazione che lega una derivazione di entità a una risorsa digitale."@it ,
                                     "This property represents the relationship that binds an entity derivation to a digital asset."@en ;
                        rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
                        rdfs:label "is entity derivation of"@en ,
                                   "è derivazione di entità di"@it ;
                        owl:versionInfo "instabile"@it ,
                                        "instable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/isExtractionTechniqueOf
dr:isExtractionTechniqueOf rdf:type owl:ObjectProperty ;
                           rdfs:domain dr:ExtractionTechnique ;
                           rdfs:range dr:EntityDerivation ;
                           rdfs:comment "Questa proprietà rappresenta la relazione che lega una tecnica di estrazione applicata a una derivazione di entità."@it ,
                                        "This property represents the relationship between an extraction technique applied to an entity derivation."@en ;
                           rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
                           rdfs:label "is extraction technique of"@en ,
                                      "è tecnica di estrazione di"@it ;
                           owl:versionInfo "instabile"@it ,
                                           "instable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/isIncludedIn
dr:isIncludedIn rdf:type owl:ObjectProperty ;
                rdfs:domain dr:DigitalResource ;
                rdfs:comment "Questa proprietà rappresenta la relazione che collega una risorsa digitale alla risorsa digitale intellettuale che contiene attraverso una situazione di inclusione."@it ,
                             "This property represents the relationship that connects a digital resource to the intellectual digital resource it contains through a situation of inclusion."@en ;
                rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
                rdfs:label "is included in"@en ,
                           "è incluso in"@it ;
                owl:versionInfo "instabile"@it .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/isIncludingSituationOf
dr:isIncludingSituationOf rdf:type owl:ObjectProperty ;
                          rdfs:range dr:CreativeDigitalResource ;
                          rdfs:comment "Questa proprietà rappresenta la relazione tra una situazione di inclusione e una risorsa digitale intellettuale. La relazione permette di affermare che una risorsa digitale intellettuale può contenere una risorsa digitale."@it ,
                                       "This property represents the relationship between an including situation and a creative digital resource. This relationship allows us to state that an intellectual digital resource can contain a digital resource."@en ;
                          rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
                          rdfs:label "is including situation of"@en ,
                                     "è situazione di inclusione di"@it ;
                          owl:versionInfo "instabile"@it ,
                                          "instable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/isMediaTypeOf
dr:isMediaTypeOf rdf:type owl:ObjectProperty ;
                 rdfs:domain dr:MediaType ;
                 rdfs:range dr:DigitalResourceDistribution ;
                 rdfs:comment "Questa è la proprietà inversa di \"ha tipo di media\"."@it ,
                              "This is the inverse property of \"has media type\"."@en ;
                 rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
                 rdfs:label "is media type of"@en ,
                            "è tipo di media di"@it ;
                 owl:versionInfo "instabile"@it ,
                                 "unstable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/isObjectOfRelation
dr:isObjectOfRelation rdf:type owl:ObjectProperty ;
                      rdfs:domain owl:Thing ;
                      rdfs:range dr:NamedRelation ;
                      rdfs:comment "Questa è la proprietà inversa di \"has object of relation\"."@it ,
                                   "This is the inverse property of \"has object of relation\"."@en ;
                      rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
                      rdfs:label "is object of relation"@en ,
                                 "è oggetto di relazione"@it ;
                      owl:versionInfo "instabile"@it ,
                                      "unstable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/isReferencedDigitalResourceOf
dr:isReferencedDigitalResourceOf rdf:type owl:ObjectProperty ;
                                 rdfs:subPropertyOf dr:isDigitalResourceOf ;
                                 rdfs:domain dr:DigitalResource ;
                                 rdfs:range l0:Entity ;
                                 rdfs:comment "Questa proprietà rappresenta la relazione tra una risorsa digitale che referenzia una qualsiasi entità del mondo."@it ,
                                              "This property represents the relationship between a digital resource that references any entity in the world."@en ;
                                 rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
                                 rdfs:label "is referenced digital resource of"@en ,
                                            "è risorsa digitale referenziata di"@it ;
                                 owl:versionInfo "instabile"@it ,
                                                 "instable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/isStartOf
dr:isStartOf rdf:type owl:ObjectProperty ;
             owl:inverseOf dr:startsWith ;
             rdfs:domain dr:DigitalResource ;
             rdfs:comment "Questa proprietà rappresenta una relazione che collega una risorsa digitale da cui parte il contenuto creativo alla risorsa digitale intellettuale che ospita quel contenuto, inserendo le coordinate digitali è possibile specificare il preciso punto di inizio."@it ,
                          "This property represents a relationship that connects a digital resource from which the creative content starts to the creative digital resource that hosts that content. By entering the digital coordinates, it is possible to specify the precise starting point."@en ;
             rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
             rdfs:label "is start of"@en ,
                        "è inizio di"@it ;
             owl:versionInfo "instabile"@it ,
                             "instable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/isStartingSituationOf
dr:isStartingSituationOf rdf:type owl:ObjectProperty ;
                         rdfs:range dr:CreativeDigitalResource ;
                         rdfs:comment "Questa proprietà rappresenta la relazione che collega una situazione di inizio a una risorsa digitale intellettuale."@it ,
                                      "This property represents the relationship that connects an inception situation to a creative digital resource."@en ;
                         rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
                         rdfs:label "is starting situation of"@en ,
                                    "è situazione di inizio di"@it ;
                         owl:versionInfo "instabile"@it ,
                                         "instable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/isStructureOf
dr:isStructureOf rdf:type owl:ObjectProperty ;
                 rdfs:domain dr:Structure ;
                 rdfs:range dr:CreativeDigitalResource ;
                 rdfs:comment "Questa proprietà rappresenta la relazione che collega una struttura, logica o fisica, che descrive una risorsa digitale intellettuale."@it ,
                              "This property represents the relationship that connects a structure, logical or physical, that describes a cultural digital resource."@en ;
                 rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
                 rdfs:label "is structure of"@en ,
                            "è struttura di"@it ;
                 owl:versionInfo "instabile"@it ,
                                 "instable"@it .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/isSubjectOfRelation
dr:isSubjectOfRelation rdf:type owl:ObjectProperty ;
                       rdfs:domain owl:Thing ;
                       rdfs:range dr:NamedRelation ;
                       rdfs:comment "Questa proprietà è l'inversa di \"has subject of relation\"."@it ,
                                    "This is the inverse property of \"has subject of relation\"."@en ;
                       rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
                       rdfs:label "is subject of relation"@en ,
                                  "è soggetto di relazione"@it ;
                       owl:versionInfo "instabile"@it ,
                                       "unstable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/startsWith
dr:startsWith rdf:type owl:ObjectProperty ;
              rdfs:range dr:DigitalResource ;
              rdfs:comment "Questa classe rappresenta una relazione che collega una risorsa digitale intellettuale alla risorsa digitale da cui parte il contenuto creativo, inserendo le coordinate nell’attributo di relazione è possibile specificare il preciso punto di inizio."@it ,
                           "This class represents a relationship that connects an intellectual digital asset to the digital asset from which the creative content starts. By inserting the coordinates in the relationship attribute, it is possible to specify the precise starting point."@en ;
              rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
              rdfs:label "inizia da"@it ,
                         "starts with"@en ;
              owl:versionInfo "instabile"@it ,
                              "instable"@en .


###  https://w3id.org/italia/onto/TI/hasTemporalEntity
ti:hasTemporalEntity rdf:type owl:ObjectProperty ;
                     owl:inverseOf ti:isTemporalEntityOf ;
                     rdfs:domain owl:Thing ;
                     rdfs:range ti:TemporalEntity ;
                     rdfs:comment "Property that links a time indexed event to a temporal entity."@en ,
                                  "Proprietà che collega un evento nel tempo ad un entità temporale."@it ;
                     rdfs:isDefinedBy <https://w3id.org/italia/onto/TI> ;
                     rdfs:label "ha entità temporale"@it ,
                                "has temporal entity"@en .


###  https://w3id.org/italia/onto/TI/hasTimeParameter
ti:hasTimeParameter rdf:type owl:ObjectProperty .


###  https://w3id.org/italia/onto/TI/isTemporalEntityOf
ti:isTemporalEntityOf rdf:type owl:ObjectProperty ;
                      rdfs:domain ti:TemporalEntity ;
                      rdfs:range owl:Thing ;
                      rdfs:comment "Property that links a temporal entity to a time indexed event."@en ,
                                   "Proprietà che collega un entità temporale ad un evento nel tempo."@it ;
                      rdfs:isDefinedBy <https://w3id.org/italia/onto/TI> ;
                      rdfs:label "is temporal entity of"@en ,
                                 "è entità temporale di"@it .


#################################################################
#    Data properties
#################################################################

###  http://www.w3.org/2004/02/skos/core#note
<http://www.w3.org/2004/02/skos/core#note> rdf:type owl:DatatypeProperty .


###  https://w3id.org/arco/ontology/arco-lite/title
a-lite:title rdf:type owl:DatatypeProperty ;
             rdfs:domain owl:Thing ;
             rdfs:range rdfs:Literal ;
             rdfs:comment "Questa proprietà rappresenta il titolo del soggetto di un bene culturale. La proprietà viene specificata in sottoproprietà per esprimere tipologie di titolo specifiche. Per la normativa trasversale è il titolo più noto e accreditato; nelle altre normative si specifica che è il titolo dato dall'autore o la denominazione tradizionale del soggetto."@it ,
                          "This property represents the title of a cultural property."@en ;
             rdfs:isDefinedBy <https://w3id.org/arco/ontology/arco-lite> ;
             rdfs:label "title"@en ,
                        "titolo"@it ;
             owl:versionInfo "stabile"@it ,
                             "stable"@en ;
             a-cat:iccdNormTag "Normativa trasversale: DA/AID/AIDT - Altre normative di versioni precedenti alla 4.00: OG/SGT/SGTT"@it .


###  https://w3id.org/arco/ontology/arco/numberOfElements
arco:numberOfElements rdf:type owl:DatatypeProperty ,
                               owl:FunctionalProperty ;
                      rdfs:domain l0:Object ;
                      rdfs:range xsd:positiveInteger ;
                      rdfs:comment "Questa propietà rappresenta  il numero complessivo, espresso in cifre, degli elementi che costituiscono il bene catalogato, nel caso esso sia un insieme o una serie i cui esemplari/oggetti componenti comprendono ciascuno più elementi."@it ,
                                   "This property represents the total number of elements of a complex cultural property, when it is composed by parts containing more elements."@en ;
                      rdfs:isDefinedBy <https://w3id.org/arco/ontology/arco> ;
                      rdfs:label "number of elements"@en ,
                                 "numero di elementi"@it ;
                      owl:versionInfo "stabile"@it ,
                                      "stable"@en ;
                      a-cat:iccdNormTag "ICCD Normativa Trasversale 4.00: OG/QNT/QNTI; OG/QNT/QNTS" .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/byteSize
dr:byteSize rdf:type owl:DatatypeProperty ;
            rdfs:domain dr:DigitalResourceDistribution ;
            rdfs:range xsd:decimal ;
            rdfs:comment "La dimensione espressa in byte della distribuzione della risorsa digitale."@it ,
                         "The size of the digital resource distribution expressed in bytes."@en ;
            rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
            rdfs:label "byte size"@en ,
                       "dimensione byte"@it ;
            owl:versionInfo "instabile"@it ,
                            "unstable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/checksum
dr:checksum rdf:type owl:DatatypeProperty ;
            rdfs:domain dr:Checksum ;
            rdfs:range rdfs:Literal ;
            rdfs:comment "Questa proprietà rappresenta il checksum, un meccanismo che può essere utilizzato per verificare che il contenuto di una distribuzione non sia stato modificato."@it ,
                         "This property represents the checksum, a mechanism that can be used to verify that the contents of a distribution have not been altered."@en ;
            rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
            rdfs:label "checksum"@en ,
                       "checksum"@it ;
            owl:versionInfo "instabile"@it ,
                            "unstable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/creationMethod
dr:creationMethod rdf:type owl:DatatypeProperty ;
                  rdfs:domain dr:DigitalCollection ;
                  rdfs:range [ rdf:type rdfs:Datatype ;
                               owl:oneOf [ rdf:type rdf:List ;
                                           rdf:first "automatic" ;
                                           rdf:rest [ rdf:type rdf:List ;
                                                      rdf:first "manual" ;
                                                      rdf:rest rdf:nil
                                                    ]
                                         ]
                             ] ;
                  rdfs:comment "Questa proprietà rappresenta il metodo di produzione di una collezione digitale, che può essere automatica o manuale."@it ,
                               "This property represents the method of production of a digital collection, which can be automatic or manual."@en ;
                  rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
                  rdfs:label "creation method"@en ,
                             "metodo di produzione"@it ;
                  owl:versionInfo "instabile"@it ,
                                  "unstable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/digitalCoordinates
dr:digitalCoordinates rdf:type owl:DatatypeProperty ;
                      rdfs:domain dr:NamedRelation ;
                      rdfs:range rdfs:Literal ;
                      rdfs:comment "Questa proprietà rappresenta la coordinata digitale di una risorsa digitale creativa all'interno di un'altra risorsa. Ad esempio, le coordinate dell'inizio di un contenuto specifico o la sua inclusione in una risorsa più ampia"@it ,
                                   "This property represents the digital coordinate of a creative digital resource within another resource. For example, the coordinates of the start of a specific piece of content or its inclusion in a larger resource."@en ;
                      rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
                      rdfs:label "coordinate digitali"@it ,
                                 "digital coordinates"@en ;
                      owl:versionInfo "instabile"@it ,
                                      "unstable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/manifestFormat
dr:manifestFormat rdf:type owl:DatatypeProperty ;
                  rdfs:domain dr:Manifest ;
                  rdfs:range [ rdf:type rdfs:Datatype ;
                               owl:oneOf [ rdf:type rdf:List ;
                                           rdf:first "custom" ;
                                           rdf:rest [ rdf:type rdf:List ;
                                                      rdf:first "default" ;
                                                      rdf:rest rdf:nil
                                                    ]
                                         ]
                             ] ;
                  rdfs:comment "Il metodo di fruizione del manifest, che può assumente i valori \"default\" (standard) o \"custom\" (specifico)."@it ,
                               "The format of the manifest, which can take the values ‘default’ (standard) or ‘custom’ (specific)."@en ;
                  rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
                  rdfs:label "manifest format"@en ,
                             "modalità fruizione"@it ;
                  owl:versionInfo "instabile"@it ,
                                  "unstable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/mediaType
dr:mediaType rdf:type owl:DatatypeProperty ;
             rdfs:domain dr:DigitalResourceDistribution ;
             rdfs:range rdfs:Literal ;
             rdfs:comment "Questa proprietà relaziona una distribuzione al suo tipo di media."@it ,
                          "This property relates a distribution with its media type"@en ;
             rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
             rdfs:label "media type"@en ,
                        "tipo di media"@it ;
             owl:versionInfo "instabile"@it ,
                             "unstable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/mimetype
dr:mimetype rdf:type owl:DatatypeProperty ;
            rdfs:domain dr:DigitalResourceDistribution ;
            rdfs:range rdfs:Literal ;
            rdfs:comment "Questa proprietà rappresenta un identificativo diviso in due parti usato per specificare il tipo di contenuto di un file o di una risorsa trasmesso su internet. Esso consente ai sistemi informatici di interpretare correttamente il contenuto e di gestirlo così in  maniera appropriata."@it ,
                         "This property represents a two-part identifier used to specify the type of content of a file or resource transmitted over the internet. It allows computer systems to correctly interpret the content and manage it appropriately."@en ;
            rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
            rdfs:label "mimetype"@en ,
                       "mimetype"@it ;
            owl:versionInfo "instabile"@it ,
                            "unstable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/originReason
dr:originReason rdf:type owl:DatatypeProperty ;
                rdfs:domain dr:ContentDerivation ;
                rdfs:range rdfs:Literal ;
                rdfs:comment "Questa proprietà rappresenta unaa descrizione testuale che spiega la ragione per cui è derivato il contenuto."@it ,
                             "This property represents a textual description explaining why the content was derived."@en ;
                rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
                rdfs:label "motivo derivazione"@it ,
                           "origin reason"@en ;
                owl:versionInfo "instabile"@it ,
                                "unstable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/protectionProfile
dr:protectionProfile rdf:type owl:DatatypeProperty ;
                     rdfs:domain [ rdf:type owl:Class ;
                                   owl:unionOf ( dr:DigitalResource
                                                 dr:Manifest
                                               )
                                 ] ;
                     rdfs:range rdfs:Literal ;
                     rdfs:comment "Questa proprietà rappresenta il profilo di protezione specificatamente attribuito al manifest IIIF della risorsa digitale intellettuale. Il profilo di protezione è un attributo che determina come circoscrivere, limitare o impedire la fruizione e il riuso del manifest IIIF della risorsa digitale intellettuale, anche rispetto a termini e condizioni definiti nel contesto di una licenza d’uso"@it ,
                                  "This property represents the protection profile specifically attributed to the IIIF manifest of the digital resource in the intellectual domain. The protection profile is an attribute that determines how to circumscribe, limit or prevent the use and reuse of the IIIF manifest of the digital resource in the intellectual domain, in accordance with the terms and conditions defined in the context of a licence of use."@en ;
                     rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
                     rdfs:label "profilo di protezione"@it ,
                                "protection profile"@en ;
                     owl:versionInfo "instabile"@it ,
                                     "unstable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/smartCollection
dr:smartCollection rdf:type owl:DatatypeProperty ;
                   rdfs:domain dr:DigitalCollection ;
                   rdfs:range xsd:boolean ;
                   rdfs:comment "Questa proprietà indica se la collezione digitale è di tipo smart."@it ,
                                "This property indicates whether the digital collection is of the smart type."@en ;
                   rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
                   rdfs:label "collezione smart"@it ,
                              "smart collection"@en ;
                   owl:versionInfo "instabile"@it ,
                                   "unstable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/source
dr:source rdf:type owl:DatatypeProperty ;
          rdfs:domain dr:DigitalResource ;
          rdfs:range rdfs:Literal ;
          rdfs:comment "Questa proprietà indica la fonte (banca dati, knowledge graph, ecc) da cui proviene la risorsa digitale."@it ,
                       "This property indicates the source (database, knowledge graph, etc.) from which the digital resource originates."@en ;
          rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
          rdfs:label "fonte"@it ,
                     "source"@en ;
          owl:versionInfo "instabile"@it ,
                          "unstable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/sourceMD
dr:sourceMD rdf:type owl:DatatypeProperty ;
            rdfs:domain dr:CreativeDigitalResource ;
            rdfs:range rdfs:Literal ;
            rdfs:comment "Questa proprietà specifica il supporto fisico da cui è tratta la digitalizzazione. Per esempio: nel caso di un Microfilm, la proprietà descriverà la bobina corrispondente."@it ,
                         "This property specifies the physical medium from which the digitisation is taken. For example: in the case of microfilm, the property will describe the corresponding reel."@en ;
            rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
            rdfs:label "fonteMD"@it ,
                       "sourceMD"@en ;
            owl:versionInfo "instabile"@it ,
                            "unstable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/subType
dr:subType rdf:type owl:DatatypeProperty ;
           rdfs:domain dr:PhysicalStructure ;
           rdfs:range [ rdf:type rdfs:Datatype ;
                        owl:oneOf [ rdf:type rdf:List ;
                                    rdf:first "not preferred" ;
                                    rdf:rest [ rdf:type rdf:List ;
                                               rdf:first "preferred" ;
                                               rdf:rest rdf:nil
                                             ]
                                  ]
                      ] ;
           rdfs:comment "La caratteristica che evidenzia se la struttura fisica in oggetto è la preferita o meno."@it ,
                        "The property that represents whether the physical structure in question is the preferred one or not."@en ;
           rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
           rdfs:label "sottotipo"@it ,
                      "subtype"@en ;
           owl:versionInfo "instabile"@it ,
                           "unstable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/viewerLink
dr:viewerLink rdf:type owl:DatatypeProperty ;
              rdfs:domain dr:DigitalResource ;
              rdfs:range rdfs:Literal ;
              rdfs:comment "Questa proprietà rappresenta il link allo strumento di visualizzazione preimpostato dall'owner della risorsa per visualizzarla. Per esempio: il link per una risorsa visualizzata con Mirador."@it ,
                           "This property represents the link to the viewer tool preset by the resource owner to view it. For example: the link for a resource viewed with Mirador."@en ;
              rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
              rdfs:label "link strumento visualizzazione"@it ,
                         "viewerLink"@en ;
              owl:versionInfo "instabile"@it ,
                              "unstable"@en .


###  https://w3id.org/italia/onto/SM/URL
sm:URL rdf:type owl:DatatypeProperty ;
       rdfs:domain owl:Thing ;
       rdfs:range xsd:anyURI ;
       rdfs:comment "Questa proprietà rappresenta un URL di una qualsiasi cosa del dominio modellato."@it ,
                    "This property represents a general URL associated with any thing of the modelled domain."@en ;
       rdfs:label "URL"@en ,
                  "URL"@it ;
       owl:versionInfo "provvisoria"@it ,
                       "unstable"@en .


#################################################################
#    Classes
#################################################################

###  http://purl.org/dc/terms/LicenseDocument
dct:LicenseDocument rdf:type owl:Class .


###  https://w3id.org/arco/ontology/core/Concept
core:Concept rdf:type owl:Class ;
             rdfs:subClassOf l0:Concept .


###  https://w3id.org/arco/ontology/core/Type
core:Type rdf:type owl:Class ;
          rdfs:subClassOf core:Concept ;
          rdfs:comment "Classe che rappresenta il concetto di tipo."@it ,
                       "The class representing the concept of type."@en ;
          rdfs:isDefinedBy <https://w3id.org/arco/ontology/core> ;
          rdfs:label "Tipo"@it ,
                     "Type"@en ;
          owl:versionInfo "stabile"@it ,
                          "stable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/Checksum
dr:Checksum rdf:type owl:Class ;
            rdfs:subClassOf l0:Description ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty core:hasType ;
                              owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                              owl:onClass dr:ChecksumType
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty dr:checksum ;
                              owl:cardinality "1"^^xsd:nonNegativeInteger
                            ] ;
            rdfs:comment "La classe rappresenta un meccanismo che può essere utilizzato per verificare che il contenuto di una distribuzione non sia stato modificato."@it ,
                         "The class represents a mechanism that can be used to verify that the contents of a distribution have not been modified."@en ;
            rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
            rdfs:label "Checksum"@en ,
                       "Checksum"@it ;
            owl:versionInfo "instabile"@it ,
                            "instable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/ChecksumType
dr:ChecksumType rdf:type owl:Class ;
                rdfs:subClassOf core:Type ;
                rdfs:comment "Questa classe rappresenta il tipo di checksum di una distribuzione digitale."@it ,
                             "This class represents the checksum type of a digital resource distribution."@en ;
                rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
                rdfs:label "Checksum type"@en ,
                           "Tipologia di checksum"@en ;
                owl:versionInfo "instabile"@it ,
                                "unstable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/ContentDerivation
dr:ContentDerivation rdf:type owl:Class ;
                     rdfs:subClassOf l0:EventOrSituation ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty dr:hasDerivedContent ;
                                       owl:someValuesFrom dr:DigitalResourceDistribution
                                     ] ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty core:hasType ;
                                       owl:allValuesFrom dr:OriginType
                                     ] ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty dr:originReason ;
                                       owl:allValuesFrom rdfs:Literal
                                     ] ;
                     rdfs:comment "Questa classe rappresenta un contenuto derivato di cui si può esprimere la ragione e l'origine."@it ,
                                  "This class represents a derived content whose reason and origin can be expressed."@en ;
                     rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
                     rdfs:label "Content derivation"@en ,
                                "Contenuto derivato"@it ;
                     owl:versionInfo "instabile"@it ,
                                     "instable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/CreativeDigitalResource
dr:CreativeDigitalResource rdf:type owl:Class ;
                           rdfs:subClassOf dr:DigitalResource ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty dr:hasStructure ;
                                             owl:someValuesFrom dr:Structure
                                           ] ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty dct:license ;
                                             owl:allValuesFrom dct:LicenseDocument
                                           ] ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty dr:hasContent ;
                                             owl:allValuesFrom dr:CreativeDigitalResource
                                           ] ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty dr:hasCoverImage ;
                                             owl:allValuesFrom dr:DigitalResource
                                           ] ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty l0:isMemberOf ;
                                             owl:allValuesFrom dr:DigitalCollection
                                           ] ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty dr:sourceMD ;
                                             owl:allValuesFrom rdfs:Literal
                                           ] ;
                           rdfs:comment """Questa classe rappresenta un’entità logica e fisica digitale, vista come un'unità di senso coerente, creata per permettere una gestione più efficiente e organizzata dei contenuti di una risorsa digitale, secondo logiche strutturali e di aggregazione, di risorse digitali semplici. Una risorsa digitale intellettuale può contenere altre risorse digitali intellettuali ed è descritta mediante dei metadati anche inclusi all’interno di file manifest. È sempre necessario creare una risorsa digitale intellettuale, anche quando essa raccoglie una singola risorsa digitale. 
Questa classe non è disgiunta dalla classe CulturalEntity perciò, un individuo appartenente a questa classe, può appartenere anche alla classe CulturalEntity; questo rende non necessaria la presenza di una specifica classe descritta come CulturalCreativeDigitalResource (Una risorsa digitale che è anche un’entità culturale)."""@it ,
                                        "This class represents a logical and physical digital entity, viewed as a coherent unit of meaning, created to enable more efficient and organized management of a digital resource's contents, according to structural and aggregation logics for simple digital resources. An intellectual digital resource can contain other intellectual digital resources and is described through metadata, including those included within manifest files. It is always necessary to create an intellectual digital resource, even when it encompasses a single digital resource. This class is not disjoint from the CulturalEntity class, so an individual belonging to this class can also belong to the CulturalEntity class; this makes the presence of a specific class described as CulturalCreativeDigitalResource (a digital resource that is also a cultural entity) unnecessary."@en ;
                           rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
                           rdfs:label "Creative digital resource"@en ,
                                      "Risorsa digitale intellettuale"@it ;
                           owl:versionInfo "instabile"@it ,
                                           "instable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/DigitalCollection
dr:DigitalCollection rdf:type owl:Class ;
                     rdfs:subClassOf l0:Collection ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty dr:creationMethod ;
                                       owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                       owl:onDataRange [ rdf:type rdfs:Datatype ;
                                                         owl:oneOf [ rdf:type rdf:List ;
                                                                     rdf:first "automatic" ;
                                                                     rdf:rest [ rdf:type rdf:List ;
                                                                                rdf:first "manual" ;
                                                                                rdf:rest rdf:nil
                                                                              ]
                                                                   ]
                                                       ]
                                     ] ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty dr:smartCollection ;
                                       owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                       owl:onDataRange xsd:boolean
                                     ] ;
                     owl:disjointWith dr:DigitalResource ;
                     rdfs:comment "Questa classe rappresenta una raccolta “virtuale” ma persistente di risorse digitali, creata secondo logiche tematiche, cronologiche o di altro tipo."@it ,
                                  "This class represents a “virtual” but persistent collection of digital resources, created according to thematic, chronological or other types of logic."@en ;
                     rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
                     rdfs:label "Collezione digitale"@it ,
                                "Digital collection"@en ;
                     owl:versionInfo "instabile"@it ,
                                     "instable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/DigitalResource
dr:DigitalResource rdf:type owl:Class ;
                   rdfs:subClassOf l0:Object ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty dr:hasDistribution ;
                                     owl:someValuesFrom dr:DigitalResourceDistribution
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty dr:belongsToStructure ;
                                     owl:allValuesFrom dr:Structure
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty dr:hasEntityDerivation ;
                                     owl:allValuesFrom dr:EntityDerivation
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty dr:isDigitalResourceOf ;
                                     owl:allValuesFrom l0:Entity
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty ti:hasTemporalEntity ;
                                     owl:allValuesFrom ti:TemporalEntity
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty l0:follows ;
                                     owl:allValuesFrom dr:DigitalResource
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty l0:precedes ;
                                     owl:allValuesFrom dr:DigitalResource
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty core:hasType ;
                                     owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                     owl:onClass core:Type
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty a-lite:title ;
                                     owl:someValuesFrom rdfs:Literal
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty dr:protectionProfile ;
                                     owl:someValuesFrom rdfs:Literal
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty dr:source ;
                                     owl:allValuesFrom rdfs:Literal
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty dr:viewerLink ;
                                     owl:allValuesFrom rdfs:Literal
                                   ] ;
                   owl:disjointWith dr:DigitalResourceDistribution ;
                   rdfs:comment "La classe che rappresenta una risorsa digitale. Questa classe comprende tutte le tipologie di risorse digitali gestite dalla piattaforma, definisce tutti i metadati comuni e necessari alla ricerca, alla visualizzazione e più in generale alla FAIRness di dati, strumenti e servizi. È una sottoclasse di cidoccrm:E73_Information_Object."@it ,
                                "The class representing a digital resource. This class includes all types of digital resources managed by the platform and defines all common metadata necessary for search, display, and, more generally, for the FAIRness of data, tools, and services. It is a subclass of cidoccrm:E73_Information_Object."@en ;
                   rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
                   rdfs:label "Digital Resource"@en ,
                              "Risorsa digitale"@it ;
                   owl:versionInfo "instabile"@it ,
                                   "instable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/DigitalResourceDistribution
dr:DigitalResourceDistribution rdf:type owl:Class ;
                               rdfs:subClassOf l0:Object ,
                                               [ rdf:type owl:Restriction ;
                                                 owl:onProperty dr:hasContentDerivation ;
                                                 owl:allValuesFrom dr:ContentDerivation
                                               ] ,
                                               [ rdf:type owl:Restriction ;
                                                 owl:onProperty dr:hasChecksum ;
                                                 owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                 owl:onClass dr:Checksum
                                               ] ,
                                               [ rdf:type owl:Restriction ;
                                                 owl:onProperty a-lite:title ;
                                                 owl:cardinality "1"^^xsd:nonNegativeInteger
                                               ] ,
                                               [ rdf:type owl:Restriction ;
                                                 owl:onProperty dr:byteSize ;
                                                 owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                 owl:onDataRange xsd:decimal
                                               ] ,
                                               [ rdf:type owl:Restriction ;
                                                 owl:onProperty dr:mediaType ;
                                                 owl:cardinality "1"^^xsd:nonNegativeInteger
                                               ] ,
                                               [ rdf:type owl:Restriction ;
                                                 owl:onProperty dr:mimetype ;
                                                 owl:cardinality "1"^^xsd:nonNegativeInteger
                                               ] ;
                               rdfs:comment "La classe che rappresenta una distribuzione di risorse digitali. Si tratta di una specifica rappresentazione digitale concreta della risorsa digitale. Le risorse digitali possono essere rese disponibili attraverso diverse serializzazioni che differiscono in base a diversi metadati tecnici quali mime-type, formati, dimensioni, profili di visibilità. Ogni distribuzione è identificata univocamente da un identificativo persistente e univoco."@it ,
                                            "The class representing a distribution of digital resources. This is a specific, concrete digital representation of the digital resource. Digital resources can be made available through various serializations that differ based on various technical metadata such as mime-type, format, size, and visibility profiles. Each distribution is uniquely identified by a persistent and unique identifier."@en ;
                               rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
                               rdfs:label "Digital Resource Distribution"@en ,
                                          "Distribuzione di risorse digitali"@it ;
                               owl:versionInfo "instabile"@it ,
                                               "instable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/EntityDerivation
dr:EntityDerivation rdf:type owl:Class ;
                    rdfs:subClassOf l0:EventOrSituation ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty dr:hasExtractionTechnique ;
                                      owl:allValuesFrom dr:ExtractionTechnique
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty dr:hasDerivedEntity ;
                                      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                      owl:onClass l0:Entity
                                    ] ;
                    rdfs:comment "Questa classe rappresenta una derivazione di entità."@it ,
                                 "This class represents a derivation of entities."@en ;
                    rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
                    rdfs:label "Entity derivation"@en ,
                               "Entità derivata"@it ;
                    owl:versionInfo "instabile"@it ,
                                    "instable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/ExtractionTechnique
dr:ExtractionTechnique rdf:type owl:Class ;
                       rdfs:subClassOf l0:Description ;
                       rdfs:comment "Questa classe rappresenta un meccanismo attraverso cui derivare una specifica entità da una risorsa digitale. Esempio: OCR, speech2text, ecc."@it ,
                                    "This class represents a mechanism for deriving a specific entity from a digital resource. Examples: OCR, speech2text, etc."@en ;
                       rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
                       rdfs:label "Extraction technique"@en ,
                                  "Tecnica di estrazione"@it ;
                       owl:versionInfo "instabile"@it ,
                                       "instable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/LogicalStructure
dr:LogicalStructure rdf:type owl:Class ;
                    rdfs:subClassOf dr:Structure ;
                    rdfs:comment "Questa classe rappresenta la suddivisione logico-strutturale degli elementi contenutistici della risorsa al fine di crearne l’indice dei contenuti."@it ,
                                 "This class represents the logical-structural subdivision of the content elements of the resource for the purpose of creating the table of contents."@en ;
                    rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
                    rdfs:label "Logical structure"@en ,
                               "Struttura logica"@it ;
                    owl:versionInfo "instabile"@it ,
                                    "instable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/Manifest
dr:Manifest rdf:type owl:Class ;
            rdfs:subClassOf l0:Object ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty dr:manifestFormat ;
                              owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                              owl:onDataRange [ rdf:type rdfs:Datatype ;
                                                owl:oneOf [ rdf:type rdf:List ;
                                                            rdf:first "custom" ;
                                                            rdf:rest [ rdf:type rdf:List ;
                                                                       rdf:first "default" ;
                                                                       rdf:rest rdf:nil
                                                                     ]
                                                          ]
                                              ]
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty dr:protectionProfile ;
                              owl:cardinality "1"^^xsd:nonNegativeInteger
                            ] ;
            rdfs:comment "Questa classe rappresenta il manifest che descrive una risorsa digitale intellettuale in un formato standardizzato, per consentire la condivisione e l’interoperabilità di immagini. Il manifest IIIF include metadati dettagliati riguardanti la risorsa, come informazioni sulla struttura dell'oggetto: per esempio, una collezione di immagini che compongono un libro digitalizzato. Descrizione delle immagini: URL delle immagini, dimensioni, formati disponibili, ecc. Metadati aggiuntivi: informazioni su autori, titoli, date, descrizioni e altri attributi rilevanti."@it ,
                         "This class represents the manifest that describes a digital intellectual resource in a standardized format, to enable image sharing and interoperability. The IIIF manifest includes detailed metadata about the resource, such as information about the object's structure—for example, a collection of images that make up a digitized book. Image descriptions include image URLs, dimensions, available formats, etc. Additional metadata includes information about authors, titles, dates, descriptions, and other relevant attributes."@en ;
            rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
            rdfs:label "Manifest"@en ,
                       "Manifest"@it ;
            owl:versionInfo "instabile"@it ,
                            "instable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/MediaType
dr:MediaType rdf:type owl:Class ;
             rdfs:subClassOf core:Type ;
             rdfs:comment "Questa classe rappresenta il tipo di media, espresso con l'estensione del file di una distribuzione. Può assumere i valori predefiniti definiti in un vocabolario controllato, per esempio http://publications.europa.eu/resource/authority/file-type ."@it ,
                          "This class represents the type of media, expressed by the file extension of a distribution. It can take the predefined values defined in a controlled vocabulary, for example http://publications.europa.eu/resource/authority/file-type ."@en ;
             rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
             rdfs:label "Media type"@en ,
                        "Tipo di media"@it ;
             owl:versionInfo "instabile"@it ,
                             "unstable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/NamedRelation
dr:NamedRelation rdf:type owl:Class ;
                 rdfs:subClassOf l0:EventOrSituation ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty dr:hasObjectOfRelation ;
                                   owl:someValuesFrom l0:Entity
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty dr:hasSubjectOfRelation ;
                                   owl:someValuesFrom l0:Entity
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty <http://www.w3.org/2004/02/skos/core#note> ;
                                   owl:allValuesFrom rdfs:Literal
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty dr:digitalCoordinates ;
                                   owl:allValuesFrom rdfs:Literal
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty l0:positionInSequence ;
                                   owl:allValuesFrom xsd:integer
                                 ] ;
                 rdfs:comment """Questa classe rappresenta la reificazione di una relazione tra entità. La classe serve per poter predicare e aggiungere informazioni su alcune specifiche relazioni del modello, quali: belongsToStucture, includes e startsWith.
La classe viene materializzata con una tipologia (RelationType) che esplicita la relazione in oggetto e collegata ad alcuni attributi della relazione, quali: note, positionInSequence e digitalCoordinates.

Un esempio di applicazione è:

data:creative-digital-resource-1 a dr:CreativeDigitalResource ;
    dr:isSubjectOfRelation data:named-relation-1 .
data:named-relation-1 core:hasType data:startsWith ;
    dr:digitalCoordinates \"10, 20, 39\" ;
    dr:hasObjectOfRelation data:digital-resource-1 ."""@it ,
                              """This class represents the reification of a relationship between entities. The class is used to be able to predicate and add information about certain specific relationships in the model, such as: belongsToStucture, includes and startsWith.
The class is materialised with a type (RelationType) that specifies the relationship in question and is linked to attributes of the relationship, such as: notes, positionInSequence and digitalCoordinates.

A data example:

data:creative-digital-resource-1 a dr:CreativeDigitalResource ;
    dr:isSubjectOfRelation data:named-relation-1 .
data:named-relation-1 core:hasType data:startsWith ;
    dr:digitalCoordinates \"10, 20, 39\" ;
    dr:hasObjectOfRelation data:digital-resource-1 ."""@en ;
                 rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
                 rdfs:label "Named relation"@en ,
                            "Relazione denominata"@it ;
                 owl:versionInfo "instabile"@it ,
                                 "unstable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/OriginType
dr:OriginType rdf:type owl:Class ;
              rdfs:subClassOf core:Type ;
              rdfs:comment "Questa classe rappresenta il metodo con cui viene derivato il contenuto di una distribuzio e di una risorsa digitale."@it ,
                           "This class represents the method by which the content of a distribution and a digital resource is derived."@en ;
              rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
              rdfs:label "Origin type"@en ,
                         "Tipo derivazione"@it ;
              owl:versionInfo "instabile"@it ,
                              "unstable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/PhysicalStructure
dr:PhysicalStructure rdf:type owl:Class ;
                     rdfs:subClassOf dr:Structure ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty dr:subType ;
                                       owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                       owl:onDataRange [ rdf:type rdfs:Datatype ;
                                                         owl:oneOf [ rdf:type rdf:List ;
                                                                     rdf:first "not preferred" ;
                                                                     rdf:rest [ rdf:type rdf:List ;
                                                                                rdf:first "preferred" ;
                                                                                rdf:rest rdf:nil
                                                                              ]
                                                                   ]
                                                       ]
                                     ] ;
                     rdfs:comment "Questa classe rappresenta l’organizzazione sequenziale delle risorse, volta alla loro fruizione ordinata." ,
                                  "This class represents the sequential organization of resources, aimed at their orderly use."@en ;
                     rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
                     rdfs:label "Physical structure"@en ,
                                "Struttura fisica"@it ;
                     owl:versionInfo "instabile"@it ,
                                     "instable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/RelationType
dr:RelationType rdf:type owl:Class ;
                rdfs:subClassOf core:Type ;
                rdfs:comment "Questa classe rappresenta il tipo di relazione di una NamedRelation. Essa assume i valori delle relazioni che vengono reificate nella NamedRelation, ad esempio \"belongsToStructure\", \"includes\" e \"startsWith\"."@it ,
                             "This class represents the type of relationship in a NamedRelation. It takes on the values of the relationships that are reified in the NamedRelation, for example, ‘belongsToStructure’, “includes” and ‘startsWith’."@en ;
                rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
                rdfs:label "Relation type"@en ,
                           "Tipo di relazione"@it ;
                owl:versionInfo "instabile"@it ,
                                "unstable"@en .


###  https://w3id.org/italia/cultural-heritage/ontology/digital-resource/Structure
dr:Structure rdf:type owl:Class ;
             rdfs:subClassOf l0:Entity ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty arco:numberOfElements ;
                               owl:allValuesFrom xsd:positiveInteger
                             ] ;
             rdfs:comment "Questa classe rappresenta un'entità che descrive l’organizzazione interna delle RisorseDigitali, e può essere di tipo fisico (sottoclasse StrutturaFisica) o di tipo logico (sottoclasse StrutturaLogica)."@it ,
                          "This class represents an entity that describes the internal organization of the Digital Resources, and can be of a physical type (PhysicalStructure subclass) or of a logical type (LogicalStructure subclass)."@en ;
             rdfs:isDefinedBy <https://w3id.org/italia/cultural-heritage/ontology/digital-resource> ;
             rdfs:label "Structure"@en ,
                        "Struttura"@it ;
             owl:versionInfo "instabile"@it ,
                             "instable"@en .


###  https://w3id.org/italia/onto/TI/TemporalEntity
ti:TemporalEntity rdf:type owl:Class ;
                  rdfs:subClassOf l0:Entity ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty ti:hasTimeParameter ;
                                    owl:allValuesFrom l0:Characteristic
                                  ] ;
                  rdfs:comment "Questa classe rappresenta un'entità di natura temporale."@it ,
                               "This class represents a temporal entity."@en ;
                  rdfs:isDefinedBy <https://w3id.org/italia/onto/TI> ;
                  rdfs:label "Entità temporale"@it ,
                             "Temporal entity"@en .


