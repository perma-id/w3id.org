Options +FollowSymLinks

# Rewrite engine setup
RewriteEngine On

# ── ROOT: Redirect to EGDC overview ──────────────────────────────────────────
RewriteCond %{HTTP_ACCEPT} text/html
RewriteRule ^$ https://European-Green-Digital-Coalition.github.io/ [R=302,L]


# ╔══════════════════════════════════════════════════════════════════════════╗
# ║                          EGDC_CaseStudy                                 ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# ── Content negotiation (machine-readable) ────────────────────────────────
RewriteCond %{HTTP_ACCEPT} text/turtle
RewriteRule ^casestudy/(.*)$ https://European-Green-Digital-Coalition.github.io/EGDC_CaseStudy/puri/$1.ttl [NE,R=302,L]

RewriteCond %{HTTP_ACCEPT} application/ld\+json
RewriteRule ^casestudy/(.*)$ https://European-Green-Digital-Coalition.github.io/EGDC_CaseStudy/puri/$1.jsonld [NE,R=302,L]

RewriteCond %{HTTP_ACCEPT} application/rdf\+xml
RewriteRule ^casestudy/(.*)$ https://European-Green-Digital-Coalition.github.io/EGDC_CaseStudy/puri/$1.rdf [NE,R=302,L]

RewriteCond %{HTTP_ACCEPT} application/n-triples
RewriteRule ^casestudy/(.*)$ https://European-Green-Digital-Coalition.github.io/EGDC_CaseStudy/puri/$1.nt [NE,R=302,L]

# ── HTML: Spec root ───────────────────────────────────────────────────────
RewriteRule ^casestudy/$ https://European-Green-Digital-Coalition.github.io/EGDC_CaseStudy/ [R=302,L]

# ── HTML: Classes ─────────────────────────────────────────────────────────
RewriteRule ^casestudy/CaseStudy$ https://European-Green-Digital-Coalition.github.io/EGDC_CaseStudy/#CaseStudy [NE,R=302,L]
RewriteRule ^casestudy/Benefit$ https://European-Green-Digital-Coalition.github.io/EGDC_CaseStudy/#Benefit [NE,R=302,L]
RewriteRule ^casestudy/Methodology$ https://European-Green-Digital-Coalition.github.io/EGDC_CaseStudy/#Methodology [NE,R=302,L]

# ── HTML: Properties ──────────────────────────────────────────────────────
RewriteRule ^casestudy/fundingType$ https://European-Green-Digital-Coalition.github.io/EGDC_CaseStudy/#fundingType [NE,R=302,L]
RewriteRule ^casestudy/hasBenefit$ https://European-Green-Digital-Coalition.github.io/EGDC_CaseStudy/#hasBenefit [NE,R=302,L]


# ╔══════════════════════════════════════════════════════════════════════════╗
# ║                            EGDC_Rule                                    ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# ── Content negotiation (machine-readable) ────────────────────────────────
RewriteCond %{HTTP_ACCEPT} text/turtle
RewriteRule ^rule/(.*)$ https://European-Green-Digital-Coalition.github.io/EGDC_Rule/puri/$1.ttl [NE,R=302,L]

RewriteCond %{HTTP_ACCEPT} application/ld\+json
RewriteRule ^rule/(.*)$ https://European-Green-Digital-Coalition.github.io/EGDC_Rule/puri/$1.jsonld [NE,R=302,L]

RewriteCond %{HTTP_ACCEPT} application/rdf\+xml
RewriteRule ^rule/(.*)$ https://European-Green-Digital-Coalition.github.io/EGDC_Rule/puri/$1.rdf [NE,R=302,L]

RewriteCond %{HTTP_ACCEPT} application/n-triples
RewriteRule ^rule/(.*)$ https://European-Green-Digital-Coalition.github.io/EGDC_Rule/puri/$1.nt [NE,R=302,L]

# ── HTML: Spec root ───────────────────────────────────────────────────────
RewriteRule ^rule/$ https://European-Green-Digital-Coalition.github.io/EGDC_Rule/ [R=302,L]

# ── HTML: Classes ─────────────────────────────────────────────────────────
RewriteRule ^rule/Rule$ https://European-Green-Digital-Coalition.github.io/EGDC_Rule/#Rule [NE,R=302,L]
RewriteRule ^rule/InputParameter$ https://European-Green-Digital-Coalition.github.io/EGDC_Rule/#InputParameter [NE,R=302,L]
RewriteRule ^rule/Output$ https://European-Green-Digital-Coalition.github.io/EGDC_Rule/#Output [NE,R=302,L]
RewriteRule ^rule/Range$ https://European-Green-Digital-Coalition.github.io/EGDC_Rule/#Range [NE,R=302,L]

# ── HTML: Properties ──────────────────────────────────────────────────────
RewriteRule ^rule/example$ https://European-Green-Digital-Coalition.github.io/EGDC_Rule/#example [NE,R=302,L]
RewriteRule ^rule/hasRange$ https://European-Green-Digital-Coalition.github.io/EGDC_Rule/#hasRange [NE,R=302,L]


# ╔══════════════════════════════════════════════════════════════════════════╗
# ║                          Code Lists (egdc-cl)                           ║
# ╚══════════════════════════════════════════════════════════════════════════╝
#
#  Code lists from EGDC_Rule:   complexity, impacttype
#  Code lists from EGDC_CaseStudy: funding, status
#
#  URI pattern: w3id.org/egdc/codelist/{listname}
#  URI pattern: w3id.org/egdc/codelist/{listname}/{conceptvalue}

# ── Content negotiation (machine-readable) — EGDC_Rule code lists ─────────
RewriteCond %{HTTP_ACCEPT} text/turtle
RewriteRule ^codelist/(complexity|impacttype)(.*)$ https://European-Green-Digital-Coalition.github.io/EGDC_Rule/puri/codelist/$1$2.ttl [NE,R=302,L]

RewriteCond %{HTTP_ACCEPT} application/ld\+json
RewriteRule ^codelist/(complexity|impacttype)(.*)$ https://European-Green-Digital-Coalition.github.io/EGDC_Rule/puri/codelist/$1$2.jsonld [NE,R=302,L]

RewriteCond %{HTTP_ACCEPT} application/rdf\+xml
RewriteRule ^codelist/(complexity|impacttype)(.*)$ https://European-Green-Digital-Coalition.github.io/EGDC_Rule/puri/codelist/$1$2.rdf [NE,R=302,L]

RewriteCond %{HTTP_ACCEPT} application/n-triples
RewriteRule ^codelist/(complexity|impacttype)(.*)$ https://European-Green-Digital-Coalition.github.io/EGDC_Rule/puri/codelist/$1$2.nt [NE,R=302,L]

# ── Content negotiation (machine-readable) — EGDC_CaseStudy code lists ───
RewriteCond %{HTTP_ACCEPT} text/turtle
RewriteRule ^codelist/(funding|status)(.*)$ https://European-Green-Digital-Coalition.github.io/EGDC_CaseStudy/puri/codelist/$1$2.ttl [NE,R=302,L]

RewriteCond %{HTTP_ACCEPT} application/ld\+json
RewriteRule ^codelist/(funding|status)(.*)$ https://European-Green-Digital-Coalition.github.io/EGDC_CaseStudy/puri/codelist/$1$2.jsonld [NE,R=302,L]

RewriteCond %{HTTP_ACCEPT} application/rdf\+xml
RewriteRule ^codelist/(funding|status)(.*)$ https://European-Green-Digital-Coalition.github.io/EGDC_CaseStudy/puri/codelist/$1$2.rdf [NE,R=302,L]

RewriteCond %{HTTP_ACCEPT} application/n-triples
RewriteRule ^codelist/(funding|status)(.*)$ https://European-Green-Digital-Coalition.github.io/EGDC_CaseStudy/puri/codelist/$1$2.nt [NE,R=302,L]

# ── HTML: Code list roots — EGDC_Rule ────────────────────────────────────
RewriteRule ^codelist/complexity$ https://European-Green-Digital-Coalition.github.io/EGDC_Rule/#complexity [NE,R=302,L]
RewriteRule ^codelist/impacttype$ https://European-Green-Digital-Coalition.github.io/EGDC_Rule/#impacttype [NE,R=302,L]

# ── HTML: Code list roots — EGDC_CaseStudy ───────────────────────────────
RewriteRule ^codelist/funding$ https://European-Green-Digital-Coalition.github.io/EGDC_CaseStudy/#funding [NE,R=302,L]
RewriteRule ^codelist/status$ https://European-Green-Digital-Coalition.github.io/EGDC_CaseStudy/#status [NE,R=302,L]

# ── HTML: Codelist root ───────────────────────────────────────────────────
RewriteRule ^codelist/$ https://European-Green-Digital-Coalition.github.io/ [R=302,L]
