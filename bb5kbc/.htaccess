# https://w3id.org/bb5kbc<ANYTHING> redirects to https://research-squirrel-engineers.github.io/bb-5kbc-sites/<ANYTHING>
#
# ## Contact
# This space is administered by:  
#
# Florian Thiery
# GitHub username: florianthiery
# email: mail@fthiery.de

Options +FollowSymLinks
RewriteEngine on

# ---------------------------------------------------------------------------
# 1. Ontology terms: /ont/<Term>  ->  /ontology#<Term>
# ---------------------------------------------------------------------------
RewriteRule ^ont/([^/]+)/?$ https://research-squirrel-engineers.github.io/bb-5kbc-sites/ontology#$1 [R=303,L,NE]
RewriteRule ^ont/?$ https://research-squirrel-engineers.github.io/bb-5kbc-sites/ontology [R=303,L]

# ---------------------------------------------------------------------------
# 2. Data resources: /<resource>  ->  /<resource>/index.html
# ---------------------------------------------------------------------------
RewriteRule ^([A-Za-z][A-Za-z0-9_]+)/?$ https://research-squirrel-engineers.github.io/bb-5kbc-sites/$1/index.html [R=303,L]

# ---------------------------------------------------------------------------
# 3. Fallback: pass anything else through to the GitHub Pages root
# ---------------------------------------------------------------------------
RewriteRule ^$ https://research-squirrel-engineers.github.io/bb-5kbc-sites/ [R=303,L]