Options -MultiViews
Require all granted

Header set Access-Control-Allow-Origin *
Header set Cache-Control "max-age=3600"

# Redirect ontology URI to raw GitHub file
RewriteEngine on

# If request accepts text/html, redirect to GitHub page
RewriteCond %{HTTP_ACCEPT} text/html
RewriteRule ^ontology$ https://github.com/[ton-username]/OntoSF/blob/main/ontosf.ttl [R=303,L]

# Otherwise redirect to raw TTL file
RewriteRule ^ontology$ https://raw.githubusercontent.com/[ton-username]/OntoSF/main/ontosf.ttl [R=303,L]
