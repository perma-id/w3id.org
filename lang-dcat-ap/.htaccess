# Turn off MultiViews
Options -MultiViews
# Rewrite engine setup
RewriteEngine On

# Directive to ensure *.rdf files served as appropriate content type,
# if not present in main apache config
AddType application/rdf+xml .rdf
AddType application/rdf+xml .owl
AddType text/turtle .ttl
AddType application/n-triples .n3
AddType application/ld+json .json


RewriteCond %{HTTPS} off

# ===============================
# 3. HTML representation
# ===============================
# Redirect any versioned IRI dynamically
# Rewrite rule to serve HTML content from the vocabulary URI if requested
RewriteCond %{HTTP_ACCEPT} text/html [NC,OR]
RewriteCond %{HTTP_ACCEPT} application/xhtml\+xml [NC]
RewriteRule ^([0-9]+\.[0-9]+\.[0-9]+)/?$ https://languagedcat-ap.github.io/LanguageDCAT-AP/releases/$1/ [R=303,L]

# Redirect unversioned IRIs to "latest"
RewriteCond %{HTTP_ACCEPT} text/html [NC,OR]
RewriteCond %{HTTP_ACCEPT} application/xhtml\+xml [NC]
RewriteRule ^$ https://languagedcat-ap.github.io/LanguageDCAT-AP/releases/0.9.2/ [R=303,L]



# ===============================
# RDF representations (specific)
# ===============================
# -------------------- Turtle representation --------------------
# Redirect any versioned IRI dynamically to the Turtle representation if requested
RewriteCond %{HTTP_ACCEPT} text/turtle [NC]
RewriteRule ^([0-9]+\.[0-9]+\.[0-9]+)/?$ https://languagedcat-ap.github.io/LanguageDCAT-AP/releases/$1/ttl/languageDCAT-AP.ttl [R=303,L]

# Redirect unversioned IRIs to "latest"
RewriteCond %{HTTP_ACCEPT} text/turtle [NC]
RewriteRule ^$ https://languagedcat-ap.github.io/LanguageDCAT-AP/releases/0.9.2/ttl/languageDCAT-AP.ttl [R=303,L]


# ===============================
# Generic RDF fallback
# ===============================
# Redirect any versioned IRI dynamically to the Turtle representation if requested
RewriteCond %{HTTP_ACCEPT} application/rdf\+xml|text/turtle|application/ld\+json [NC]
RewriteRule ^([0-9]+\.[0-9]+\.[0-9]+)/?$ https://languagedcat-ap.github.io/LanguageDCAT-AP/releases/$1/ttl/languageDCAT-AP.ttl [R=303,L]
# Redirect unversioned IRIs to "latest"
RewriteCond %{HTTP_ACCEPT} application/rdf\+xml|text/turtle|application/ld\+json [NC]
RewriteRule ^$ https://languagedcat-ap.github.io/LanguageDCAT-AP/releases/0.9.2/ttl/languageDCAT-AP.ttl [R=303,L]
