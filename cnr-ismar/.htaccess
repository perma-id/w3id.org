Options +FollowSymLinks
RewriteEngine On

# Metadata profiles
RewriteRule ^profile/(.*)$ https://github.com/federicobellati/metadata_profiles/tree/main/$1 [R=302,L]

# Ontologies
RewriteRule ^ontology/(.*)$ https://github.com/federicobellati/sosa_sensorTemplate_extension/tree/main/$1 [R=302,L]

# Sensor templates
RewriteRule ^template/(.*)$ https://github.com/federicobellati/sensor_catalog/tree/main/$1 [R=302,L]

# Sensor deployments
RewriteRule ^deployment/(.*)$ https://github.com/federicobellati/sensor_instances/tree/main/$1 [R=302,L]

# Landing page
RewriteRule ^$ https://github.com/federicobellati [R=302,L]
