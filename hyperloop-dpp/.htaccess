Options -MultiViews
RewriteEngine on

# JSON-LD: extract serial number and serve .jsonld from passports/
RewriteCond %{HTTP_ACCEPT} application/ld\+json
RewriteRule ^01/[^/]+/10/[^/]+/21/([^/]+)$ https://DPPIP.github.io/DPP-EUROTUBE/passports/$1.jsonld [R=303,L]

# HTML: extract serial number from GS1 path and redirect to passports/
RewriteRule ^01/[^/]+/10/[^/]+/21/(SN-[0-9]+)$ https://DPPIP.github.io/DPP-EUROTUBE/passports/$1.html [R=303,L]

# Fallback: redirect to main page
RewriteRule ^$ https://DPPIP.github.io/DPP-EUROTUBE/ [R=303,L]
