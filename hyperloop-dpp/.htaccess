Options -MultiViews
RewriteEngine on

# JSON-LD: extract serial number and serve .jsonld from passports/
RewriteCond %{HTTP_ACCEPT} application/ld\+json
RewriteRule ^01/[^/]+/10/[^/]+/21/([^/]+)$ https://DPPIP.github.io/DPP-EUROTUBE/passports/$1.jsonld [R=303,L]

# HTML: redirect to GS1 path on GitHub Pages (serves index.html)
RewriteRule ^(.*)$ https://DPPIP.github.io/DPP-EUROTUBE/$1 [R=303,L]