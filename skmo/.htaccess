#Options -MultiViews

#AddType application/rdf+xml .owl

RewriteEngine on

# OWL context
#RewriteCond %{HTTP_ACCEPT} \*/\* [OR]
#RewriteCond %{HTTP_ACCEPT} application/rdf\+xml
RewriteRule ^$ https://raw.githubusercontent.com/SafetyKnowledgeModelOntology/SKMO/refs/heads/main/skmo.owl [R=302,L]

RewriteRule ^merged$ https://raw.githubusercontent.com/SafetyKnowledgeModelOntology/SKMO/refs/heads/main/skmo-merged.owl [R=302,L]